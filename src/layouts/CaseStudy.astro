---
import Base from './Base.astro';

interface Props {
  title: string;
  description: string;
  client: string;
  tags?: string[];
  image?: string;
  pubDate: Date;
}

const { title, description, client, tags = [], image, pubDate } = Astro.props;
---

<Base title={`${title} — Golden Purple`} description={description} image={image}>
  <div class="topbar-simple">
    <a href="/prace" class="logo-link">← Všechny projekty</a>
  </div>

  <article class="case-wrap">
    <header class="case-header">
      <div class="kicker">
        {tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <p class="client-label">Klient: <strong>{client}</strong></p>
    </header>

    {image && <img src={image} alt={title} class="case-hero" />}

    <div class="prose">
      <slot />
    </div>
  </article>

  <section class="case-cta">
    <p class="eyebrow">Máte podobný projekt?</p>
    <h2>Pojďme to probrat.</h2>
    <a href="/#p7" class="btn">
      Napsat nám
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
        <path d="M5 12h14M13 6l6 6-6 6"/>
      </svg>
    </a>
  </section>
</Base>

<style is:global>
  .topbar-simple {
    position: fixed; top: 0; left: 0; right: 0; z-index: 70;
    padding: 22px clamp(28px, 6vw, 100px);
  }
  .topbar-simple .logo-link {
    font-size: .82rem; letter-spacing: .14em; text-transform: uppercase;
    font-weight: 600; color: var(--muted); transition: color .2s;
  }
  .topbar-simple .logo-link:hover { color: var(--gold); }

  .case-wrap {
    max-width: 900px; margin: 0 auto;
    padding: clamp(100px, 14vh, 140px) clamp(28px, 6vw, 60px) clamp(60px, 10vh, 100px);
  }

  .case-header { margin-bottom: 48px; }

  .kicker { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 18px; }
  .tag {
    font-size: .76rem; letter-spacing: .16em; text-transform: uppercase;
    font-weight: 600; color: var(--gold); border: 1px solid rgba(245,189,2,.3);
    padding: 5px 12px; border-radius: 100px;
  }

  .case-header h1 {
    font-family: var(--display); font-weight: 700;
    font-size: clamp(2.8rem, 8vw, 6rem); line-height: .9;
    letter-spacing: -.04em; margin-bottom: 22px;
  }

  .case-header .lead {
    font-size: clamp(1.05rem, 1.8vw, 1.3rem); color: #D7CEDB;
    line-height: 1.6; margin-bottom: 12px; max-width: 58ch;
  }

  .client-label { font-size: .9rem; color: var(--muted); }
  .client-label strong { color: var(--paper); }

  .case-hero {
    width: 100%; border-radius: 16px; margin-bottom: 56px;
    aspect-ratio: 16/9; object-fit: cover;
  }

  .case-cta {
    text-align: center;
    padding: clamp(60px, 10vh, 100px) clamp(28px, 6vw, 60px);
    border-top: 1px solid var(--line);
  }
  .case-cta .eyebrow {
    font-size: .74rem; letter-spacing: .3em; text-transform: uppercase;
    font-weight: 600; color: var(--gold); margin-bottom: 14px;
  }
  .case-cta h2 {
    font-family: var(--display); font-weight: 700;
    font-size: clamp(2.4rem, 7vw, 5rem); letter-spacing: -.03em;
    line-height: .9; margin-bottom: 36px;
  }
  .btn {
    display: inline-flex; align-items: center; gap: 11px;
    background: var(--gold); color: var(--ink);
    padding: 18px 38px; border-radius: 100px;
    font-weight: 600; font-family: var(--display); font-size: 1.1rem;
    transition: transform .2s, box-shadow .2s;
  }
  .btn:hover { transform: translateY(-3px); box-shadow: 0 18px 44px rgba(245,189,2,.42); }
</style>
