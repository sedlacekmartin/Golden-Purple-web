---
import Base from './Base.astro';
import Topbar from '../components/Topbar.astro';
import Arrow from '../components/Arrow.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  client: string;
  tags?: string[];
  image?: string;
  heroImage?: string;
  pubDate: Date;
  yearLabel?: string;
  id?: string;
}

const { title, description, client, tags = [], image, heroImage, pubDate, yearLabel, id } = Astro.props;
const year = yearLabel ?? String(pubDate.getFullYear());

const allProjects = (await getCollection('prace', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const currentIdx = allProjects.findIndex(p => p.id === id);
const nextTwo: typeof allProjects = [];
for (let i = 1; i < allProjects.length && nextTwo.length < 2; i++) {
  nextTwo.push(allProjects[(currentIdx + i) % allProjects.length]);
}
---

<Base title={`${title} — Golden Purple`} description={description} image={image}>

<div class="progress" id="cs-progress"></div>

<Topbar />

<section class="cs-hero">
  {heroImage && <div class="cs-hero-bg" style={`background-image:url('${heroImage}')`}></div>}
  <div class="hglow"></div>
  <div class="hglow2"></div>
  <div class="wrap-content">
    <div class="cs-kick reveal">
      {tags.map(t => <span class="cs-tag">{t}</span>)}
    </div>
    <h1 class="reveal">{title}</h1>
    <p class="cs-lead reveal">{description}</p>
  </div>
  <div class="cs-metastrip reveal">
    <div class="wrap-wide">
      <div class="ms-grid">
        <div class="ms-cell"><div class="ms-l">Klient</div><div class="ms-v">{client}</div></div>
        <div class="ms-cell"><div class="ms-l">Obor</div><div class="ms-v">{tags[0]}</div></div>
        <div class="ms-cell"><div class="ms-l">Co jsme dělali</div><div class="ms-v">{tags.join(' · ')}</div></div>
        <div class="ms-cell"><div class="ms-l">Rok</div><div class="ms-v">{year}</div></div>
      </div>
    </div>
  </div>
</section>

<section class="cs-showcase">
  <div class="wrap-wide reveal">
    <div class="cs-devices">
      <div class="cs-desktop">
        <div class="cs-dbar"><i></i><i></i><i></i><div class="cs-durl"></div></div>
        <div class="cs-dscreen">
          {image
            ? <img src={image} alt={title} style="width:100%;height:100%;object-fit:cover" />
            : <div class="cs-dph"></div>
          }
        </div>
      </div>
      <div class="cs-mobile">
        <div class="cs-phone">
          <div class="cs-notch"></div>
          <div class="cs-mscreen"><div class="cs-mph">Mobil</div></div>
        </div>
      </div>
    </div>
  </div>
</section>

<div class="cs-prose wrap-content reveal">
  <slot />
</div>

{nextTwo.length > 0 && (
  <section class="cs-nextp wrap-content">
    <div class="cs-nlab reveal">Další projekty</div>
    <div class="cs-nextgrid">
      {nextTwo.map(p => (
        <a class="cs-npcard reveal" href={`/prace/${p.id}`}>
          <div>
            <div class="cs-nt">{p.data.tags.slice(0,2).join(' · ')}</div>
            <h4>{p.data.title}</h4>
          </div>
          <span class="cs-arr">→</span>
        </a>
      ))}
    </div>
  </section>
)}

<section class="cs-cta">
  <div class="cs-cglow"></div>
  <h2 class="reveal">Máte podobný projekt? <em>Postaráme se.</em></h2>
  <p class="reveal">Napište pár slov o tom, co řešíte. Ozveme se do dvou dnů s konkrétními nápady.</p>
  <a class="btn reveal" href="/#kontakt">
    Pojďme do toho
    <Arrow size={18} />
  </a>
</section>


<script>
  let _ac: AbortController | null = null;

  document.addEventListener('astro:page-load', () => {
    const prog = document.getElementById('cs-progress');
    if (!prog) return;

    _ac?.abort();
    _ac = new AbortController();
    const sig = _ac.signal;

    window.addEventListener('scroll', () => {
      const h = document.documentElement;
      prog.style.width = (h.scrollTop / (h.scrollHeight - h.clientHeight) * 100) + '%';
    }, { passive: true, signal: sig });

    const io = new IntersectionObserver(
      es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
      { threshold: .08, rootMargin: '0px 0px -5% 0px' }
    );
    document.querySelectorAll('.reveal').forEach(el => io.observe(el));
    setTimeout(() => document.querySelectorAll('.reveal').forEach(el => el.classList.add('in')), 600);
  });
</script>

</Base>

<style is:global>

/* PROGRESS */
#cs-progress { position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--gold-soft),var(--gold));z-index:90;width:0;pointer-events:none }

/* HERO */
.cs-hero { padding:150px 0 70px;position:relative;overflow:hidden }
.cs-hero-bg { position:absolute;inset:0;background-size:cover;background-position:center 20%;opacity:.28;z-index:0;mask-image:linear-gradient(to bottom,black 30%,transparent 88%);-webkit-mask-image:linear-gradient(to bottom,black 30%,transparent 88%) }
.cs-hero .hglow { position:absolute;top:-20%;right:-10%;width:55%;height:130%;background:radial-gradient(circle,rgba(86,33,94,.55),transparent 65%);filter:blur(70px);pointer-events:none;z-index:1 }
.cs-hero .hglow2 { position:absolute;bottom:-30%;left:-8%;width:40%;height:100%;background:radial-gradient(circle,rgba(245,189,2,.15),transparent 65%);filter:blur(80px);pointer-events:none;z-index:1 }
.cs-hero .wrap-content { position:relative;z-index:2 }
.cs-hero .cs-metastrip { position:relative;z-index:2 }
.cs-kick { display:flex;align-items:center;gap:10px;margin-bottom:26px;flex-wrap:wrap }
.cs-tag { font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);border:1px solid rgba(245,189,2,.3);padding:7px 14px;border-radius:100px }
.cs-hero h1 { font-family:var(--display);font-weight:600;font-size:clamp(3.4rem,11vw,9rem);line-height:.9;letter-spacing:-.035em;margin-bottom:28px }
.cs-lead { max-width:60ch;font-size:clamp(1.15rem,2.2vw,1.5rem);color:var(--text-soft);line-height:1.5 }

/* METASTRIP */
.cs-metastrip { border-top:1px solid var(--line);border-bottom:1px solid var(--line);margin-top:56px }
.ms-grid { display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:var(--line) }
@media(max-width:760px) { .ms-grid { grid-template-columns:repeat(2,1fr) } }
.ms-cell { background:var(--ink);padding:26px clamp(18px,2vw,28px) }
.ms-l { font-size:.66rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);margin-bottom:9px }
.ms-v { font-family:var(--display);font-weight:600;font-size:1.15rem;line-height:1.2 }

/* DEVICE MOCKUP */
.cs-showcase { padding:30px 0 90px }
.cs-devices { position:relative;display:flex;align-items:flex-end;justify-content:center }
.cs-desktop { position:relative;width:min(820px,72vw);z-index:1 }
.cs-dbar { background:#241830;border-radius:14px 14px 0 0;padding:11px 16px;display:flex;align-items:center;gap:7px;border:1px solid var(--line);border-bottom:none }
.cs-dbar i { width:11px;height:11px;border-radius:50%;background:#3d2b4a;display:block }
.cs-durl { margin-left:14px;flex:1;height:22px;background:#1a1022;border-radius:6px }
.cs-dscreen { aspect-ratio:16/10;background:linear-gradient(135deg,rgba(86,33,94,.5),rgba(59,18,67,.4)),repeating-linear-gradient(45deg,rgba(247,247,247,.02) 0 14px,transparent 14px 28px),var(--ink-3);border:1px solid var(--line);border-radius:0 0 14px 14px;display:flex;align-items:center;justify-content:center;overflow:hidden;position:relative }
.cs-dph { font-size:.74rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);text-align:center;padding:20px }
.cs-dscreen::after { content:'';position:absolute;top:0;left:-60%;width:40%;height:100%;background:linear-gradient(90deg,transparent,rgba(255,255,255,.06),transparent);transform:skewX(-20deg);animation:cs-sweep 5s ease-in-out infinite }
@keyframes cs-sweep { 0%,60%{left:-60%} 100%{left:130%} }
.cs-mobile { position:relative;width:min(190px,20vw);margin-left:-70px;margin-bottom:-10px;z-index:2;filter:drop-shadow(0 30px 50px rgba(0,0,0,.5)) }
.cs-phone { background:#241830;border:1px solid var(--line);border-radius:26px;padding:9px;position:relative }
.cs-notch { position:absolute;top:9px;left:50%;transform:translateX(-50%);width:42px;height:5px;background:#1a1022;border-radius:10px;z-index:2 }
.cs-mscreen { aspect-ratio:9/19;background:linear-gradient(160deg,rgba(245,189,2,.18),rgba(86,33,94,.45)),repeating-linear-gradient(45deg,rgba(247,247,247,.02) 0 10px,transparent 10px 20px),var(--ink-3);border-radius:18px;display:flex;align-items:center;justify-content:center;overflow:hidden }
.cs-mph { font-size:.6rem;letter-spacing:.08em;text-transform:uppercase;color:var(--muted);writing-mode:vertical-rl;transform:rotate(180deg);opacity:.7 }
@media(max-width:760px) { .cs-desktop{width:88vw} .cs-mobile{display:none} }

/* PROSE (markdown content) */
.cs-prose { padding:70px 0 90px;max-width:860px }
.cs-prose h2 { font-family:var(--display);font-weight:600;font-size:clamp(1.8rem,3.5vw,2.8rem);line-height:1.08;letter-spacing:-.02em;margin:0 0 20px }
.cs-prose h2:not(:first-child) { margin-top:64px }
.cs-prose h3 { font-family:var(--display);font-weight:600;font-size:clamp(1.3rem,2.5vw,1.8rem);line-height:1.1;letter-spacing:-.015em;margin:40px 0 14px }
.cs-prose p { color:var(--text-card);margin-bottom:18px;font-size:1.06rem;line-height:1.75 }
.cs-prose p b, .cs-prose p strong { color:var(--paper);font-weight:600 }
.cs-prose ul, .cs-prose ol { padding-left:1.4em;margin-bottom:20px;color:var(--text-card) }
.cs-prose li { margin-bottom:10px;font-size:1.02rem;line-height:1.65 }
.cs-prose li::marker { color:var(--gold) }
.cs-prose em { font-style:italic;color:var(--gold-soft) }
.cs-prose hr { border:none;border-top:1px solid var(--line);margin:52px 0 }

/* NEXT PROJECTS */
.cs-nextp { border-top:1px solid var(--line);padding:60px 0 }
.cs-nlab { font-size:.72rem;letter-spacing:.16em;text-transform:uppercase;color:var(--muted);margin-bottom:24px }
.cs-nextgrid { display:grid;grid-template-columns:1fr 1fr;gap:24px }
@media(max-width:700px) { .cs-nextgrid{grid-template-columns:1fr} }
.cs-npcard { border:1px solid var(--line);border-radius:16px;padding:30px;display:flex;justify-content:space-between;align-items:center;gap:20px;transition:.35s;background:linear-gradient(150deg,var(--ink-2),var(--ink)) }
.cs-npcard:hover { border-color:rgba(245,189,2,.4);transform:translateY(-4px) }
.cs-nt { font-size:.64rem;letter-spacing:.12em;text-transform:uppercase;color:var(--gold);margin-bottom:10px }
.cs-npcard h4 { font-family:var(--display);font-weight:600;font-size:1.5rem }
.cs-arr { color:var(--gold);font-size:1.4rem;flex-shrink:0;font-style:normal }

/* CTA */
.cs-cta { text-align:center;padding:90px clamp(22px,5vw,56px) 110px;position:relative;overflow:hidden }
.cs-cglow { position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:60%;height:200%;background:radial-gradient(circle,rgba(86,33,94,.35),transparent 60%);filter:blur(70px);pointer-events:none }
.cs-cta h2 { position:relative;font-family:var(--display);font-weight:600;font-size:clamp(2rem,5vw,3.8rem);line-height:1;letter-spacing:-.02em;max-width:18ch;margin:0 auto 22px }
.cs-cta h2 em { font-style:normal;color:var(--gold) }
.cs-cta p { position:relative;color:var(--text-soft);max-width:42ch;margin:0 auto 32px }

/* REVEAL — defined globally in Base.astro */
@media(prefers-reduced-motion:reduce) { .cs-dscreen::after{animation:none} }
</style>
