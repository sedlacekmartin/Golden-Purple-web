---
import Base from './Base.astro';
import Topbar from '../components/Topbar.astro';
import Arrow from '../components/Arrow.astro';
import { getCollection } from 'astro:content';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  image?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, image, tags = [] } = Astro.props;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const dateStr = pubDate.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long', day: 'numeric' });
const updatedStr = updatedDate?.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long', day: 'numeric' });
const morePosts = allPosts.filter(p => p.data.title !== title).slice(0, 2);
---

<Base title={`${title} — Blog — Golden Purple`} description={description} image={image}>

<div class="bp-prog" id="bp-prog"></div>

<Topbar />

<article>
  <header class="bp-hero">
    <div class="wrap">
      <h1 class="rv">{title}</h1>
      <p class="bp-lead reveal">{description}</p>
      <div class="bp-meta reveal">
        <time datetime={pubDate.toISOString()}>{dateStr}</time>
        {updatedStr && <span class="bp-upd">&nbsp;· aktualizováno {updatedStr}</span>}
      </div>
    </div>
  </header>

  {image && (
    <div class="bp-cover reveal">
      <div class="wrap-content">
        <img src={image} alt={title} />
      </div>
    </div>
  )}

  <div class="bp-prose wrap-text">
    <slot />
  </div>
</article>

{morePosts.length > 0 && (
  <section class="bp-more wrap-text">
    <div class="bp-mlab reveal">Další články</div>
    <div class="bp-mgrid">
      {morePosts.map(p => (
        <a class="bp-mcard reveal" href={`/blog/${p.id}`}>
          <div class="bp-mc-body">
            <h4>{p.data.title}</h4>
            <p>{p.data.description}</p>
          </div>
          <span class="bp-arr">→</span>
        </a>
      ))}
    </div>
  </section>
)}

<section class="bp-cta">
  <div class="bp-cglow"></div>
  <h2 class="rv">Řešíte web nebo brand? <em>Ozvi se.</em></h2>
  <p class="rv">Napište pár slov o tom, co potřebujete. Ozveme se do dvou dnů s konkrétními nápady.</p>
  <a class="btn reveal" href="/#kontakt">
    Pojďme do toho
    <Arrow size={18} />
  </a>
</section>

<script>
  let _ac: AbortController | null = null;
  let _io: IntersectionObserver | null = null;

  function revealAboveFold() {
    const revs = [...document.querySelectorAll<HTMLElement>('.reveal')];
    if (!revs.length) return;
    revs.forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < innerHeight && r.bottom > 0) {
        el.style.transition = 'none';
        el.classList.add('in');
      }
    });
    requestAnimationFrame(() => revs.forEach(el => { el.style.transition = ''; }));
  }

  document.addEventListener('astro:after-swap', revealAboveFold);

  document.addEventListener('astro:page-load', () => {
    const prog = document.getElementById('bp-prog');
    if (!prog) return;

    _ac?.abort();
    _ac = new AbortController();
    const sig = _ac.signal;

    window.addEventListener('scroll', () => {
      const h = document.documentElement;
      prog.style.width = (h.scrollTop / (h.scrollHeight - h.clientHeight) * 100) + '%';
    }, { passive: true, signal: sig });

    _io?.disconnect();
    const revs = [...document.querySelectorAll<HTMLElement>('.reveal')];
    if (!revs.length) return;

    revs.forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < innerHeight && r.bottom > 0 && !el.classList.contains('in')) {
        el.style.transition = 'none';
        el.classList.add('in');
      }
    });
    requestAnimationFrame(() => revs.forEach(el => { el.style.transition = ''; }));

    const hidden = revs.filter(el => !el.classList.contains('in'));
    hidden.forEach((el, i) => { el.style.transitionDelay = (i % 3 * 70) + 'ms'; });
    _io = new IntersectionObserver(
      es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); _io!.unobserve(e.target); } }),
      { threshold: .08, rootMargin: '0px 0px -5% 0px' }
    );
    hidden.forEach(el => _io!.observe(el));
    setTimeout(() => revs.forEach(el => el.classList.add('in')), 600);
  });
</script>

</Base>

<style is:global>

/* PROGRESS */
#bp-prog { position:fixed;top:0;left:0;height:3px;background:linear-gradient(90deg,var(--gold-soft),var(--gold));z-index:90;width:0;pointer-events:none }

/* HERO */
.bp-hero { padding:150px 0 56px; position:relative; overflow:hidden }
.bp-hero::before { content:''; position:absolute; top:-20%; right:-10%; width:55%; height:130%; background:radial-gradient(circle,rgba(86,33,94,.5),transparent 65%); filter:blur(70px); pointer-events:none }
.bp-hero::after  { content:''; position:absolute; bottom:-30%; left:-8%;  width:40%; height:100%; background:radial-gradient(circle,rgba(245,189,2,.12),transparent 65%); filter:blur(80px); pointer-events:none }
.bp-hero .wrap { position:relative; z-index:2 }

.bp-hero h1 { font-family:var(--display); font-weight:600; font-size:clamp(2.8rem,7vw,5.5rem); line-height:.93; letter-spacing:-.035em; margin-bottom:28px }
.bp-lead { font-size:clamp(1.1rem,2vw,1.35rem); color:var(--text-soft); line-height:1.7; margin-bottom:24px }
.bp-meta { font-size:.84rem; color:var(--muted) }
.bp-upd  { opacity:.7 }

/* COVER IMAGE */
.bp-cover { padding:0 0 60px }
.bp-cover img { width:100%; border-radius:20px; border:1px solid var(--line); display:block; aspect-ratio:16/9; object-fit:cover }

/* PROSE */
.bp-prose { padding:60px 0 90px }
.bp-prose h2 { font-family:var(--display); font-weight:600; font-size:clamp(1.7rem,3vw,2.5rem); line-height:1.08; letter-spacing:-.02em; margin:0 0 18px }
.bp-prose h2:not(:first-child) { margin-top:60px }
.bp-prose h3 { font-family:var(--display); font-weight:600; font-size:clamp(1.2rem,2.2vw,1.7rem); line-height:1.1; letter-spacing:-.015em; margin:40px 0 14px }
.bp-prose p  { color:var(--text-prose); margin-bottom:18px; font-size:1.06rem; line-height:1.78 }
.bp-prose p b, .bp-prose p strong { color:var(--paper); font-weight:600 }
.bp-prose ul, .bp-prose ol { padding-left:1.4em; margin-bottom:20px; color:var(--text-prose) }
.bp-prose li { margin-bottom:10px; font-size:1.02rem; line-height:1.65 }
.bp-prose li::marker { color:var(--gold) }
.bp-prose em { font-style:italic; color:var(--gold-soft) }
.bp-prose hr { border:none; border-top:1px solid var(--line); margin:52px 0 }
.bp-prose blockquote { border-left:3px solid var(--gold); padding:16px 24px; margin:32px 0; background:rgba(245,189,2,.06); border-radius:0 12px 12px 0 }
.bp-prose blockquote p { color:var(--paper); font-size:1.1rem; margin:0; font-style:italic }
.bp-prose img { width:100%; border-radius:14px; border:1px solid var(--line); margin:28px 0 }
.bp-prose a { color:var(--gold); text-decoration:underline; text-underline-offset:3px }
.bp-prose code { background:var(--ink-2); color:var(--gold-soft); padding:2px 7px; border-radius:5px; font-size:.9em }
.bp-prose pre { background:var(--ink-2); border:1px solid var(--line); border-radius:10px; padding:1.2em; overflow-x:auto; margin-bottom:1.4em }
.bp-prose pre code { background:none; padding:0; color:var(--paper) }

/* DALŠÍ ČLÁNKY */
.bp-more { border-top:1px solid var(--line); padding:60px 0 }
.bp-mlab { font-size:.72rem; letter-spacing:.16em; text-transform:uppercase; color:var(--muted); margin-bottom:24px }
.bp-mgrid { display:grid; grid-template-columns:1fr 1fr; gap:20px }
@media(max-width:640px) { .bp-mgrid { grid-template-columns:1fr } }
.bp-mcard { border:1px solid var(--line); border-radius:16px; padding:28px; display:flex; justify-content:space-between; align-items:center; gap:20px; transition:transform .3s cubic-bezier(.22,1,.36,1),border-color .3s; background:linear-gradient(150deg,var(--ink-2),var(--ink)) }
.bp-mcard:hover { border-color:var(--gold); transform:translateY(-5px) }
.bp-mcard h4 { font-family:var(--display); font-weight:600; font-size:1.2rem; margin-bottom:8px; line-height:1.15 }
.bp-mc-body p { font-size:.88rem; color:var(--text-prose); line-height:1.5 }
.bp-arr { color:var(--gold); font-size:1.4rem; flex-shrink:0 }

/* CTA */
.bp-cta { text-align:center; padding:90px 0 110px; position:relative; overflow:hidden }
.bp-cglow { position:absolute; top:50%; left:50%; transform:translate(-50%,-50%); width:60%; height:200%; background:radial-gradient(circle,rgba(86,33,94,.35),transparent 60%); filter:blur(70px); pointer-events:none }
.bp-cta h2 { position:relative; font-family:var(--display); font-weight:600; font-size:clamp(2rem,5vw,3.8rem); line-height:1; letter-spacing:-.02em; max-width:18ch; margin:0 auto 22px }
.bp-cta h2 em { font-style:normal; background:linear-gradient(100deg,var(--gold-deep),var(--gold-soft),var(--gold-deep)); background-size:200% 100%; -webkit-background-clip:text; background-clip:text; color:transparent; animation:shine var(--shine-dur) linear infinite alternate }
.bp-cta p { position:relative; color:var(--text-soft); max-width:42ch; margin:0 auto 32px }

/* REVEAL */
.reveal { opacity:0; transform:translateY(30px); transition:opacity .8s cubic-bezier(.22,1,.36,1),transform .8s cubic-bezier(.22,1,.36,1) }
.reveal.in { opacity:1; transform:none }
@media(prefers-reduced-motion:reduce) { .reveal { opacity:1; transform:none; transition:none } }
</style>
