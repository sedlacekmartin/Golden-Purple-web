---
import { ClientRouter } from 'astro:transitions';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  noFooter?: boolean;
}

const {
  title,
  description = 'Golden Purple — digitálně kreativní agentura. Postaráme se o vás královsky. Třebíč · Jihlava · Brno.',
  image = '/assets/og-image.png',
  noindex = false,
  noFooter = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);

const ldSchema = {
  "@context": "https://schema.org",
  "@type": ["LocalBusiness", "ProfessionalService"],
  "name": "Golden Purple",
  "description": "Digitálně kreativní agentura. Stavíme weby, značky a systémy, které firmám přivádí poptávky, šetří ruční práci a zvedají jejich vnímanou hodnotu.",
  "url": Astro.site?.href ?? "https://goldenpurple.cz",
  "telephone": "+420604798369",
  "email": "info@goldenpurple.cz",
  "logo": new URL("/assets/logo-stacked.svg", Astro.site).href,
  "image": new URL("/assets/og-image.png", Astro.site).href,
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Třebíč",
    "addressRegion": "Kraj Vysočina",
    "addressCountry": "CZ"
  },
  "areaServed": [
    { "@type": "City", "name": "Třebíč" },
    { "@type": "City", "name": "Jihlava" },
    { "@type": "City", "name": "Brno" }
  ],
  "founder": {
    "@type": "Person",
    "name": "Martin Sedláček"
  },
  "priceRange": "$$",
  "knowsLanguage": "cs"
};
---

<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="generator" content={Astro.generator} />

  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex, nofollow" />}

  <link rel="canonical" href={canonical} />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonical} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(image, Astro.site)} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:locale" content="cs_CZ" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={new URL(image, Astro.site)} />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="theme-color" content="#0C0610" />

  <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
  <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
  <link
    href="https://api.fontshare.com/v2/css?f[]=clash-display@500,600,700&f[]=general-sans@400,500,600&f[]=space-grotesk@400,500&display=swap"
    rel="stylesheet"
  />

  <!-- Cookie Consent CSS — non-blocking -->
  <link
    rel="stylesheet"
    href="https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3/dist/cookieconsent.css"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3/dist/cookieconsent.css" />
  </noscript>

  <ClientRouter />

  <script type="application/ld+json" set:html={JSON.stringify(ldSchema)} />

  <!-- GTM — nahraď GTM-XXXXXXX svým Container ID -->
  <!-- <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','GTM-XXXXXXX');</script> -->
</head>
<body>

  <!-- GTM noscript -->
  <!-- <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-XXXXXXX" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript> -->

  <slot />

  {!noFooter && <Footer />}

  <!-- View-transition recovery: keep pages visible even if a local reveal script misses a swap. -->
  <script>
    (() => {
      let revealObserver: IntersectionObserver | null = null;
      const revealSelector = '.rv, .reveal, .cv';
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';

      function scrollToPageStart() {
        if (location.hash) return;
        document.documentElement.scrollTop = 0;
        document.body.scrollTop = 0;
        window.scrollTo({ top: 0, left: 0, behavior: 'auto' });
        document.querySelector<HTMLElement>('.scroller')?.scrollTo({ top: 0, left: 0, behavior: 'auto' });
      }

      function settlePageStart() {
        scrollToPageStart();
        window.setTimeout(scrollToPageStart, 0);
        window.setTimeout(scrollToPageStart, 80);
      }

      function revealVisible() {
        const els = [...document.querySelectorAll<HTMLElement>(revealSelector)];
        if (!els.length) return;

        els.forEach((el) => {
          const r = el.getBoundingClientRect();
          if (r.top < innerHeight && r.bottom > 0) {
            el.style.transition = 'none';
            el.classList.add('in');
            if (el.classList.contains('cv')) el.classList.add('active');
          }
        });

        requestAnimationFrame(() => {
          els.forEach((el) => {
            el.style.transition = '';
          });
        });
      }

      function initRevealFallback() {
        revealObserver?.disconnect();
        revealVisible();

        const hidden = [...document.querySelectorAll<HTMLElement>(revealSelector)]
          .filter((el) => !el.classList.contains('in') && !el.classList.contains('active'));

        revealObserver = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            const el = entry.target as HTMLElement;
            el.classList.add('in');
            if (el.classList.contains('cv')) el.classList.add('active');
            revealObserver?.unobserve(el);
          });
        }, { threshold: 0.04, rootMargin: '0px 0px -2% 0px' });

        hidden.forEach((el) => revealObserver?.observe(el));

        window.setTimeout(revealVisible, 120);
        window.setTimeout(revealVisible, 600);
      }

      document.addEventListener('astro:after-swap', () => {
        settlePageStart();
        initRevealFallback();
      });
      document.addEventListener('astro:page-load', initRevealFallback);
      document.addEventListener('DOMContentLoaded', initRevealFallback);
    })();
  </script>

  <!-- Cookie Consent init -->
  <script type="module">
    import * as CookieConsent from 'https://cdn.jsdelivr.net/npm/vanilla-cookieconsent@3/dist/cookieconsent.esm.js';

    function loadClarity() {
      if (window._clarityLoaded) return;
      window._clarityLoaded = true;
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "x9oaprggqn");
    }

    // Preserve #cc-main across VT body swaps — the element is appended to body
    // by vanilla-cookieconsent and would be destroyed when Astro replaces the body.
    let savedCcMain = null;
    document.addEventListener('astro:before-swap', () => {
      savedCcMain = document.getElementById('cc-main');
      savedCcMain?.remove();
    });
    document.addEventListener('astro:after-swap', () => {
      if (savedCcMain && !document.getElementById('cc-main')) {
        document.body.appendChild(savedCcMain);
      }
      savedCcMain = null;
    });

    // Wire up "Nastavení cookies" button on /cookies — called directly in closure
    // so CookieConsent.showPreferences() always refers to the live module function.
    document.addEventListener('astro:page-load', () => {
      document.getElementById('ccPrefsBtn')?.addEventListener('click', () => {
        CookieConsent.showPreferences();
      });
    });

    window.__cc = CookieConsent;

    CookieConsent.run({
      guiOptions: {
        consentModal: { layout: 'box', position: 'bottom right', equalWeightButtons: false },
        preferencesModal: { layout: 'box' },
      },
      onConsent: () => {
        if (CookieConsent.acceptedCategory('analytics')) loadClarity();
      },
      onChange: ({ changedCategories }) => {
        if (changedCategories.includes('analytics')) {
          if (CookieConsent.acceptedCategory('analytics')) loadClarity();
        }
      },
      categories: {
        necessary: {
          enabled: true,
          readOnly: true,
        },
        analytics: {
          autoClear: {
            cookies: [
              { name: /^(_ga|_gid)/ },
              { name: /^(_clck|_clsk|CLID)/ },
            ],
          },
        },
        marketing: {
          autoClear: {
            cookies: [{ name: /^(_fbp|_fbc)/ }],
          },
        },
      },
      language: {
        default: 'cs',
        translations: {
          cs: {
            consentModal: {
              title: 'Cookies',
              description:
                'Používáme cookies pro analýzu návštěvnosti a cílený marketing. Vždy si můžeš nastavit, co povolit.',
              acceptAllBtn: 'Přijmout vše',
              acceptNecessaryBtn: 'Jen nutné',
              showPreferencesBtn: 'Nastavení',
            },
            preferencesModal: {
              title: 'Nastavení cookies',
              acceptAllBtn: 'Přijmout vše',
              acceptNecessaryBtn: 'Jen nutné',
              savePreferencesBtn: 'Uložit nastavení',
              closeIconLabel: 'Zavřít',
              sections: [
                {
                  title: 'Nezbytné cookies',
                  description: 'Tyto cookies jsou nutné pro správné fungování webu a nelze je vypnout.',
                  linkedCategory: 'necessary',
                },
                {
                  title: 'Analytické cookies',
                  description:
                    'Pomáhají nám pochopit, jak návštěvníci web používají (Google Analytics, Microsoft Clarity). Data jsou anonymizovaná.',
                  linkedCategory: 'analytics',
                },
                {
                  title: 'Marketingové cookies',
                  description:
                    'Slouží k zobrazení relevantní reklamy (Meta Pixel, Google Ads). Sdílíme data s reklamními platformami.',
                  linkedCategory: 'marketing',
                },
                {
                  title: 'Více informací',
                  description:
                    'Máš-li dotazy k našim cookies, podívej se na naše <a href="/cookies">Zásady cookies</a> nebo nás kontaktuj na <a href="mailto:info@goldenpurple.cz">info@goldenpurple.cz</a>.',
                },
              ],
            },
          },
        },
      },
    });
  </script>

</body>
</html>

<style is:global>
  :root {
    --gold: #F5BD02;
    --gold-soft: #FFD75E;
    --gold-deep: #C99700;
    --purple: #56215E;
    --purple-deep: #3B1243;
    --purple-bright: #8E4D97;
    --ink: #0C0610;
    --ink-2: #150A1A;
    --paper: #F7F7F7;
    --muted: #A99CAE;
    --line: rgba(247,247,247,.12);
    --display: 'Clash Display', 'General Sans', system-ui, sans-serif;
    --body: 'General Sans', system-ui, sans-serif;

    /* Text colour tokens */
    --text-soft:   var(--text-soft);
    --text-card:   var(--text-card);
    --text-prose:  var(--text-prose);
    --text-bright: var(--text-bright);
    --text-faint:  var(--text-faint);

    /* Semantic tokens */
    --success: var(--success);
    --danger:  var(--danger);
    --error:   var(--error);
  }

  /* View Transitions */
  @keyframes vtIn  { from { opacity: 0; transform: translateY(8px); } }
  @keyframes vtOut { to   { opacity: 0; transform: translateY(-5px); } }
  ::view-transition-old(root) { animation: vtOut .18s ease-in both; }
  ::view-transition-new(root) { animation: vtIn  .24s ease-out .08s both; }
  ::view-transition-old(topbar),
  ::view-transition-new(topbar) { animation: none; mix-blend-mode: normal; }
  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(root), ::view-transition-new(root),
    ::view-transition-old(topbar), ::view-transition-new(topbar) { animation: none; }
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }
  [hidden] { display: none !important; }
  .rv.in,
  .reveal.in,
  .cv.in,
  .cv.active {
    opacity: 1 !important;
    transform: none !important;
  }
  html { overflow-x: clip; }
  body {
    background: var(--ink);
    color: var(--paper);
    font-family: var(--body);
    font-size: 17px;
    -webkit-font-smoothing: antialiased;
  }
  a { color: inherit; text-decoration: none; }
  ::selection { background: var(--gold); color: var(--ink); }

  /* ── Cookie Consent — Golden Purple theme ── */
  #cc-main {
    --cc-font-family: 'General Sans', system-ui, sans-serif;
    --cc-bg: #150A1A;
    --cc-primary-color: #F7F7F7;
    --cc-secondary-color: #A99CAE;
    --cc-modal-border-radius: .875rem;
    --cc-btn-border-radius: .5rem;
    --cc-btn-icon-border-radius: .5rem;
    --cc-overlay-bg: rgba(12,6,16,.75);

    /* primary = gold */
    --cc-btn-primary-bg: #F5BD02;
    --cc-btn-primary-color: #0C0610;
    --cc-btn-primary-border-color: #F5BD02;
    --cc-btn-primary-hover-bg: #FFD75E;
    --cc-btn-primary-hover-color: #0C0610;
    --cc-btn-primary-hover-border-color: #FFD75E;

    /* secondary = ghost */
    --cc-btn-secondary-bg: transparent;
    --cc-btn-secondary-color: #A99CAE;
    --cc-btn-secondary-border-color: rgba(247,247,247,.14);
    --cc-btn-secondary-hover-bg: rgba(247,247,247,.07);
    --cc-btn-secondary-hover-color: #F7F7F7;
    --cc-btn-secondary-hover-border-color: rgba(247,247,247,.22);

    /* separators & blocks */
    --cc-separator-border-color: rgba(247,247,247,.09);
    --cc-cookie-category-block-bg: rgba(247,247,247,.04);
    --cc-cookie-category-block-bg-hover: rgba(247,247,247,.07);
    --cc-cookie-category-block-border: 1px solid rgba(247,247,247,.06);
    --cc-cookie-category-block-hover-border: 1px solid rgba(247,247,247,.12);
    --cc-cookie-category-expanded-block-bg: rgba(247,247,247,.03);
    --cc-cookie-category-expanded-block-hover-bg: rgba(247,247,247,.05);

    /* toggle */
    --cc-toggle-bg-on: #F5BD02;
    --cc-toggle-bg-off: rgba(247,247,247,.18);
    --cc-toggle-bg-readonly: rgba(247,247,247,.10);
    --cc-toggle-knob-bg: #0C0610;
    --cc-toggle-knob-icon-color: transparent;
  }

  /* ── Consent modal box ── */
  #cc-main .cm {
    border: 1px solid rgba(245,189,2,.18);
    box-shadow: 0 0 0 1px rgba(245,189,2,.06), 0 12px 56px rgba(0,0,0,.75);
    max-width: 330px;
  }

  #cc-main .cm-body { padding: 22px 22px 6px; }

  #cc-main .cm-title {
    font-family: 'Clash Display', 'General Sans', system-ui, sans-serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -.02em;
    color: #F7F7F7;
    margin-bottom: 8px;
  }
  #cc-main .cm-text { font-size: .82rem; line-height: 1.65; color: #A99CAE; }
  #cc-main .cm-text a { color: #F5BD02; }

  #cc-main .cm-footer { padding: 14px 22px 22px; flex-direction: column; gap: 8px; }
  #cc-main .cm-btn-group { gap: 8px; }
  #cc-main .cm-footer .btn { width: 100%; justify-content: center; font-size: .84rem; padding: 9px 16px; }
  #cc-main .cm-footer .btn--primary { font-weight: 600; }
  #cc-main .cm-footer .btn--secondary { font-weight: 500; }

  /* ── Preferences modal ── */
  #cc-main .pm {
    border: 1px solid rgba(247,247,247,.10);
    box-shadow: 0 16px 72px rgba(0,0,0,.8);
    max-width: 500px;
  }
  #cc-main .pm-header {
    border-bottom: 1px solid rgba(247,247,247,.08);
    padding: 22px 24px 18px;
  }
  #cc-main .pm-title {
    font-family: 'Clash Display', 'General Sans', system-ui, sans-serif;
    font-weight: 600;
    font-size: 1.2rem;
    letter-spacing: -.02em;
    color: #F7F7F7;
  }
  #cc-main .pm-close-btn { color: #A99CAE; }
  #cc-main .pm-close-btn:hover { color: #F7F7F7; background: rgba(247,247,247,.08); }

  /* ── Toggle section rows (exact class names from vanilla-cookieconsent v3 HTML) ── */

  /* Title row — reset library's light hover bg */
  #cc-main .pm__section-title-wrapper {
    border-radius: 8px;
    transition: background .15s, outline-color .15s;
    outline: 1px solid transparent;
  }
  #cc-main .pm__section-title-wrapper:hover {
    background: rgba(245,189,2,.07) !important;
    outline-color: rgba(245,189,2,.2) !important;
  }

  /* Section title button */
  #cc-main .pm__section-title {
    color: #F7F7F7 !important;
    font-size: .875rem !important;
    font-weight: 600 !important;
    font-family: 'General Sans', system-ui, sans-serif !important;
    background: none !important;
    border: none !important;
  }

  /* Arrow chevron */
  #cc-main .pm__section-arrow svg { stroke: #A99CAE; transition: stroke .15s; }
  #cc-main .pm__section-title-wrapper:hover .pm__section-arrow svg { stroke: #F7F7F7; }

  /* Description text */
  #cc-main .pm__section-desc { color: #A99CAE !important; font-size: .82rem !important; line-height: 1.65 !important; }
  #cc-main .pm__section-desc a { color: #F5BD02 !important; }

  /* ── Toggle switch colors ── */

  /* Track — OFF state */
  #cc-main .toggle__icon {
    background: rgba(247,247,247,.2) !important;
    transition: background .2s !important;
  }
  /* Track — ON state (checkbox checked) */
  #cc-main .section__toggle:checked + .toggle__icon {
    background: #F5BD02 !important;
  }
  /* Track — disabled (Nezbytné, always ON) */
  #cc-main .section__toggle:disabled + .toggle__icon {
    background: rgba(245,189,2,.45) !important;
    cursor: not-allowed !important;
  }

  /* Knob */
  #cc-main .toggle__icon-circle {
    background: #F7F7F7 !important;
    transition: background .2s !important;
  }
  #cc-main .section__toggle:checked + .toggle__icon .toggle__icon-circle {
    background: #0C0610 !important;
  }

  /* Icons inside knob */
  #cc-main .toggle__icon-off svg path { stroke: rgba(247,247,247,.45) !important; }
  #cc-main .toggle__icon-on svg path  { stroke: #F5BD02 !important; }

  /* Info section (Více informací) — no toggle */
  #cc-main .pm__section:not(.pm__section--toggle) .pm__section-title {
    font-size: .68rem !important;
    letter-spacing: .12em !important;
    text-transform: uppercase !important;
    color: #F5BD02 !important;
  }

  #cc-main .pm-footer { border-top: 1px solid rgba(247,247,247,.08); padding: 16px 24px; gap: 10px; }
  #cc-main .pm-footer .btn { font-size: .84rem; padding: 9px 18px; font-weight: 600; }
</style>
