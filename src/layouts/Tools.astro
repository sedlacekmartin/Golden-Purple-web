---
import Base from './Base.astro';
import Topbar from '../components/Topbar.astro';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const { title, description, noindex } = Astro.props;
---

<Base {title} {description} {noindex} noFooter={true}>
  <Topbar />
  <canvas id="aurora"></canvas>
  <slot />

  <script>
    let _toolRaf: number | null = null;
    let _toolAc: AbortController | null = null;

    document.addEventListener('astro:page-load', () => {
      const c = document.getElementById('aurora') as HTMLCanvasElement | null;
      if (!c) return;
      if (_toolRaf !== null) { cancelAnimationFrame(_toolRaf); _toolRaf = null; }
      _toolAc?.abort();
      _toolAc = new AbortController();
      const ctx = c.getContext('2d')!;
      let W: number, H: number, t = 0;
      const reduce = matchMedia('(prefers-reduced-motion:reduce)').matches;
      function sz() { W = c.width = innerWidth; H = c.height = innerHeight; } sz();
      window.addEventListener('resize', sz, { signal: _toolAc.signal });
      const bl = [
        { cx: .25, cy: .35, r: .5,  col: [86, 33, 94]   },
        { cx: .75, cy: .3,  r: .45, col: [59, 18, 67]   },
        { cx: .55, cy: .7,  r: .5,  col: [142, 77, 151] },
        { cx: .4,  cy: .5,  r: .3,  col: [245, 189, 2]  },
      ];
      function dr() {
        t += .003;
        ctx.clearRect(0, 0, W, H);
        ctx.fillStyle = '#0C0610';
        ctx.fillRect(0, 0, W, H);
        bl.forEach((b, i) => {
          const px = (b.cx + Math.sin(t + i * 1.7) * .06) * W;
          const py = (b.cy + Math.cos(t * .9 + i * 2.1) * .06) * H;
          const rad = b.r * Math.min(W, H) * (i === 3 ? .5 : 1);
          const g = ctx.createRadialGradient(px, py, 0, px, py, rad);
          const a = i === 3 ? .12 : .5;
          g.addColorStop(0, `rgba(${b.col[0]},${b.col[1]},${b.col[2]},${a})`);
          g.addColorStop(1, `rgba(${b.col[0]},${b.col[1]},${b.col[2]},0)`);
          ctx.fillStyle = g;
          ctx.beginPath();
          ctx.arc(px, py, rad, 0, 7);
          ctx.fill();
        });
        if (!reduce) _toolRaf = requestAnimationFrame(dr);
      }
      dr();
    });
  </script>

  <style is:global>
    #aurora { position: fixed; inset: 0; z-index: 0; }
    .intro { text-align: center; margin-bottom: 42px; }
    .intro .itag { margin-bottom: 26px; }
    .intro h1 { font-family: var(--display); font-weight: 600; font-size: clamp(2.2rem,6vw,3.8rem); line-height: .98; letter-spacing: -.025em; margin-bottom: 16px; }
    .intro h1 em { font-style: normal; color: var(--gold); }
    .intro p { color: var(--text-soft); margin: 0 auto; font-size: 1.05rem; max-width: 48ch; }
    .foot { text-align: center; color: var(--muted); font-size: .82rem; margin-top: 40px; }
    .foot a { color: var(--gold); }

    /* Checklist items — shared across tool pages */
    .item{display:flex;gap:15px;align-items:flex-start;padding:15px 16px;border-radius:13px;cursor:pointer;transition:background .2s;border:1px solid transparent}
    .item:hover{background:rgba(247,247,247,.03)}
    .item.on{background:rgba(245,189,2,.06);border-color:rgba(245,189,2,.22)}
    .box{flex-shrink:0;width:24px;height:24px;border-radius:7px;border:2px solid var(--muted);display:flex;align-items:center;justify-content:center;margin-top:2px;transition:.2s}
    .item.on .box{border-color:var(--gold);background:var(--gold)}
    .box svg{width:13px;height:13px;color:var(--ink);opacity:0;transition:opacity .2s}
    .item.on .box svg{opacity:1}
    .tx .n{font-weight:600;font-size:1.05rem;margin-bottom:2px}
    .tx .d{font-size:.92rem;color:var(--text-prose);line-height:1.45}

    /* Modal */
    .modal{position:fixed;inset:0;z-index:30;background:rgba(12,6,16,.8);backdrop-filter:blur(10px);display:none;align-items:center;justify-content:center;padding:24px}
    .modal.on{display:flex}
    .card{background:linear-gradient(160deg,var(--ink-2),var(--ink));border:1px solid var(--line);border-radius:22px;padding:40px 34px;max-width:480px;width:100%;text-align:center;position:relative;max-height:90vh;overflow-y:auto}
    .card .big{font-family:var(--display);font-weight:700;font-size:3.4rem;line-height:1;margin-bottom:6px}
    .card .big b{color:var(--gold)}
    .card .of{color:var(--muted);font-family:var(--mono);font-size:.8rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:18px}
    .card h3{font-family:var(--display);font-weight:600;font-size:1.5rem;margin-bottom:10px}
    .card .vtext{color:var(--text-soft);font-size:.97rem;margin-bottom:24px}
    .close{position:absolute;top:16px;right:18px;background:none;border:none;color:var(--muted);font-size:1.6rem;cursor:pointer;line-height:1}

    /* Gate + email form */
    .gate{background:linear-gradient(150deg,var(--purple),var(--purple-deep));border-radius:14px;padding:22px}
    .gate p{font-size:.9rem;color:var(--text-bright);margin-bottom:14px}
    .field{display:flex;gap:9px}
    .field input{flex:1;background:rgba(12,6,16,.4);border:1px solid rgba(247,247,247,.2);border-radius:10px;padding:13px 15px;color:var(--paper);font-family:var(--body);outline:none}
    .field input:focus{border-color:var(--gold)}
    .field button{background:var(--gold);color:var(--ink);border:none;padding:13px 18px;border-radius:10px;font-family:var(--display);font-size:1rem;font-weight:600;cursor:pointer;white-space:nowrap}
    .okmsg{display:none;color:var(--gold);font-family:var(--display);margin-top:10px}
    .okmsg.on{display:block}
  </style>
</Base>
