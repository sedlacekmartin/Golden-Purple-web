<script>
  // Bundlovaný (ne is:inline) kvůli CSP bez 'unsafe-inline'; page-load kvůli view transitions
  const fillYear = () =>
    document.querySelectorAll('.yr').forEach(el => { el.textContent = String(new Date().getFullYear()); });
  fillYear();
  document.addEventListener('astro:page-load', fillYear);
</script>

<style is:global>
  .site-foot {
    position: relative; z-index: 2;
    text-align: center;
    font-size: .78rem;
    color: var(--muted);
    padding: 32px clamp(28px, 6vw, 100px);
    border-top: 1px solid var(--line);
  }
  .site-foot a { color: var(--muted); text-decoration: none; transition: color .2s; }
  .site-foot a:hover { color: var(--gold); }
</style>
