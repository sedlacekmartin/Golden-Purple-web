---
interface Props {
  backHref: string;
  backLabel: string;
}
const { backHref, backLabel } = Astro.props;
---

<header class="tpb">
  <a class="tpb-logo" href="/"><img src="/assets/logo-stacked.svg" alt="Golden Purple" /></a>
  <div class="tpb-right">
    <a class="tpb-back" href={backHref}>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M11 18l-6-6 6-6"/></svg>
      {backLabel}
    </a>
    <button class="tpb-burger" id="nav-toggle" aria-label="Menu" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<div class="nav-overlay" id="nav-overlay" aria-hidden="true">
  <button class="nav-close" id="nav-close" aria-label="Zavřít menu">
    <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M18 6L6 18M6 6l12 12"/></svg>
  </button>
  <nav class="nav-links">
    <a href="/" class="nav-link">Domů</a>
    <a href="/prace/" class="nav-link">Naše práce</a>
    <a href="/blog/" class="nav-link">Blog</a>
    <a href="/#p7" class="nav-link">Kontakt</a>
  </nav>
  <div class="nav-foot">
    <span>Golden <span class="np">Purple</span></span>
    <span>Třebíč · Jihlava · Brno</span>
  </div>
</div>

<script>
  const toggle = document.getElementById('nav-toggle')!;
  const close  = document.getElementById('nav-close')!;
  const overlay = document.getElementById('nav-overlay')!;

  function open() {
    overlay.classList.add('open');
    overlay.setAttribute('aria-hidden', 'false');
    toggle.setAttribute('aria-expanded', 'true');
    toggle.classList.add('active');
    document.body.style.overflow = 'hidden';
  }
  function closeNav() {
    overlay.classList.remove('open');
    overlay.setAttribute('aria-hidden', 'true');
    toggle.setAttribute('aria-expanded', 'false');
    toggle.classList.remove('active');
    document.body.style.overflow = '';
  }

  toggle.addEventListener('click', () => overlay.classList.contains('open') ? closeNav() : open());
  close.addEventListener('click', closeNav);
  overlay.addEventListener('click', e => { if (e.target === overlay) closeNav(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeNav(); });
</script>

<style is:global>
/* TOPBAR */
.tpb { position:fixed;top:0;left:0;right:0;z-index:80;display:flex;justify-content:space-between;align-items:center;padding:20px clamp(22px,5vw,56px);background:linear-gradient(180deg,rgba(12,6,16,.92),transparent);backdrop-filter:blur(8px) }
.tpb-logo img { height:38px;width:auto;display:block }
.tpb-right { display:flex;align-items:center;gap:14px }
.tpb-back { font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted);border:1px solid var(--line);padding:10px 18px;border-radius:100px;transition:.25s;display:flex;align-items:center;gap:8px }
.tpb-back:hover { color:var(--gold);border-color:var(--gold) }

/* HAMBURGER */
.tpb-burger { display:flex;flex-direction:column;justify-content:center;gap:5px;width:42px;height:42px;border:1px solid var(--line);border-radius:100px;background:none;cursor:pointer;padding:0 11px;transition:border-color .25s }
.tpb-burger:hover { border-color:var(--gold) }
.tpb-burger span { display:block;height:1.5px;background:var(--paper);border-radius:2px;transition:transform .35s cubic-bezier(.77,0,.18,1),opacity .25s,width .35s }
.tpb-burger span:nth-child(3) { width:65% }
.tpb-burger.active span:nth-child(1) { transform:translateY(6.5px) rotate(45deg) }
.tpb-burger.active span:nth-child(2) { opacity:0;transform:scaleX(0) }
.tpb-burger.active span:nth-child(3) { width:100%;transform:translateY(-6.5px) rotate(-45deg) }

/* OVERLAY */
.nav-overlay { position:fixed;inset:0;z-index:100;background:var(--ink);display:flex;flex-direction:column;justify-content:center;align-items:center;opacity:0;pointer-events:none;transition:opacity .45s cubic-bezier(.77,0,.18,1) }
.nav-overlay.open { opacity:1;pointer-events:all }
.nav-close { position:absolute;top:24px;right:clamp(22px,5vw,56px);width:46px;height:46px;border:1px solid var(--line);border-radius:100px;background:none;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--muted);transition:.25s }
.nav-close:hover { border-color:var(--gold);color:var(--gold) }

/* NAV LINKS */
.nav-links { display:flex;flex-direction:column;align-items:center;gap:6px }
.nav-link { font-family:var(--display);font-weight:600;font-size:clamp(2.6rem,7vw,5.2rem);line-height:1.05;letter-spacing:-.03em;color:var(--paper);transition:color .2s;position:relative }
.nav-link::after { content:'';position:absolute;left:0;bottom:-2px;width:0;height:2px;background:var(--gold);transition:width .35s cubic-bezier(.77,0,.18,1) }
.nav-link:hover { color:var(--gold) }
.nav-link:hover::after { width:100% }

/* staggered entrance */
.nav-overlay.open .nav-link { animation:nav-in .55s cubic-bezier(.22,1,.36,1) both }
.nav-overlay.open .nav-link:nth-child(1) { animation-delay:.05s }
.nav-overlay.open .nav-link:nth-child(2) { animation-delay:.11s }
.nav-overlay.open .nav-link:nth-child(3) { animation-delay:.17s }
.nav-overlay.open .nav-link:nth-child(4) { animation-delay:.23s }
@keyframes nav-in { from{opacity:0;transform:translateY(28px)} to{opacity:1;transform:none} }

/* FOOTER v overlay */
.nav-foot { position:absolute;bottom:32px;font-size:.8rem;color:var(--muted);display:flex;flex-direction:column;align-items:center;gap:4px;font-family:var(--display);font-weight:600 }
.nav-foot .np { color:var(--gold) }
</style>
