<script>
  let _ac: AbortController | null = null;
  let _firstLoad = true;

  function initTopbar() {
    // Cleanup previous listeners
    _ac?.abort();
    _ac = new AbortController();
    const sig = _ac.signal;

    const paths = document.querySelectorAll<SVGPathElement>('.tpb-logo svg path');
    if (_firstLoad) {
      // Initial load — randomized letter animation
      const n = paths.length;
      const order = Array.from({ length: n }, (_, i) => i);
      for (let i = n - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [order[i], order[j]] = [order[j], order[i]];
      }
      paths.forEach((p, i) => { p.style.animationDelay = (order[i] * 0.08).toFixed(2) + 's'; });
      _firstLoad = false;
    } else {
      // Navigation — topbar already visible via view transition, show logo instantly
      paths.forEach(p => { p.style.animation = 'none'; (p as HTMLElement).style.opacity = '1'; });
    }

    const btn     = document.getElementById('menuBtn')!;
    const overlay = document.getElementById('overlay')!;
    const tpb     = document.getElementById('tpb')!;

    const closeMenu = () => {
      overlay.classList.remove('open');
      btn.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    };
    const openMenu = () => {
      overlay.classList.add('open');
      btn.classList.add('open');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    };

    btn.addEventListener('click', () =>
      overlay.classList.contains('open') ? closeMenu() : openMenu(), { signal: sig });
    overlay.querySelectorAll<HTMLAnchorElement>('nav a').forEach(a =>
      a.addEventListener('click', closeMenu, { signal: sig }));
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape') closeMenu();
    }, { signal: sig });

    const scroller = document.querySelector<HTMLElement>('.scroller');
    const onScroll = () => {
      const scrolled = window.scrollY > 20 || (scroller ? scroller.scrollTop > 20 : false);
      tpb.classList.toggle('scrolled', scrolled);
    };
    window.addEventListener('scroll', onScroll, { passive: true, signal: sig });
    scroller?.addEventListener('scroll', onScroll, { passive: true, signal: sig });
    onScroll();
  }

  // Close menu before page swap
  document.addEventListener('astro:before-swap', () => {
    document.getElementById('overlay')?.classList.remove('open');
    document.getElementById('menuBtn')?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
  });

  document.addEventListener('astro:page-load', initTopbar);
</script>

<style is:global>
/* TOPBAR */
.tpb{position:fixed;top:0;left:0;right:0;z-index:110;display:flex;justify-content:space-between;align-items:center;padding:26px clamp(28px,6vw,100px);transition:background .35s,backdrop-filter .35s;pointer-events:none}
.tpb-logo,.menu-btn{pointer-events:auto}
.tpb-logo svg{height:46px;width:auto;display:block;overflow:visible}
.tpb-logo svg path{opacity:0;animation:logoIn .55s cubic-bezier(.19,1,.22,1) forwards;transform-box:fill-box;transform-origin:center bottom}
@keyframes logoIn{from{opacity:0;transform:translateY(7px)}to{opacity:1;transform:translateY(0)}}
@media(prefers-reduced-motion:reduce){.tpb-logo svg path{animation:none;opacity:1}}
.tpb.scrolled{background:rgba(12,6,16,.88);backdrop-filter:blur(18px)}

/* HAMBURGER */
.menu-btn{display:flex;flex-direction:column;justify-content:center;gap:5px;width:46px;height:46px;border:1px solid var(--line);border-radius:100px;background:rgba(12,6,16,.4);cursor:pointer;transition:.25s;padding:0;align-items:center}
.menu-btn:hover{border-color:var(--gold)}
.menu-btn span{display:block;width:18px;height:2px;background:var(--paper);border-radius:2px;transition:transform .3s,opacity .3s}
.menu-btn.open span:nth-child(1){transform:translateY(7px) rotate(45deg)}
.menu-btn.open span:nth-child(2){opacity:0}
.menu-btn.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg)}

/* OVERLAY */
.overlay{position:fixed;inset:0;z-index:100;background:rgba(12,6,16,.97);backdrop-filter:blur(16px);display:flex;flex-direction:column;justify-content:center;padding:0 clamp(28px,8vw,120px);opacity:0;visibility:hidden;transition:opacity .4s,visibility .4s}
.overlay.open{opacity:1;visibility:visible}
.overlay .ov-glow{position:absolute;top:-10%;right:-5%;width:50vw;height:50vw;max-width:700px;max-height:700px;border-radius:50%;background:radial-gradient(circle,rgba(86,33,94,.5),transparent 60%);filter:blur(70px);pointer-events:none}
.overlay nav{position:relative;z-index:2;display:flex;flex-direction:column;gap:6px}
.overlay nav a{font-family:var(--display);font-weight:600;font-size:clamp(2.4rem,7vw,5rem);line-height:1.05;letter-spacing:-.02em;color:var(--paper);text-decoration:none;display:flex;align-items:baseline;gap:18px;padding:6px 0;width:fit-content;opacity:0;transform:translateY(30px);transition:color .25s,transform .6s cubic-bezier(.19,1,.22,1),opacity .6s}
.overlay.open nav a{opacity:1;transform:none}
.overlay.open nav a:nth-child(1){transition-delay:.08s}
.overlay.open nav a:nth-child(2){transition-delay:.15s}
.overlay.open nav a:nth-child(3){transition-delay:.22s}
.overlay.open nav a:nth-child(4){transition-delay:.29s}
.overlay.open nav a:nth-child(5){transition-delay:.36s}
.overlay.open nav a:nth-child(6){transition-delay:.43s}
.overlay.open nav a:nth-child(7){transition-delay:.50s}
.overlay nav a .num{font-size:.9rem;font-weight:500;color:var(--gold);letter-spacing:.1em;min-width:2.2em;font-variant-numeric:tabular-nums;flex-shrink:0}
.overlay nav a:hover{color:var(--gold)}
.overlay .ov-foot{position:absolute;bottom:clamp(30px,6vh,60px);left:clamp(28px,8vw,120px);z-index:2;display:flex;gap:26px;flex-wrap:wrap;font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.overlay .ov-foot a{color:var(--muted);text-decoration:none;transition:color .2s}
.overlay .ov-foot a:hover{color:var(--gold)}
@media(prefers-reduced-motion:reduce){.overlay,.overlay nav a{transition:none!important}.overlay nav a{opacity:1;transform:none}}
</style>
