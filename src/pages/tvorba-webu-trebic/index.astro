---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Topbar from '../../components/Topbar.astro';
import Arrow from '../../components/Arrow.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Uděláte web i firmě mimo Třebíč?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ano. Sídlíme v Třebíči a osobní schůzky nabízíme také v Jihlavě a Brně, ale pracujeme s firmami po celé České republice. Vzdálenější projekty řešíme online bez omezení."
      }
    },
    {
      "@type": "Question",
      "name": "Jak dlouho trvá tvorba webu?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Běžný firemní web dodáme za 4 až 8 týdnů od zahájení spolupráce. Záleží na rozsahu a připravenosti podkladů. Expresní realizace je možná, pokud neohrozí kvalitu výsledku."
      }
    },
    {
      "@type": "Question",
      "name": "Musíme mít připravené texty a fotografie?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ne. Stačí vědět, co prodáváte a komu. Texty, strukturu webu i doporučení k fotografiím připravíme společně, copywriting i focení umíme zajistit."
      }
    },
    {
      "@type": "Question",
      "name": "Postaráte se o web i po spuštění?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ano. Nabízíme pravidelnou správu, aktualizace, měření výsledků a další rozvoj webu. Většina klientů s námi po spuštění pokračuje dlouhodobě."
      }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "serviceType": "Tvorba webových stránek",
  "name": "Tvorba webů Třebíč",
  "description": "Tvorba webových stránek na míru pro firmy z Třebíče a Vysočiny. Strategie, design, texty, vývoj a dlouhodobá správa od místního kreativního studia.",
  "provider": {
    "@type": "LocalBusiness",
    "name": "Golden Purple",
    "url": "https://goldenpurple.cz",
    "telephone": "+420604798369",
    "email": "info@goldenpurple.cz",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Třebíč",
      "addressRegion": "Kraj Vysočina",
      "addressCountry": "CZ"
    }
  },
  "areaServed": [
    { "@type": "City", "name": "Třebíč" },
    { "@type": "AdministrativeArea", "name": "Kraj Vysočina" }
  ],
  "inLanguage": "cs"
};
---

<Base
  title="Tvorba webů Třebíč — weby, které přivádí poptávky | Golden Purple"
  description="Tvorba webových stránek v Třebíči. Kreativní studio Golden Purple staví weby, které odpovídají kvalitě vaší práce a dělají z návštěvníků poptávky. První konzultace zdarma."
>

<Topbar />

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(serviceSchema)} />

<main class="lw">

  <!-- HERO -->
  <section class="lw-hero">
    <div class="lw-glow"></div>
    <div class="wrap-text">
      <div class="itag reveal"><span class="d"></span><span class="mono">Třebíč · Kraj Vysočina</span></div>
      <h1 class="reveal">Tvorba webů <em>v Třebíči</em></h1>
      <p class="lw-sub reveal">Jsme kreativní studio přímo z Třebíče. Stavíme webové stránky, které odpovídají kvalitě vaší práce a dělají z návštěvníků poptávky. Strategie, design, texty, vývoj i správa na jednom místě.</p>
      <div class="lw-cta reveal">
        <a class="btn" href="/#kontakt">Probrat projekt<Arrow size={17} /></a>
        <a class="lw-sec" href="/scan/">Nejdřív otestovat současný web zdarma</a>
      </div>
    </div>
  </section>

  <!-- PROČ MÍSTNÍ -->
  <section class="lw-section">
    <div class="wrap-text">
      <p class="eyebrow reveal">Proč studio z Třebíče</p>
      <h2 class="reveal">Web od někoho, s kým si <em>podáte ruku</em></h2>
      <div class="lw-grid">
        <div class="lw-card reveal">
          <span class="lw-n">01</span>
          <h3>Osobní schůzka, ne videohovor s agenturou</h3>
          <p>Projekt probereme u vás ve firmě nebo u kávy v Třebíči. Uvidíte, s kým pracujete, a my pochopíme váš provoz na vlastní oči. Schůzky zvládneme i v Jihlavě a Brně.</p>
        </div>
        <div class="lw-card reveal">
          <span class="lw-n">02</span>
          <h3>Rozumíme místnímu trhu</h3>
          <p>Víme, jak nakupují zákazníci na Vysočině a co funguje na místní firmy, restaurace i výrobce. Web nestavíme podle pražských šablon, ale podle vašich zákazníků.</p>
        </div>
        <div class="lw-card reveal">
          <span class="lw-n">03</span>
          <h3>Jeden partner pro celý web</h3>
          <p>Návrh, texty, grafika, vývoj, SEO i následná správa vznikají u nás pod jednou střechou. Nemusíte koordinovat tři dodavatele a hlídat, jestli si rozumí.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CO DOSTANETE -->
  <section class="lw-section lw-section--dark">
    <div class="wrap-text">
      <p class="eyebrow reveal">Co ve webu dostanete</p>
      <h2 class="reveal">Webové stránky jako <em>obchodní nástroj</em></h2>
      <p class="lw-perex reveal">Hezkých webů je plno. My stavíme weby, které mají práci: vysvětlit nabídku, vzbudit důvěru a dovést návštěvníka k poptávce, rezervaci nebo objednávce.</p>
      <ul class="lw-list">
        <li class="reveal"><b>Strategie a struktura</b> podle toho, co prodáváte a komu. Nezačínáme barvami, ale argumenty.</li>
        <li class="reveal"><b>Texty, které prodávají.</b> Copywriting je součást práce, ne položka navíc.</li>
        <li class="reveal"><b>Design na míru,</b> který odliší vaši firmu od konkurence se šablonou.</li>
        <li class="reveal"><b>Technický základ:</b> rychlé načítání, mobilní verze, SEO a zabezpečení. Věci, které Google i zákazníci poznají.</li>
        <li class="reveal"><b>Měření a správa.</b> Po spuštění sledujeme, co web přináší, a průběžně ho zlepšujeme.</li>
      </ul>
      <div class="lw-work reveal">
        <p>Jak taková práce vypadá, vidíte v <a href="/prace/">našich projektech</a>. Mezi klienty patří AMFELS, Restaurace Baroko, Arlex nebo penzion Na Rachačkách.</p>
      </div>
    </div>
  </section>

  <!-- PROCES -->
  <section class="lw-section">
    <div class="wrap-text">
      <p class="eyebrow reveal">Jak spolupráce probíhá</p>
      <h2 class="reveal">Od první schůzky <em>ke spuštění</em></h2>
      <div class="lw-steps">
        <div class="lw-step reveal"><span class="lw-n">01</span><div><h3>Úvodní konzultace zdarma</h3><p>Probereme, co má web dělat, komu prodává a kde dnes ztrácíte zákazníky.</p></div></div>
        <div class="lw-step reveal"><span class="lw-n">02</span><div><h3>Návrh struktury a obsahu</h3><p>Nejdřív argumentace a cesta návštěvníka, potom design. Vše schvalujete průběžně.</p></div></div>
        <div class="lw-step reveal"><span class="lw-n">03</span><div><h3>Design a vývoj</h3><p>Web vzniká na míru včetně textů, s důrazem na rychlost a použitelnost na mobilu.</p></div></div>
        <div class="lw-step reveal"><span class="lw-n">04</span><div><h3>Spuštění a péče</h3><p>Nasadíme, změříme a dál rozvíjíme. Web není plakát, má pracovat.</p></div></div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="lw-section lw-section--dark">
    <div class="wrap-text">
      <p class="eyebrow reveal">Časté otázky</p>
      <h2 class="reveal">Na co se firmy z Třebíče <em>ptají nejčastěji</em></h2>
      <div class="lw-faq">
        <details class="reveal">
          <summary>Uděláte web i firmě mimo Třebíč?</summary>
          <p>Ano. Sídlíme v Třebíči a osobní schůzky nabízíme také v Jihlavě a Brně, ale pracujeme s firmami po celé republice. Vzdálenější projekty řešíme online bez omezení.</p>
        </details>
        <details class="reveal">
          <summary>Jak dlouho trvá tvorba webu?</summary>
          <p>Běžný firemní web dodáme za 4 až 8 týdnů od zahájení spolupráce. Záleží na rozsahu a připravenosti podkladů.</p>
        </details>
        <details class="reveal">
          <summary>Musíme mít připravené texty a fotky?</summary>
          <p>Ne. Stačí vědět, co prodáváte a komu. Texty i strukturu připravíme společně, copywriting a focení umíme zajistit.</p>
        </details>
        <details class="reveal">
          <summary>Postaráte se o web i po spuštění?</summary>
          <p>Ano. Nabízíme pravidelnou správu, aktualizace, měření výsledků a další rozvoj. Většina klientů s námi pokračuje dlouhodobě.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="lw-final">
    <div class="lw-glow lw-glow--bottom"></div>
    <div class="wrap-text">
      <h2 class="reveal">Pojďme probrat <em>váš web</em></h2>
      <p class="lw-sub reveal">Napište nám pár vět o firmě a o tom, co má web umět. Ozveme se do dvou pracovních dnů s prvním pohledem na situaci. Konzultace je zdarma a nezávazná.</p>
      <div class="lw-cta reveal">
        <a class="btn" href="/#kontakt">Napsat poptávku<Arrow size={17} /></a>
        <a class="lw-sec" href="tel:+420604798369">+420 604 798 369</a>
      </div>
    </div>
  </section>

</main>

</Base>

<style is:global>
.lw{padding-top:120px}
.lw .wrap-text{position:relative;z-index:2}

.lw-hero{position:relative;padding:60px 0 90px;overflow:hidden}
.lw-glow{position:absolute;top:-20%;left:-10%;width:60vw;height:60vw;max-width:750px;max-height:750px;border-radius:50%;background:radial-gradient(circle,rgba(86,33,94,.45),transparent 62%);filter:blur(80px);z-index:0;pointer-events:none}
.lw-glow--bottom{top:auto;left:50%;bottom:-30%;transform:translateX(-50%);background:radial-gradient(circle,rgba(245,189,2,.12),transparent 62%)}

.lw h1{font-family:var(--display);font-weight:700;font-size:clamp(2.6rem,7vw,5.5rem);line-height:.95;letter-spacing:-.03em;margin:10px 0 24px}
.lw h1 em,.lw h2 em{font-style:normal;background:linear-gradient(100deg,var(--gold-deep),var(--gold-soft),var(--gold-deep));background-size:200% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;animation:shine var(--shine-dur) linear infinite alternate}
.lw h2{font-family:var(--display);font-weight:600;font-size:clamp(2rem,5vw,3.6rem);line-height:.98;letter-spacing:-.025em;margin:12px 0 30px}
.lw h3{font-family:var(--display);font-weight:600;font-size:clamp(1.1rem,2vw,1.4rem);letter-spacing:-.015em;line-height:1.15;margin-bottom:8px}

.lw-sub{font-size:clamp(1.02rem,1.7vw,1.25rem);color:var(--text-soft);line-height:1.7;max-width:56ch}
.lw-perex{font-size:clamp(1rem,1.6vw,1.15rem);color:var(--text-soft);line-height:1.7;max-width:58ch;margin-bottom:28px}
.lw-cta{display:flex;align-items:center;gap:24px;flex-wrap:wrap;margin-top:32px}
.lw-sec{font-family:var(--display);font-weight:600;font-size:1rem;color:var(--muted);border-bottom:1px solid var(--line);padding-bottom:3px;transition:color .2s,border-color .2s}
.lw-sec:hover{color:var(--gold);border-color:var(--gold)}

.lw-section{padding:clamp(60px,9vh,110px) 0;position:relative}
.lw-section--dark{background:var(--ink-2)}
.lw-final{padding:clamp(80px,12vh,140px) 0;position:relative;overflow:hidden;text-align:left}

.lw-grid{display:grid;grid-template-columns:1fr;gap:14px}
.lw-card{border:1px solid var(--line);border-radius:16px;padding:24px 22px;background:linear-gradient(160deg,rgba(247,247,247,.03),transparent);transition:border-color .3s}
.lw-card:hover{border-color:rgba(245,189,2,.3)}
.lw-card p{font-size:clamp(.92rem,1.5vw,1.02rem);color:var(--text-soft);line-height:1.7}
.lw-n{font-family:var(--display);font-weight:500;font-size:.95rem;color:var(--gold);display:block;margin-bottom:10px}

.lw-list{list-style:none;margin:0;padding:0}
.lw-list li{padding:14px 0 14px 26px;border-top:1px solid var(--line);position:relative;font-size:clamp(.95rem,1.5vw,1.05rem);color:var(--text-soft);line-height:1.7}
.lw-list li:last-child{border-bottom:1px solid var(--line)}
.lw-list li::before{content:'';position:absolute;left:0;top:23px;width:7px;height:7px;border-radius:50%;background:var(--gold);opacity:.75}
.lw-list b{color:var(--paper);font-weight:600}
.lw-work{margin-top:26px}
.lw-work p{font-size:.95rem;color:var(--muted);line-height:1.7}
.lw-work a{color:var(--gold);border-bottom:1px solid rgba(245,189,2,.4)}

.lw-steps{display:flex;flex-direction:column}
.lw-step{display:flex;gap:20px;padding:20px 0;border-top:1px solid var(--line);align-items:baseline}
.lw-step:last-child{border-bottom:1px solid var(--line)}
.lw-step .lw-n{margin-bottom:0;min-width:2rem}
.lw-step p{font-size:clamp(.92rem,1.5vw,1.02rem);color:var(--text-soft);line-height:1.7}

.lw-faq details{border-top:1px solid var(--line);padding:4px 0}
.lw-faq details:last-child{border-bottom:1px solid var(--line)}
.lw-faq summary{cursor:pointer;font-family:var(--display);font-weight:600;font-size:clamp(1.05rem,2vw,1.3rem);padding:16px 0;list-style:none;display:flex;justify-content:space-between;align-items:center;gap:16px;transition:color .25s}
.lw-faq summary::-webkit-details-marker{display:none}
.lw-faq summary::after{content:'›';color:var(--muted);font-size:1.4rem;transition:transform .3s,color .3s;flex-shrink:0}
.lw-faq details[open] summary{color:var(--gold)}
.lw-faq details[open] summary::after{transform:rotate(90deg);color:var(--gold)}
.lw-faq details p{font-size:clamp(.92rem,1.5vw,1.02rem);color:var(--text-soft);line-height:1.7;padding:0 0 18px;max-width:62ch}

@media(min-width:720px){.lw-grid{grid-template-columns:repeat(3,1fr)}}
</style>
