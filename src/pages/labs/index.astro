---
import Base from '../../layouts/Base.astro';
import Topbar from '../../components/Topbar.astro';
import Arrow from '../../components/Arrow.astro';
---

<Base
  title="Golden Labs — Digitální produkty — Golden Purple"
  description="Vlastní digitální produkty Golden Purple — rezervační systémy, správa flotily, QR tracking a provozní nástroje pro firemní weby."
>

<Topbar />

<section class="lhero">
  <div class="wrap">
    <span class="eyebrow reveal">Golden Labs</span>
    <h1 class="reveal">Digitální produkty.<br><em>Stavěné k použití.</em></h1>
    <p class="lhero-sub reveal">Vedle klientské práce vyvíjíme vlastní nástroje — protože správné řešení někdy prostě neexistuje hotové. Klientům to přináší systémy na míru místo náhodného lepení pluginů.</p>
  </div>
</section>

<section class="lproducts">
  <div class="wrap">
    <div class="labs-grid">

      <div class="lprod reveal">
        <span class="lp-status live">Dostupný</span>
        <div class="lp-label"><span class="lg">GOLDEN</span><span class="lsep">·</span><span class="ln2">Suite</span></div>
        <h3>Chytrý provozní balík pro firemní weby</h3>
        <p>WordPress pluginy, které firmám přidají na web rezervace, otevírací dobu, poptávky, nabídky, akce, recenze a jednoduchou správu kontaktů. Vše jako jednotný balík místo hromady nesourodých pluginů.</p>
        <div class="lp-chips"><span class="pchip">WordPress</span><span class="pchip">Rezervace</span><span class="pchip">Otevírací doba</span><span class="pchip">Poptávky</span><span class="pchip">Recenze</span></div>
        <div class="lp-screen" aria-hidden="true">
          <div class="lps-bar"><i></i><i></i><i></i></div>
          <div class="lps-body">
            <div class="lps-row a"></div>
            <div class="lps-row"></div>
            <div class="lps-row s"></div>
            <div class="lps-row"></div>
            <div class="lps-row a"></div>
            <div class="lps-row s"></div>
          </div>
        </div>
      </div>

      <div class="lprod reveal">
        <span class="lp-status soon">Beta</span>
        <div class="lp-label"><span class="lg">GOLDEN</span><span class="lsep">·</span><span class="ln2">Fleet</span></div>
        <h3>Správa flotily vozidel</h3>
        <p>Přehled nad celou firemní flotilou na jednom místě — pojištění, STK, dálniční známky, povinné ručení, havarijní pojištění a termíny servisů. Žádné tabulky v Excelu, žádné prohledávání složek.</p>
        <div class="lp-chips"><span class="pchip">STK</span><span class="pchip">Pojištění</span><span class="pchip">Dálniční známky</span><span class="pchip">Servis</span><span class="pchip">Náklady</span></div>
        <div class="lp-screen" aria-hidden="true">
          <div class="lps-bar"><i></i><i></i><i></i></div>
          <div class="lps-body">
            <div class="lps-row s"></div>
            <div class="lps-row a"></div>
            <div class="lps-row"></div>
            <div class="lps-row s"></div>
            <div class="lps-row"></div>
            <div class="lps-row a"></div>
          </div>
        </div>
      </div>

      <div class="lprod reveal">
        <span class="lp-status soon">Beta</span>
        <div class="lp-label"><span class="lg">GOLDEN</span><span class="lsep">·</span><span class="ln2">QR Tracking</span></div>
        <h3>QR tracking platforma</h3>
        <p>Vlastní platforma pro tvorbu dynamických QR kódů, měření scanů, správu kampaní a propojení offline marketingu s webovou analytikou. Zjistěte, které tiskové materiály skutečně fungují.</p>
        <div class="lp-chips"><span class="pchip">Dynamické QR</span><span class="pchip">Tracking</span><span class="pchip">Kampaně</span><span class="pchip">Analytika</span></div>
        <div class="lp-screen" aria-hidden="true">
          <div class="lps-bar"><i></i><i></i><i></i></div>
          <div class="lps-body">
            <div class="lps-row"></div>
            <div class="lps-row a"></div>
            <div class="lps-row s"></div>
            <div class="lps-row a"></div>
            <div class="lps-row"></div>
            <div class="lps-row s"></div>
          </div>
        </div>
      </div>

      <div class="lprod reveal">
        <span class="lp-status live">Verze 1.7</span>
        <div class="lp-label"><span class="lg">GET MY</span><span class="lsep">·</span><span class="ln2">Reservation</span></div>
        <h3>Rezervační systém pro restaurace</h3>
        <p>Komplexní dynamický rezervační systém — správa stolů, kapacit, časových slotů a online rezervací v reálném čase přímo z webu restaurace. Bez prostředníků, bez provizí, bez zbytečné složitosti.</p>
        <div class="lp-chips"><span class="pchip">Restaurace</span><span class="pchip">Online rezervace</span><span class="pchip">Správa stolů</span><span class="pchip">Real-time</span></div>
        <div class="lp-screen lp-screen--photo" aria-hidden="true">
          <img src="/assets/gmr-dashboard.png" alt="" loading="lazy" decoding="async" style="width:100%;height:100%;object-fit:cover;object-position:left top;display:block" />
        </div>
      </div>

    </div>
  </div>
</section>

<section class="lcta">
  <div class="lcta-glow"></div>
  <h2 class="reveal">Máte zájem o některý z nástrojů?</h2>
  <p class="reveal">Napište nám — rádi probereme, jak by konkrétní produkt zapadl do vašeho provozu.</p>
  <a class="btn reveal" href="/#kontakt">
    Ozvěte se
    <Arrow size={17} />
  </a>
</section>

<script>
  let _io: IntersectionObserver | null = null;

  function revealAboveFold() {
    const revs = [...document.querySelectorAll<HTMLElement>('.reveal')];
    if (!revs.length) return;
    revs.forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < innerHeight && r.bottom > 0) {
        el.style.transition = 'none';
        el.classList.add('in');
      }
    });
    requestAnimationFrame(() => revs.forEach(el => { el.style.transition = ''; }));
  }

  // After-swap fires before VT animation — elements revealed before capture → visible during fade-in
  document.addEventListener('astro:after-swap', revealAboveFold);

  document.addEventListener('astro:page-load', () => {
    _io?.disconnect();
    const revs = [...document.querySelectorAll<HTMLElement>('.reveal')];
    if (!revs.length) return;

    // Fallback reveal for any above-fold elements missed by after-swap
    revs.forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < innerHeight && r.bottom > 0 && !el.classList.contains('in')) {
        el.style.transition = 'none';
        el.classList.add('in');
      }
    });
    requestAnimationFrame(() => revs.forEach(el => { el.style.transition = ''; }));

    const hidden = revs.filter(el => !el.classList.contains('in'));
    hidden.forEach((el, i) => { el.style.transitionDelay = (i % 3 * 70) + 'ms'; });
    _io = new IntersectionObserver(
      es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); _io!.unobserve(e.target); } }),
      { threshold: .08, rootMargin: '0px 0px -5% 0px' }
    );
    hidden.forEach(el => _io!.observe(el));
    setTimeout(() => revs.forEach(el => el.classList.add('in')), 600);
  });
</script>

</Base>

<style is:global>

/* HERO */
.lhero { padding: 160px 0 80px; }
.lhero h1 { font-family: var(--display); font-weight: 600; font-size: clamp(3rem,9vw,7rem); line-height: .92; letter-spacing: -.03em; max-width: 14ch; }
.lhero h1 em { font-style: normal; color: var(--gold); }
.lhero-sub { font-size: clamp(1.05rem,2vw,1.35rem); max-width: 52ch; color: var(--text-soft); margin-top: 26px; }

/* PRODUCTS */
.lproducts { padding: 20px 0 100px; }
.labs-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 20px; }
@media(max-width:820px) { .labs-grid { grid-template-columns: 1fr; } }

.lprod { background: linear-gradient(160deg,var(--ink-2),var(--ink)); border: 1px solid var(--line); border-radius: 18px; padding: 28px 44% 28px 26px; transition: transform .3s cubic-bezier(.22,1,.36,1),border-color .3s; position: relative; overflow: hidden; }
.lprod:hover { transform: translateY(-5px); border-color: rgba(245,189,2,.35); }
.lp-label { font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; margin-bottom: 12px; display: flex; align-items: center; gap: 7px; }
.lp-label .lg { color: var(--gold); font-weight: 700; }
.lp-label .lsep { color: var(--line); }
.lp-label .ln2 { color: var(--muted); font-weight: 600; }
.lprod h3 { font-family: var(--display); font-weight: 600; font-size: clamp(1.15rem,2vw,1.5rem); letter-spacing: -.01em; margin-bottom: 12px; line-height: 1.1; }
.lprod p { font-size: .92rem; color: var(--text-prose); line-height: 1.6; margin-bottom: 16px; }
.lp-chips { display: flex; flex-wrap: wrap; gap: 6px; }
.lp-status { font-size: .62rem; letter-spacing: .1em; text-transform: uppercase; font-weight: 700; padding: 4px 11px; border-radius: 100px; position: absolute; top: 18px; right: 18px; z-index: 2; }
.lp-status.soon { color: var(--muted); background: rgba(169,156,174,.08); border: 1px solid rgba(169,156,174,.2); }
.lp-status.live { color: var(--gold); background: rgba(245,189,2,.1); border: 1px solid rgba(245,189,2,.28); }
.lp-screen { position: absolute; right: 0; top: 0; bottom: 0; width: 42%; background: #060210; border-left: 1px solid rgba(247,247,247,.08); border-radius: 0 17px 17px 0; overflow: hidden; pointer-events: none; display: flex; flex-direction: column; }
.lp-screen::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 36px; background: linear-gradient(to right,#060210,transparent); z-index: 1; pointer-events: none; }
.lp-screen--photo::before { display: none; }
.lp-screen--photo img { transition: transform .5s cubic-bezier(.22,1,.36,1); }
.lprod:hover .lp-screen--photo img { transform: scale(1.06); }
.lps-bar { display: flex; align-items: center; gap: 4px; padding: 7px 10px; background: rgba(86,33,94,.5); border-bottom: 1px solid rgba(247,247,247,.08); flex-shrink: 0; }
.lps-bar i { width: 5px; height: 5px; border-radius: 50%; background: rgba(247,247,247,.4); display: block; }
.lps-body { padding: 14px 14px 14px 18px; display: flex; flex-direction: column; justify-content: space-between; flex: 1; }
.lps-row { height: 5px; border-radius: 100px; background: rgba(247,247,247,.1); }
.lps-row.a { background: rgba(245,189,2,.45); width: 52%; }
.lps-row.s { width: 70%; }
@media(max-width:520px) { .lp-screen { display: none; } .lprod { padding-right: 26px; } }

/* CTA */
.lcta { text-align: center; padding: 90px 0 110px; position: relative; overflow: hidden; }
.lcta-glow { position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%); width: 60%; height: 200%; background: radial-gradient(circle,rgba(86,33,94,.35),transparent 60%); filter: blur(70px); pointer-events: none; }
.lcta h2 { position: relative; font-family: var(--display); font-weight: 600; font-size: clamp(2rem,5vw,3.8rem); line-height: 1; letter-spacing: -.02em; margin-bottom: 22px; }
.lcta p { position: relative; color: var(--text-soft); max-width: 42ch; margin: 0 auto 32px; }

/* REVEAL */
.reveal { opacity: 0; transform: translateY(30px); transition: opacity .8s cubic-bezier(.22,1,.36,1),transform .8s cubic-bezier(.22,1,.36,1); }
.reveal.in { opacity: 1; transform: none; }
@media(prefers-reduced-motion:reduce) { .reveal { opacity: 1; transform: none; transition: none; } }
</style>
