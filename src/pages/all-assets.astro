---
import Base from '../layouts/Base.astro';
import Topbar from '../components/Topbar.astro';
import Arrow from '../components/Arrow.astro';
---

<Base title="Design System — Golden Purple" noindex={true}>
  <Topbar />

  <div class="ds-wrap">

    <!-- ── SIDEBAR ── -->
    <nav class="ds-nav">
      <p class="ds-nav-label">Obsah</p>
      <a href="#colors">Barvy</a>
      <a href="#typography">Typografie</a>
      <a href="#buttons">Tlačítka</a>
      <a href="#tags">Tagy & badges</a>
      <a href="#chips">Chips</a>
      <a href="#cards">Karty</a>
      <a href="#forms">Formuláře</a>
      <a href="#dividers">Separátory</a>
      <a href="#sections">Sekce vzory</a>
    </nav>

    <!-- ── MAIN ── -->
    <main class="ds-main">

      <header class="ds-header">
        <div class="ds-header-tag"><span class="d"></span><span class="mono">Internal</span></div>
        <h1>Design System</h1>
        <p class="ds-header-sub">Všechny UI elementy webu na jednom místě. Pokud jsou dvě věci stejné, měly by vypadat stejně.</p>
      </header>

      <!-- ════════════════════ COLORS ════════════════════ -->
      <section id="colors" class="ds-section">
        <h2 class="ds-title">Barvy</h2>

        <div class="ds-row">
          <div class="ds-swatch-group">
            <p class="ds-label">Brand</p>
            <div class="ds-swatches">
              <div class="ds-swatch" style="background:#F5BD02"><span>--gold<br>#F5BD02</span></div>
              <div class="ds-swatch" style="background:#FFD75E"><span>--gold-soft<br>#FFD75E</span></div>
              <div class="ds-swatch" style="background:#C99700"><span>--gold-deep<br>#C99700</span></div>
              <div class="ds-swatch" style="background:#56215E"><span>--purple<br>#56215E</span></div>
              <div class="ds-swatch" style="background:#3B1243"><span>--purple-deep<br>#3B1243</span></div>
              <div class="ds-swatch" style="background:#8E4D97"><span>--purple-bright<br>#8E4D97</span></div>
            </div>
          </div>
          <div class="ds-swatch-group">
            <p class="ds-label">Neutrals</p>
            <div class="ds-swatches">
              <div class="ds-swatch" style="background:#0C0610; border:1px solid rgba(247,247,247,.12)"><span>--ink<br>#0C0610</span></div>
              <div class="ds-swatch" style="background:#150A1A; border:1px solid rgba(247,247,247,.12)"><span>--ink-2<br>#150A1A</span></div>
              <div class="ds-swatch" style="background:#F7F7F7; color:#0C0610"><span>--paper<br>#F7F7F7</span></div>
              <div class="ds-swatch" style="background:#A99CAE; color:#0C0610"><span>--muted<br>#A99CAE</span></div>
            </div>
          </div>
        </div>

        <div class="ds-row" style="margin-top:24px">
          <div class="ds-swatch-group">
            <p class="ds-label">Text tokeny</p>
            <div class="ds-swatches">
              <div class="ds-swatch" style="background:#E4DBE8; color:#0C0610"><span>--text-bright<br>#E4DBE8</span></div>
              <div class="ds-swatch" style="background:#D7CEDB; color:#0C0610"><span>--text-soft<br>#D7CEDB<br><small>perex, martin-bio</small></span></div>
              <div class="ds-swatch" style="background:#CFC4D3; color:#0C0610"><span>--text-card<br>#CFC4D3<br><small>popis karet</small></span></div>
              <div class="ds-swatch" style="background:#C6BBCC; color:#0C0610"><span>--text-prose<br>#C6BBCC<br><small>právní texty, odstavce</small></span></div>
              <div class="ds-swatch" style="background:#5a5060; border:1px solid rgba(247,247,247,.12)"><span>--text-faint<br>#5a5060<br><small>potlačené detaily</small></span></div>
            </div>
          </div>
          <div class="ds-swatch-group">
            <p class="ds-label">Sémantické barvy</p>
            <div class="ds-swatches">
              <div class="ds-swatch" style="background:#2FA968; color:#0C0610"><span>--success<br>#2FA968</span></div>
              <div class="ds-swatch" style="background:#D64545"><span>--danger<br>#D64545</span></div>
              <div class="ds-swatch" style="background:#ff6b6b"><span>--error<br>#ff6b6b</span></div>
            </div>
          </div>
        </div>
      </section>

      <!-- ════════════════════ TYPOGRAPHY ════════════════════ -->
      <section id="typography" class="ds-section">
        <h2 class="ds-title">Typografie</h2>

        <!-- H1 variants -->
        <div class="ds-block">
          <p class="ds-label">H1 — Hero (homepage, největší na webu)</p>
          <h1 class="typo-h1">Stavíme weby,<br>co vydělávají.</h1>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>700</strong></span>
            <span>Size: <strong>clamp(3.4rem, 10vw, 9.5rem)</strong></span>
            <span>Line-height: <strong>.86</strong> (velmi těsné)</span>
            <span>Letter-spacing: <strong>-.04em</strong> (písmenka blíž k sobě)</span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">H1 — Martin / velký section hero</p>
          <h1 class="typo-h1-martin">Martin Sedláček</h1>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>700</strong></span>
            <span>Size: <strong>clamp(3rem, 9vw, 7rem)</strong></span>
            <span>Line-height: <strong>.9</strong></span>
            <span>Letter-spacing: <strong>-.04em</strong></span>
          </div>
        </div>

        <!-- H2 variants — jsou 3 různé velikostní skupiny -->
        <div class="ds-block">
          <p class="ds-label">H2 — XL (Golden Vision, Kontakt) — největší sekční nadpisy</p>
          <h2 class="typo-h2-xl">Postaráme se o vás</h2>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>700</strong></span>
            <span>Size: <strong>clamp(2.8rem, 6–8vw, 5.5–6.5rem)</strong></span>
            <span>Line-height: <strong>.9–.92</strong></span>
            <span>Letter-spacing: <strong>-.035em</strong></span>
            <span>Kde: .gv-left h2, .ct-left h2</span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">H2 — L (Výzvy, Služby, Labs, FAQ, Ceník…) — standardní sekční nadpis</p>
          <h2 class="typo-h2-l">Co vás trápí nejvíc</h2>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>600</strong></span>
            <span>Size: <strong>clamp(2.4rem, 6vw, 4.5rem)</strong></span>
            <span>Line-height: <strong>.95</strong></span>
            <span>Letter-spacing: <strong>-.025em</strong></span>
            <span>Kde: .bolesti-head h2, #sluzby h2, #faq h2, .ltease-inner h2, .collab-left h2</span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">H2 — M (Vybraná práce, Ceník, Nástroje) — kompaktnější nadpis</p>
          <h2 class="typo-h2-m">Vybraná práce</h2>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>600</strong></span>
            <span>Size: <strong>clamp(2.2rem, 4.5–5.5vw, 3.6–4rem)</strong></span>
            <span>Line-height: <strong>.95–.96</strong></span>
            <span>Letter-spacing: <strong>-.025em</strong></span>
            <span>Kde: .vp-left h2, #cenik h2, #nastroje h2</span>
          </div>
        </div>

        <!-- H3 variants -->
        <div class="ds-block">
          <p class="ds-label">H3 — Service row title (.srow .st)</p>
          <h3 class="typo-h3-service">Web design & vývoj</h3>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>600</strong></span>
            <span>Size: <strong>clamp(1.6rem, 4vw, 3rem)</strong></span>
            <span>Line-height: <strong>1.1</strong></span>
            <span>Letter-spacing: <strong>-.02em</strong></span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">H3 — Card / step title (.cs-body h3, .gvs-t)</p>
          <h3 class="typo-h3-card">Strategie & nabídka</h3>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>600</strong></span>
            <span>Size: <strong>clamp(1.15–1.4rem, 2.2–3vw, 1.5–2.2rem)</strong></span>
            <span>Line-height: <strong>1.1</strong></span>
            <span>Letter-spacing: <strong>-.015em až -.02em</strong></span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">H3 — Tool card title (.tool h3)</p>
          <h3 class="typo-h3-tool">Web Skener</h3>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>600</strong></span>
            <span>Size: <strong>1.5rem</strong> (fixní, ne clamp)</span>
            <span>Line-height: <strong>1.05</strong></span>
            <span>Letter-spacing: <strong>-.01em</strong></span>
          </div>
        </div>

        <!-- Body text variants -->
        <div class="ds-block">
          <p class="ds-label">Body — perex / velký body (.h-vp, .martin-bio, .gv-desc, .ltease-desc)</p>
          <p class="typo-lead">Tvoříme digitální zážitky, které přivádějí poptávky, šetří ruční práci a zvedají vnímanou hodnotu vaší firmy.</p>
          <div class="typo-spec">
            <span>Font: <strong>General Sans</strong></span>
            <span>Weight: <strong>400</strong></span>
            <span>Size: <strong>clamp(1.05rem, 1.7vw, 1.3rem)</strong></span>
            <span>Line-height: <strong>1.7</strong></span>
            <span>Letter-spacing: <strong>není nastavené</strong> (výchozí 0)</span>
            <span>Color: <strong>var(--text-soft)</strong></span>
            <span>Max-width: layout-specific (54ch hero · 56ch martin-bio · 40ch gv-desc · 52ch labs)</span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">Body — Standard / card text</p>
          <p class="typo-body">Zpracováváme osobní údaje v souladu s GDPR. Pokud máte dotazy, kontaktujte nás na info@goldenpurple.cz</p>
          <div class="typo-spec">
            <span>Font: <strong>General Sans</strong></span>
            <span>Weight: <strong>400</strong></span>
            <span>Size: <strong>17px</strong> (base) nebo <strong>.88–.95rem</strong> v kartách</span>
            <span>Line-height: <strong>1.5–1.6</strong></span>
            <span>Letter-spacing: <strong>není nastavené</strong></span>
            <span>Color: <strong>var(--text-card)</strong> v kartách (tmavší varianta mutu)</span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">Body — Muted / pomocný text</p>
          <p class="typo-muted">Zpracováváme osobní údaje v souladu s GDPR. Souhlas lze kdykoliv odvolat.</p>
          <div class="typo-spec">
            <span>Font: <strong>General Sans</strong></span>
            <span>Weight: <strong>400</strong></span>
            <span>Size: <strong>.78–.95rem</strong></span>
            <span>Color: <strong>--muted</strong> = #A99CAE</span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">Poznámka pod ceníkem — .cenik-note</p>
          <p class="typo-cenik-note">Konzultace a strategie <b>2 000 Kč/h</b> · expresní práce mimo plán <b>+50 %</b> · ceny jsou orientační, finální podle rozsahu. Nejsem plátce DPH.</p>
          <div class="typo-spec">
            <span>Font: <strong>General Sans</strong></span>
            <span>Weight: <strong>400</strong> / tučné hodnoty <strong>600</strong></span>
            <span>Size: <strong>.86rem</strong></span>
            <span>Line-height: <strong>1.6</strong></span>
            <span>Letter-spacing: <strong>není nastavené</strong></span>
            <span>Color: <strong>--muted</strong> (#A99CAE) · <code>&lt;b&gt;</code> uvnitř = <strong>var(--text-soft)</strong> (zvýraznění čísel)</span>
            <span>Max-width: <strong>80ch</strong> (nejširší text blok na webu)</span>
          </div>
        </div>

        <div class="ds-warn" style="margin-bottom:20px; border-color: rgba(47,169,104,.3); background: rgba(47,169,104,.06)">
          <p style="color: var(--success)">✓ Textové barvy jsou teď tokeny v Base.astro :root — více níže v sekci Barvy.</p>
        </div>

        <!-- Labels / uppercase -->
        <div class="ds-block">
          <p class="ds-label">Eyebrow / Kicker — .eyebrow (nad sekcemi, gold)</p>
          <p class="typo-eyebrow">Co umíme</p>
          <div class="typo-spec">
            <span>Font: <strong>General Sans</strong></span>
            <span>Weight: <strong>600</strong></span>
            <span>Size: <strong>.74rem</strong></span>
            <span>Letter-spacing: <strong>.3em</strong> (nejroztaženější text na webu)</span>
            <span>Text-transform: <strong>uppercase</strong></span>
            <span>Color: <strong>--gold</strong></span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">Mono label — .mono (v badge, navigaci)</p>
          <p class="typo-mono">Golden Purple Studio</p>
          <div class="typo-spec">
            <span>Font: <strong>General Sans</strong></span>
            <span>Weight: <strong>600</strong></span>
            <span>Size: <strong>.72rem</strong></span>
            <span>Letter-spacing: <strong>.16em</strong></span>
            <span>Text-transform: <strong>uppercase</strong></span>
            <span>Color: <strong>--muted</strong></span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">Section number / label (.eyebrow variant)</p>
          <p class="typo-num">01</p>
          <div class="typo-spec">
            <span>Font: <strong>General Sans</strong></span>
            <span>Weight: <strong>500</strong></span>
            <span>Size: <strong>.72–.85rem</strong></span>
            <span>Letter-spacing: <strong>.08–.14em</strong></span>
            <span>Text-transform: <strong>uppercase</strong></span>
            <span>Color: <strong>--gold</strong></span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">Blockquote / recenze (speciální styl)</p>
          <blockquote class="typo-quote">"Výsledky překonaly naše očekávání. Zákazníci si nás teď sami nacházejí."</blockquote>
          <div class="typo-spec">
            <span>Font: <strong>Clash Display</strong></span>
            <span>Weight: <strong>500</strong></span>
            <span>Size: <strong>clamp(1.8rem, 4.5vw, 3.4rem)</strong></span>
            <span>Line-height: <strong>1.18</strong></span>
            <span>Letter-spacing: <strong>-.015em</strong></span>
          </div>
        </div>

        <div class="ds-block">
          <p class="ds-label">.shine — hero keyword (gold gradient sweep, shodný s h2 em)</p>
          <h1 class="typo-h1"><span class="ds-shine">královsky.</span></h1>
          <p class="ds-meta">background: gold-deep→gold-soft→gold-deep · background-size: 200% · animation: shine var(--shine-dur) linear infinite alternate<br>Použití: klíčové slovo v hero H1 (index, /martin)</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">h2 &lt;em&gt; typ A — prostá zlatá barva (většina sekcí)</p>
          <h2 class="typo-h2">Postaráme se o <em class="ds-em-plain">vás</em> dobře.</h2>
          <p class="ds-meta">font-style: normal · color: var(--gold) · žádná animace<br>Kde: .vp-left · .bolesti-head · #sluzby · .ltease-inner · .collab-left · #nastroje · #faq · .bp-cta · .cs-cta · .e4-wrap · .bhero · .lhero · /scan · /brand-scorecard</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">h2 &lt;em&gt; — animovaný gold gradient sweep (všechny sekce)</p>
          <h2 class="typo-h2">Postaráme se o <em class="ds-em">vás</em> dobře.</h2>
          <p class="ds-meta">font-style: normal · background: gold-deep→gold-soft→gold-deep · background-clip: text · animation: shine var(--shine-dur) linear infinite alternate<br>
          Kde (index.astro): .vp-left h2 · .bolesti-head h2 · .gv-left h2 · #sluzby h2 · .ltease-inner h2 · .collab-left h2 · #nastroje h2 · #cenik h2 · .ct-left h2 · #faq h2<br>
          Další stránky: .mp-cta h2 (/martin) · .endcta h2 (/prace)</p>
        </div>

        <div class="ds-warn" style="margin-top:-10px; margin-bottom:20px; border-color: rgba(47,169,104,.3); background: rgba(47,169,104,.06)">
          <p style="color: var(--success)">✓ Sjednoceno — Typ A (prostá zlatá) zrušen. Všechny h2 &lt;em&gt; na webu teď jedou Typ B (gradient sweep).</p>
        </div>
      </section>

      <!-- ════════════════════ BUTTONS ════════════════════ -->
      <section id="buttons" class="ds-section">
        <h2 class="ds-title">Tlačítka</h2>

        <div class="ds-block">
          <p class="ds-label">Primary — .btn</p>
          <div class="ds-row-wrap">
            <a href="#" class="btn">Zjistit více</a>
            <a href="#" class="btn btn-sm">Zjistit více</a>
          </div>
          <p class="ds-meta">background: --gold · color: --ink · border-radius: 100px · padding: 18px 38px · font-weight: 600</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Secondary text link — .h-sec</p>
          <div class="ds-row-wrap">
            <a href="#" class="h-sec">Zobrazit všechny projekty</a>
          </div>
          <p class="ds-meta">color: --muted · border-bottom: 1px solid --line · font-weight: 600</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Ghost / Outline</p>
          <div class="ds-row-wrap">
            <a href="#" class="btn-ghost">Kontaktovat</a>
          </div>
          <p class="ds-meta">border: 1px solid --line · background: transparent · border-radius: 100px</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Text / Link button — .link-btn</p>
          <div class="ds-row-wrap">
            <button type="button" class="link-btn">Nastavení cookies</button>
          </div>
          <p class="ds-meta">background: none · color: --gold · text-decoration: underline</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Form submit — .ct-btn (výchozí · hover · disabled)</p>
          <div class="ds-row-wrap">
            <button type="button" class="ct-btn">
              <span class="ct-btn-label">Odeslat poptávku</span>
              <Arrow />
            </button>
            <button type="button" class="ct-btn ct-btn--loading" disabled>
              <span class="ct-btn-label">Odesílám…</span>
              <Arrow />
            </button>
          </div>
          <p class="ds-meta">font-family: <strong style="color:var(--gold)">Clash Display</strong> (ne General Sans!) · background: --gold · color: --ink · padding: 14px 26px · border-radius: 100px<br>hover: translateY(-2px) + box-shadow 0 12px 32px rgba(245,189,2,.35) (gold glow)<br>disabled: opacity .55 + cursor not-allowed · label text se mění JS na "Odesílám…"</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Navigační šipka (vybrana prace) — .vp-arr</p>
          <div class="ds-row-wrap">
            <span class="vp-arr-demo">→</span>
          </div>
          <p class="ds-meta">Čistý → šipka, color: --muted · přechod na --gold při hoveru na řádku</p>
        </div>
      </section>

      <!-- ════════════════════ TAGS & BADGES ════════════════════ -->
      <section id="tags" class="ds-section">
        <h2 class="ds-title">Tagy & Badges</h2>

        <div class="ds-block">
          <p class="ds-label">Hero badge — .h-badge</p>
          <div class="ds-row-wrap">
            <div class="h-badge"><span class="d"></span><span class="mono">Třebíč · Jihlava · Brno</span></div>
          </div>
          <p class="ds-meta">border: 1px solid --line · background: rgba(247,247,247,.04) · border-radius: 100px · obsahuje pulzující dot</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Legal tag — .tag</p>
          <div class="ds-row-wrap">
            <div class="tag"><span class="d"></span><span class="mono">Právní dokumenty</span></div>
          </div>
          <p class="ds-meta">Stejný styl jako .h-badge, méně padding</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Blog / case study tag — .bp-tag</p>
          <div class="ds-row-wrap">
            <span class="bp-tag">Web design</span>
            <span class="bp-tag">Branding</span>
            <span class="bp-tag">E-shop</span>
          </div>
          <p class="ds-meta">border: 1px solid rgba(245,189,2,.3) · color: --gold · font-size .7rem · uppercase · letter-spacing .12em · border-radius: 100px</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Blog card mini tag — .bp-mt</p>
          <div class="ds-row-wrap">
            <span class="bp-mt">SEO</span>
            <span class="bp-mt">Copywriting</span>
          </div>
          <p class="ds-meta">Bez bordurou, čistý uppercase gold label pro karty</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Free / Gold badge — .free</p>
          <div class="ds-row-wrap">
            <span class="free-demo">Zdarma</span>
          </div>
          <p class="ds-meta">background: --gold · color: --ink · pozice: absolute top-right na tool kartě</p>
        </div>

        <div class="ds-block">
          <p class="ds-label">Project kicker — .vp-tag</p>
          <div class="ds-row-wrap">
            <span class="vp-tag-demo">Web design & Dev</span>
