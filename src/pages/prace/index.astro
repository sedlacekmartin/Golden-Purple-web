---
import Base from '../../layouts/Base.astro';
import Topbar from '../../components/Topbar.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('prace', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

const featured = projects[0];
const rest = projects.slice(1);
---

<Base
  title="Naše práce — Golden Purple"
  description="Výběr toho, co jsme postavili — weby, e-shopy, branding a digitální produkty pro firmy, co chtějí působit profesionálně a získávat klienty."
>

<Topbar />

<section class="phero">
  <div class="wrap">
    <span class="eyebrow reveal">Naše práce</span>
    <h1 class="reveal">Projekty, které dávají smysl.</h1>
    <p class="reveal">Výběr toho, co jsme postavili — weby, e-shopy, branding a digitální produkty pro firmy, co chtějí působit profesionálně a získávat klienty.</p>
    <div class="stats reveal">
      <div class="s"><b>4+</b><span>realizovaných projektů</span></div>
      <div class="s"><b>100%</b><span>na míru, žádné šablony</span></div>
      <div class="s"><b>Vysočina<br />&amp; Brno</b><span>kde působíme</span></div>
    </div>
  </div>
</section>

{featured && (
  <section class="featured">
    <div class="wrap">
      <a class="fcard reveal" href={`/prace/${featured.id}`}>
        <div class="vis">
          <span class="ftag">Featured · {featured.data.tags.slice(0,2).join(' · ')}</span>
          <span class="bignum">01</span>
        </div>
        <div class="body">
          <span class="kick">{featured.data.tags.join(' · ')}</span>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.description}</p>
          <div class="meta">
            {featured.data.tags.map(t => <span>{t}</span>)}
          </div>
          <span class="go">
            Zobrazit projekt
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </span>
        </div>
      </a>
    </div>
  </section>
)}

{rest.length > 0 && (
  <section class="grid-sec">
    <div class="wrap">
      <div class="gh">Všechny projekty</div>
      <div class="pgrid">
        {rest.map((p, i) => (
          <a class="pcard reveal" href={`/prace/${p.id}`}>
            <div class="pvis">
              <span class="t">{p.data.tags.slice(0,2).join(' · ')}</span>
              <span class="n">0{i + 2}</span>
            </div>
            <div class="pbody">
              <h3>{p.data.title}</h3>
              <p class="desc">{p.data.description}</p>
              <div class="foot">
                <span>{p.data.pubDate.getFullYear()}</span>
                <span class="arr">→</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
)}

<section class="endcta">
  <div class="wrap">
    <h2 class="reveal">Váš projekt může být <em>další v řadě</em>.</h2>
    <p class="reveal">Napište pár slov o tom, co řešíte. Ozveme se do dvou dnů s konkrétními nápady.</p>
    <a class="btn reveal" href="/#kontakt">
      Pojďme do toho
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
    </a>
  </div>
</section>

<Footer />

<script>
  document.addEventListener('astro:page-load', () => {
    const io = new IntersectionObserver(
      (es) => { es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }); },
      { threshold: .08, rootMargin: '0px 0px -5% 0px' }
    );
    const revs = document.querySelectorAll('.reveal');
    revs.forEach((el, i) => { el.style.transitionDelay = (i % 3 * 70) + 'ms'; io.observe(el); });
    setTimeout(() => {
      revs.forEach(el => { const r = el.getBoundingClientRect(); if (r.top < innerHeight * 1.1) el.classList.add('in'); });
    }, 200);
    setTimeout(() => revs.forEach(el => el.classList.add('in')), 1200);
  });
</script>

</Base>

<style is:global>
.wrap{max-width:1280px;margin:0 auto;padding:0 clamp(24px,5vw,64px)}

/* HERO */
.phero{padding:160px 0 70px}
.phero .eyebrow{font-size:.78rem;letter-spacing:.28em;text-transform:uppercase;font-weight:600;color:var(--gold);margin-bottom:22px;display:block}
.phero h1{font-family:var(--display);font-weight:600;font-size:clamp(3rem,9vw,7rem);line-height:.92;letter-spacing:-.03em;max-width:14ch}
.phero p{font-size:clamp(1.05rem,2vw,1.35rem);max-width:52ch;color:#D7CEDB;margin-top:26px}
.phero .stats{display:flex;gap:48px;margin-top:44px;flex-wrap:wrap}
.phero .stats .s b{font-family:var(--display);font-weight:600;font-size:2.4rem;display:block;line-height:1;color:var(--gold)}
.phero .stats .s span{font-size:.85rem;color:var(--muted);margin-top:6px;display:block}

/* FEATURED */
.featured{padding:30px 0 24px}
.fcard{position:relative;display:grid;grid-template-columns:1.1fr 1fr;gap:0;background:linear-gradient(160deg,var(--ink-2),var(--ink));border:1px solid var(--line);border-radius:24px;overflow:hidden;transition:transform .4s cubic-bezier(.22,1,.36,1),border-color .4s;min-height:440px}
.fcard:hover{transform:translateY(-6px);border-color:var(--gold)}
.fcard .vis{position:relative;background:radial-gradient(circle at 30% 30%,rgba(86,33,94,.6),transparent 60%),linear-gradient(135deg,#2a2030,#15101c);display:flex;align-items:center;justify-content:center;overflow:hidden}
.fcard .vis .bignum{font-family:var(--display);font-weight:700;font-size:13rem;line-height:1;color:transparent;-webkit-text-stroke:1.5px rgba(245,189,2,.25);user-select:none}
.fcard .vis .ftag{position:absolute;top:24px;left:24px;font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;font-weight:700;color:var(--gold);background:rgba(245,189,2,.1);border:1px solid rgba(245,189,2,.25);padding:7px 14px;border-radius:100px}
.fcard .body{padding:clamp(30px,4vw,54px);display:flex;flex-direction:column;justify-content:center}
.fcard .body .kick{font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;color:var(--gold);margin-bottom:16px}
.fcard .body h2{font-family:var(--display);font-weight:600;font-size:clamp(2.4rem,5vw,3.6rem);line-height:.96;letter-spacing:-.02em;margin-bottom:18px}
.fcard .body p{color:#D7CEDB;font-size:1.05rem;margin-bottom:24px;max-width:42ch}
.fcard .body .meta{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:28px}
.fcard .body .meta span{font-size:.8rem;border:1px solid var(--line);padding:6px 13px;border-radius:100px;color:#CFC4D3}
.fcard .body .go{display:inline-flex;align-items:center;gap:10px;font-family:var(--display);font-weight:600;color:var(--gold)}
.fcard .body .go svg{transition:transform .3s}
.fcard:hover .body .go svg{transform:translateX(6px)}
@media(max-width:860px){.fcard{grid-template-columns:1fr}.fcard .vis{min-height:240px}.fcard .vis .bignum{font-size:8rem}}

/* GRID */
.grid-sec{padding:24px 0 120px}
.gh{font-size:.74rem;letter-spacing:.18em;text-transform:uppercase;color:var(--muted);margin:36px 0 24px;padding-bottom:14px;border-bottom:1px solid var(--line)}
.pgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
@media(max-width:960px){.pgrid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:600px){.pgrid{grid-template-columns:1fr}}
.pcard{position:relative;background:linear-gradient(160deg,var(--ink-2),var(--ink));border:1px solid var(--line);border-radius:18px;overflow:hidden;transition:transform .35s cubic-bezier(.22,1,.36,1),border-color .35s;display:flex;flex-direction:column}
.pcard:hover{transform:translateY(-6px);border-color:var(--gold)}
.pcard .pvis{aspect-ratio:16/11;position:relative;background:radial-gradient(circle at 60% 30%,rgba(86,33,94,.45),transparent 60%),linear-gradient(135deg,#241b2c,#140f1a);display:flex;align-items:center;justify-content:center;overflow:hidden}
.pcard .pvis .n{font-family:var(--display);font-weight:700;font-size:5rem;color:transparent;-webkit-text-stroke:1px rgba(245,189,2,.2)}
.pcard .pvis .t{position:absolute;top:16px;left:16px;font-size:.64rem;letter-spacing:.12em;text-transform:uppercase;font-weight:700;color:var(--gold);background:rgba(245,189,2,.1);border:1px solid rgba(245,189,2,.2);padding:5px 11px;border-radius:100px}
.pcard .pbody{padding:24px 26px 28px;flex:1;display:flex;flex-direction:column}
.pcard h3{font-family:var(--display);font-weight:600;font-size:1.5rem;letter-spacing:-.01em;margin-bottom:8px}
.pcard .desc{font-size:.92rem;color:#C6BBCC;line-height:1.5;margin-bottom:16px;flex:1}
.pcard .foot{display:flex;justify-content:space-between;align-items:center;font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted)}
.pcard .foot .arr{color:var(--gold);transition:transform .3s;font-style:normal}
.pcard:hover .foot .arr{transform:translateX(5px)}

/* CTA */
.endcta{text-align:center;padding:90px 0 110px;position:relative}
.endcta h2{font-family:var(--display);font-weight:700;font-size:clamp(2.2rem,6vw,4.4rem);line-height:.96;letter-spacing:-.03em;max-width:18ch;margin:0 auto 22px}
.endcta h2 em{font-style:normal;background:linear-gradient(100deg,var(--gold-deep),var(--gold-soft),var(--gold-deep));background-size:200% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;animation:shine 5s linear infinite}
.endcta p{color:#D7CEDB;max-width:42ch;margin:0 auto 32px}
.btn{display:inline-flex;align-items:center;gap:11px;background:var(--gold);color:var(--ink);padding:17px 36px;border-radius:100px;font-family:var(--display);font-weight:600;font-size:1.05rem;transition:transform .2s,box-shadow .2s}
.btn:hover{transform:translateY(-3px);box-shadow:0 16px 40px rgba(245,189,2,.4)}
@keyframes shine{to{background-position:-200% 0}}

/* REVEAL */
.reveal{opacity:0;transform:translateY(30px);transition:opacity .8s cubic-bezier(.22,1,.36,1),transform .8s cubic-bezier(.22,1,.36,1)}
.reveal.in{opacity:1;transform:none}
@media(prefers-reduced-motion:reduce){.reveal{opacity:1;transform:none;transition:none}.endcta h2 em{animation:none}}
</style>
