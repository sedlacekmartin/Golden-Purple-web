---
export const prerender = true;
import Base from '../../layouts/Base.astro';
import Topbar from '../../components/Topbar.astro';
import Arrow from '../../components/Arrow.astro';
---

<Base
  title="Martin Sedláček — Golden Purple"
  description="Webdesigner, grafik a digitální stratég z Třebíče. Spojuji design, marketing a technické řešení do jednoho procesu. Golden Purple."
>
  <Topbar />

  <main class="martin-page">

    <!-- HERO -->
    <section class="mp-hero">
      <div class="mph-glow"></div>
      <div class="mph-inner">
        <p class="eyebrow">Za Golden Purple</p>
        <h1>Martin<br><span class="shine">Sedláček</span></h1>
        <p class="mph-role">Webdesigner · Grafik · Digitální stratég</p>
        <div class="mph-chips">
          <span class="pchip">Třebíč</span>
          <span class="pchip">Jihlava</span>
          <span class="pchip">Brno</span>
        </div>
      </div>
    </section>

    <!-- BIO -->
    <section class="mp-section" id="kdo-jsem">
      <div class="mp-wrap">
        <div class="mp-label">Kdo jsem</div>
        <div class="mp-content">
          <p class="mp-lead">Jsem freelancer a zakladatel Golden Purple. Dělám weby, značky a digitální systémy pro firmy, které chtějí působit profesionálně a přivádět víc zákazníků online.</p>
          <p>Nezaměřuju se jen na to, aby výsledek vypadal dobře. Zajímá mě, jestli web zákazníkovi pomáhá vydělávat — jestli návštěvník pochopí nabídku, uvěří jí a udělá další krok.</p>
          <p>Pracoval jsem pro restaurace, B2B firmy, výrobce, ubytovací zařízení i lokální živnostníky. Každý projekt řeším od strategie přes design až po spuštění a dlouhodobou péči.</p>
          <p>Vedle klientské práce vyvíjím vlastní digitální nástroje pod hlavičkou <strong>Golden Labs</strong> — rezervační systémy, QR tracking, provozní pluginy. Protože správné řešení někdy prostě neexistuje hotové.</p>
        </div>
      </div>
    </section>

    <!-- SKILLS -->
    <section class="mp-section mp-section--dark" id="co-delam">
      <div class="mp-wrap">
        <div class="mp-label">Co dělám</div>
        <div class="mp-skills">
          <div class="msk">
            <span class="msk-n">01</span>
            <h3>Weby & webdesign</h3>
            <p>WordPress, Elementor, ACF, Astro. Stavím weby, které jsou rychlé, dobře strukturované a navržené tak, aby návštěvník pochopil nabídku a odeslal poptávku. Zajistím i domény, hosting a bezstarostný provoz.</p>
            <div class="msk-tags"><span>WordPress</span><span>Astro</span><span>UX</span><span>SEO</span><span>Domény & hosting</span></div>
          </div>
          <div class="msk">
            <span class="msk-n">02</span>
            <h3>Branding, grafika & tisk</h3>
            <p>Logo, vizuální styl, brand manuál a veškerá navazující grafika: katalogy, letáky, bannery, tiskoviny i polepy. Vytvářím značky, které jsou konzistentní, zapamatovatelné a působí profesionálně napříč všemi kanály.</p>
            <div class="msk-tags"><span>Logo</span><span>Brand manuál</span><span>Vizuální styl</span><span>Katalogy & letáky</span><span>Bannery</span></div>
          </div>
          <div class="msk">
            <span class="msk-n">03</span>
            <h3>Marketing & obsah</h3>
            <p>Google Ads, Meta Ads, e-mail marketing, copywriting, foto a video. Kampaně nastavuji tak, aby měly měřitelný výstup — ne jen zobrazení, ale poptávky a objednávky.</p>
            <div class="msk-tags"><span>Google Ads</span><span>Meta Ads</span><span>E-mail</span><span>Copywriting</span></div>
          </div>
          <div class="msk">
            <span class="msk-n">04</span>
            <h3>Digitální produkty</h3>
            <p>Vlastní rezervační systémy, WordPress pluginy, QR tracking platformy a další nástroje. Stavím systémy, které šetří čas a automatizují opakující se procesy.</p>
            <div class="msk-tags"><span>Rezervace</span><span>Pluginy</span><span>Automatizace</span><span>API</span></div>
          </div>
        </div>
      </div>
    </section>

    <!-- HOW I WORK -->
    <section class="mp-section" id="jak-pracuji">
      <div class="mp-wrap">
        <div class="mp-label">Jak pracuji</div>
        <div class="mp-content">
          <div class="mp-steps">
            <div class="mpst">
              <span class="mpst-n">01</span>
              <div>
                <h3>Audit & pochopení situace</h3>
                <p>Začínám tím, že pochopím váš byznys, cílové zákazníky a aktuální problémy. Bez toho nelze navrhnout řešení, které bude fungovat.</p>
              </div>
            </div>
            <div class="mpst">
              <span class="mpst-n">02</span>
              <div>
                <h3>Strategie & struktura</h3>
                <p>Navrhuji strukturu, obsah a vizuální směr. Vše konzultuji a dostávám zpětnou vazbu před tím, než začne samotná realizace.</p>
              </div>
            </div>
            <div class="mpst">
              <span class="mpst-n">03</span>
              <div>
                <h3>Design & vývoj</h3>
                <p>Realizuji projekt s důrazem na detaily, výkon a použitelnost. Průběžně sdílím výstupy a zapracovávám připomínky.</p>
              </div>
            </div>
            <div class="mpst">
              <span class="mpst-n">04</span>
              <div>
                <h3>Spuštění & péče</h3>
                <p>Nasadím projekt, ošetřím technické detaily a zajistím, aby vše fungovalo. U dlouhodobých klientů vedu servis, aktualizace a marketing.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- FACTS -->
    <section class="mp-section mp-section--dark" id="fakta">
      <div class="mp-wrap">
        <div class="mp-label">Fakta</div>
        <div class="mp-facts">
          <div class="mpf">
            <span class="mpf-val">10+</span>
            <span class="mpf-lab">let v oboru</span>
          </div>
          <div class="mpf">
            <span class="mpf-val">4</span>
            <span class="mpf-lab">vlastní produkty (Golden Labs)</span>
          </div>
          <div class="mpf">
            <span class="mpf-val">1</span>
            <span class="mpf-lab">člověk za vším</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CERTIFIKACE -->
    <section class="mp-section" id="certifikace">
      <div class="mp-wrap">
        <div class="mp-label">Certifikace</div>
        <div class="mp-certs">
          <div class="mcert">
            <a class="mcert-shot" href="/assets/certifikaty/skvot-rozvoj-a-budovani-znacky.pdf" target="_blank" rel="noopener" aria-label="Otevřít certifikát SKVOT v PDF">
              <img src="/assets/certifikaty/skvot-cert.jpg" alt="Certifikát SKVOT — Rozvoj a budování značky" loading="lazy" decoding="async" />
            </a>
            <span class="mcert-y">2025 · SKVOT</span>
            <h3>Rozvoj a budování značky</h3>
            <p>Celý proces tvorby značky: analýza trhu a konkurence, brand positioning, brand platforma (mise, vize, hodnoty), komunikační strategie, brand guidelines a měření výkonu značky. Pod vedením Libora Uhlíka (Leo Burnett, Saatchi &amp; Saatchi, Behavio).</p>
            <div class="mcert-foot">
              <span class="mcert-meta">18 vyučovacích hodin · 12 lekcí</span>
              <span class="mcert-links">
                <a class="mcert-link" href="/assets/certifikaty/skvot-rozvoj-a-budovani-znacky.pdf" target="_blank" rel="noopener">Certifikát (PDF)</a>
                <a class="mcert-link" href="https://skvt.cz/course/139-tvorba-znacky-krok-za-krokem" target="_blank" rel="noopener">O kurzu ↗</a>
              </span>
            </div>
          </div>
          <div class="mcert">
            <a class="mcert-shot" href="/assets/certifikaty/laba-marketingovy-reditel.pdf" target="_blank" rel="noopener" aria-label="Otevřít certifikát Laba v PDF">
              <img src="/assets/certifikaty/laba-cert.jpg" alt="Certifikát Laba — Marketingový ředitel" loading="lazy" decoding="async" />
            </a>
            <span class="mcert-y">2024 · Laba Czech</span>
            <h3>Marketingový ředitel</h3>
            <p>Řízení marketingu z pohledu CMO: marketingová strategie od nuly, audit, segmentace trhu a pozice značky, framework See-Think-Do-Care, KPI, vedení týmu a rozpočtů. Pod vedením Jaroslava Kauckého, exCMO ZOOT.</p>
            <div class="mcert-foot">
              <span class="mcert-meta">18 vyučovacích hodin · 12 lekcí</span>
              <span class="mcert-links">
                <a class="mcert-link" href="/assets/certifikaty/laba-marketingovy-reditel.pdf" target="_blank" rel="noopener">Certifikát (PDF)</a>
                <a class="mcert-link" href="https://l-a-b-a.cz/lecture/312-marketingovy-reditel" target="_blank" rel="noopener">O kurzu ↗</a>
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="mp-cta">
      <div class="mp-cta-glow"></div>
      <div class="mp-cta-inner">
        <p class="eyebrow">Pojďme spolupracovat</p>
        <h2>Máte projekt?<br><em>Do dvou dnů víte, na čem jste.</em></h2>
        <p>Napište pár vět o tom, co řešíte. Nezávazně to posoudím a navrhnu, jak začít. Ať už jde o web, značku, nebo obojí.</p>
        <div class="mp-cta-btns">
          <a class="btn" href="/#kontakt">
            Probrat projekt
            <Arrow size={17} />
          </a>
          <a class="mp-back" href="mailto:info@goldenpurple.cz">info@goldenpurple.cz</a>
        </div>
      </div>
    </section>

  </main>

</Base>

<style>
/* PAGE SHELL */
.martin-page{padding-top:80px}

/* HERO */
.mp-hero{min-height:80vh;display:flex;align-items:center;padding:80px clamp(28px,6vw,100px);position:relative;overflow:hidden}
.mph-glow{position:absolute;top:20%;left:-60px;width:600px;height:600px;border-radius:50%;background:radial-gradient(circle,rgba(86,33,94,.45),transparent 65%);filter:blur(80px);z-index:0;pointer-events:none}
.mph-inner{position:relative;z-index:2}
.mp-hero h1{font-family:var(--display);font-weight:700;font-size:clamp(3rem,9vw,7rem);line-height:.88;letter-spacing:-.035em;margin-bottom:28px}
.shine{background:linear-gradient(100deg,var(--gold-deep),var(--gold-soft),var(--gold-deep));background-size:200% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;animation:shine var(--shine-dur) linear infinite alternate}

.mph-role{font-size:clamp(1rem,1.7vw,1.2rem);color:var(--text-soft);margin-bottom:28px}
.mph-chips{display:flex;flex-wrap:wrap;gap:10px}

/* SECTIONS */
.mp-section{padding:clamp(60px,10vh,120px) clamp(28px,6vw,100px)}
.mp-section--dark{background:var(--ink-2)}
.mp-wrap{display:grid;grid-template-columns:200px 1fr;gap:clamp(32px,6vw,80px);align-items:start}
@media(max-width:760px){.mp-wrap{grid-template-columns:1fr}}
.mp-label{font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);font-weight:600;padding-top:6px}
@media(max-width:760px){.mp-label{margin-bottom:0}}

/* BIO */
.mp-lead{font-family:var(--display);font-weight:500;font-size:clamp(1.3rem,2.5vw,1.9rem);line-height:1.3;letter-spacing:-.01em;color:var(--paper);margin-bottom:28px}
.mp-content p{font-size:clamp(1rem,1.7vw,1.2rem);color:var(--text-soft);line-height:1.7;margin-bottom:16px}
.mp-content p:last-child{margin-bottom:0}
.mp-content strong{color:var(--paper);font-weight:600}

/* SKILLS */
.mp-skills{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:640px){.mp-skills{grid-template-columns:1fr}}
.msk{background:linear-gradient(160deg,rgba(247,247,247,.03),transparent);border:1px solid var(--line);border-radius:16px;padding:28px 24px;transition:border-color .3s,transform .3s}
.msk:hover{border-color:rgba(245,189,2,.3);transform:translateY(-4px)}
.msk-n{font-family:var(--display);font-weight:500;font-size:1rem;color:var(--gold);display:block;margin-bottom:12px}
.msk h3{font-family:var(--display);font-weight:600;font-size:clamp(1.15rem,2.2vw,1.5rem);letter-spacing:-.015em;margin-bottom:10px;line-height:1.1}
.msk p{font-size:clamp(.9rem,1.5vw,1.05rem);color:var(--text-soft);line-height:1.7;margin-bottom:14px}
.msk-tags{display:flex;flex-wrap:wrap;gap:6px}
.msk-tags span{font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;border:1px solid var(--line);padding:4px 10px;border-radius:100px;color:var(--muted)}

/* HOW I WORK */
.mp-steps{display:flex;flex-direction:column;gap:0}
.mpst{display:flex;gap:24px;padding:clamp(20px,3vh,32px) 0;border-top:1px solid var(--line);transition:padding-left .3s;cursor:default}
.mpst:last-child{border-bottom:1px solid var(--line)}
.mpst:hover{padding-left:12px}
.mpst-n{font-family:var(--display);font-weight:500;font-size:1rem;color:var(--gold);min-width:36px;flex-shrink:0;padding-top:3px}
.mpst h3{font-family:var(--display);font-weight:600;font-size:clamp(1.15rem,2.2vw,1.5rem);letter-spacing:-.015em;margin-bottom:8px;line-height:1.1;transition:color .3s}
.mpst:hover h3{color:var(--gold)}
.mpst p{font-size:clamp(.9rem,1.5vw,1.05rem);color:var(--text-soft);line-height:1.7}

/* FACTS */
.mp-facts{display:grid;grid-template-columns:repeat(3,1fr);gap:20px}
@media(max-width:760px){.mp-facts{grid-template-columns:1fr}}
.mpf{border:1px solid var(--line);border-radius:16px;padding:24px 20px;text-align:center}
.mpf-val{font-family:var(--display);font-weight:700;font-size:clamp(2rem,5vw,3.5rem);letter-spacing:-.03em;color:var(--gold);display:block;margin-bottom:6px}
.mpf-lab{font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}

/* CERTIFIKACE */
.mp-certs{display:grid;grid-template-columns:1fr 1fr;gap:20px}
@media(max-width:640px){.mp-certs{grid-template-columns:1fr}}
.mcert{border:1px solid var(--line);border-radius:16px;padding:26px 24px;background:linear-gradient(160deg,rgba(247,247,247,.03),transparent);transition:border-color .3s,transform .3s;overflow:hidden}
.mcert:hover{border-color:rgba(245,189,2,.3);transform:translateY(-4px)}
.mcert-shot{display:block;margin:-26px -24px 20px;border-bottom:1px solid var(--line)}
.mcert-shot img{width:100%;display:block;transition:transform .4s cubic-bezier(.22,1,.36,1)}
.mcert:hover .mcert-shot img{transform:scale(1.03)}
.mcert-y{font-family:var(--display);font-weight:500;font-size:.82rem;letter-spacing:.08em;text-transform:uppercase;color:var(--gold);display:block;margin-bottom:12px}
.mcert h3{font-family:var(--display);font-weight:600;font-size:clamp(1.1rem,2vw,1.4rem);letter-spacing:-.015em;margin-bottom:8px;line-height:1.15}
.mcert p{font-size:.92rem;color:var(--text-soft);line-height:1.65;margin-bottom:14px}
.mcert-foot{display:flex;justify-content:space-between;align-items:baseline;gap:14px;flex-wrap:wrap}
.mcert-meta{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted)}
.mcert-links{display:inline-flex;gap:16px}
.mcert-link{font-size:.78rem;color:var(--gold);border-bottom:1px solid rgba(245,189,2,.35);padding-bottom:1px;transition:opacity .2s;white-space:nowrap}
.mcert-link:hover{opacity:.75}

/* CTA */
.mp-cta{padding:clamp(80px,14vh,160px) clamp(28px,6vw,100px);text-align:center;position:relative;overflow:hidden}
.mp-cta-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:70vw;height:70vw;max-width:900px;max-height:900px;border-radius:50%;background:radial-gradient(circle,rgba(86,33,94,.5),transparent 60%);filter:blur(70px);z-index:0;pointer-events:none}
.mp-cta-inner{position:relative;z-index:2}
.mp-cta h2{font-family:var(--display);font-weight:700;font-size:clamp(2.8rem,9vw,7rem);line-height:.9;letter-spacing:-.04em;margin:0 0 28px}
.mp-cta h2 em{font-style:normal;color:var(--gold)}
.mp-cta p{font-size:clamp(1rem,1.7vw,1.2rem);color:var(--text-soft);max-width:46ch;margin:0 auto 44px;line-height:1.7}
.mp-cta-btns{display:flex;align-items:center;justify-content:center;gap:28px;flex-wrap:wrap}
.mp-back{font-family:var(--display);font-weight:600;font-size:.95rem;color:var(--muted);border-bottom:1px solid var(--line);padding-bottom:3px;transition:color .2s,border-color .2s}
.mp-back:hover{color:var(--gold);border-color:var(--gold)}
</style>
