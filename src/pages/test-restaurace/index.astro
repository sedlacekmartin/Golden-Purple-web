---
import Tools from '../../layouts/Tools.astro';
---

<Tools
  title="Test: Plní váš web restaurace stoly? — Golden Purple"
  description="Interaktivní checklist 21 prvků webu restaurace. Zaškrtejte, co máte, a zjistěte své skóre. Od Golden Purple."
>

<div class="shell">
  <div class="intro">
    <div class="itag"><span class="d"></span><span class="mono">Test pro restaurace · 2 minuty</span></div>
    <h1>Plní váš web <em>stoly</em>?</h1>
    <p>Zaškrtejte, co váš web má. Dole se naživo počítá skóre — a hned uvidíte, kolik hostů vám možná uniká.</p>
  </div>

  <div id="list"></div>

  <p class="foot">Powered by <a href="https://goldenpurple.cz">Golden Purple</a> — postaráme se o vás královsky.</p>
</div>

<div class="scorebar">
  <div class="in">
    <div class="meter">
      <div class="top"><span class="label">Vaše skóre</span><span class="num"><b id="scoreNum">0</b> / 21</span></div>
      <div class="track"><div class="fill" id="fill"></div></div>
      <div class="verdict" id="verdict">Zaškrtejte prvky, které váš web má.</div>
    </div>
    <button class="cta-btn" id="showResult">Zobrazit výsledek</button>
  </div>
</div>

<div class="modal" id="modal">
  <div class="card">
    <button class="close" id="close">×</button>
    <div class="big"><b id="mScore">0</b></div>
    <div class="of">z 21 prvků</div>
    <h3 id="mTitle"></h3>
    <p class="vtext" id="mText"></p>
    <div class="gate">
      <p>Chcete vědět, které prvky doplnit jako první a jak? Pošleme vám konkrétní plán na míru — zdarma.</p>
      <div class="field">
        <input id="email" type="email" placeholder="vas@email.cz" autocomplete="email">
        <button id="send">Poslat plán</button>
      </div>
      <p class="okmsg" id="ok">✓ Hotovo — plán dorazí do pár minut.</p>
    </div>
  </div>
</div>

<style is:global>
.shell{position:relative;z-index:2;max-width:760px;margin:0 auto;padding:100px 22px 160px}

.intro{margin-bottom:36px}

.cat{font-family:var(--mono);font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:600;margin:30px 0 10px;padding-bottom:9px;border-bottom:1px solid var(--line)}
.item{display:flex;gap:15px;align-items:flex-start;padding:15px 16px;border-radius:13px;cursor:pointer;transition:background .2s;border:1px solid transparent}
.item:hover{background:rgba(247,247,247,.03)}
.item.on{background:rgba(245,189,2,.06);border-color:rgba(245,189,2,.22)}
.box{flex-shrink:0;width:24px;height:24px;border-radius:7px;border:2px solid var(--muted);display:flex;align-items:center;justify-content:center;margin-top:2px;transition:.2s}
.item.on .box{border-color:var(--gold);background:var(--gold)}
.box svg{width:13px;height:13px;color:var(--ink);opacity:0;transition:opacity .2s}
.item.on .box svg{opacity:1}
.tx .n{font-weight:600;font-size:1.05rem;margin-bottom:2px}
.tx .n .no{color:var(--gold);font-family:var(--mono);font-size:.8rem;margin-right:8px}
.tx .d{font-size:.92rem;color:var(--text-prose);line-height:1.45}
.tx .ex{font-size:.86rem;color:var(--gold);margin-top:5px;padding-left:11px;border-left:2px solid rgba(245,189,2,.4);font-style:italic}

.modal{position:fixed;inset:0;z-index:30;background:rgba(12,6,16,.8);backdrop-filter:blur(10px);display:none;align-items:center;justify-content:center;padding:24px}
.modal.on{display:flex}
.card{background:linear-gradient(160deg,var(--ink-2),var(--ink));border:1px solid var(--line);border-radius:22px;padding:40px 34px;max-width:480px;width:100%;text-align:center;position:relative}
.card .big{font-family:var(--display);font-weight:700;font-size:3.4rem;line-height:1;margin-bottom:6px}
.card .big b{color:var(--gold)}
.card .of{color:var(--muted);font-family:var(--mono);font-size:.8rem;letter-spacing:.1em;text-transform:uppercase;margin-bottom:18px}
.card h3{font-family:var(--display);font-weight:600;font-size:1.5rem;margin-bottom:10px}
.card .vtext{color:var(--text-soft);font-size:.97rem;margin-bottom:24px}
.gate{background:linear-gradient(150deg,var(--purple),var(--purple-deep));border-radius:14px;padding:22px;margin-top:4px}
.gate p{font-size:.9rem;color:var(--text-bright);margin-bottom:14px}
.field{display:flex;gap:9px}
.field input{flex:1;background:rgba(12,6,16,.4);border:1px solid rgba(247,247,247,.2);border-radius:10px;padding:13px 15px;color:var(--paper);font-family:var(--body);outline:none}
.field input:focus{border-color:var(--gold)}
.field button{background:var(--gold);color:var(--ink);border:none;padding:13px 18px;border-radius:10px;font-family:var(--display);font-weight:600;cursor:pointer;white-space:nowrap}
.okmsg{display:none;color:var(--gold);font-family:var(--display);margin-top:10px}
.okmsg.on{display:block}
.close{position:absolute;top:16px;right:18px;background:none;border:none;color:var(--muted);font-size:1.6rem;cursor:pointer;line-height:1}
.foot{margin-top:40px}
@media(prefers-reduced-motion:reduce){.fill{transition:none}}
</style>

<script>
document.addEventListener('astro:page-load', () => {
  const groups=[
    {cat:'A · První dojem (první 3 vteřiny)',items:[
      ['Jasné sdělení, kdo jste a co nabízíte','Návštěvník do 3 vteřin pozná typ podniku a atmosféru.','Baroko: koncept „restaurace a bar" hned v hero sekci.'],
      ['Kvalitní fotky jídla a prostoru','Host jí očima. Vlastní profesionální foto, ne stock.',''],
      ['Rychlé načítání na mobilu','Web nad 3 vteřiny ztrácí hosty dřív, než něco uvidí.',''],
      ['Otevírací doba viditelná hned','Nejčastější důvod návštěvy webu. Bez hledání.','Baroko: dynamická otevírací doba s aktuálním stavem.'],
    ]},
    {cat:'B · Orientace (co u vás je)',items:[
      ['Aktuální menu s cenami','Bez cen host odejde. Menu na webu, ne nečitelné PDF.',''],
      ['Denní menu / aktuální nabídka','Snadno aktualizovatelné bez programátora.',''],
      ['Označení alergenů a diet','Rozhoduje, jestli k vám skupina vůbec přijde.',''],
    ]},
    {cat:'C · Rozhodnutí (proč zrovna vy)',items:[
      ['Aktuální akce a události','Důvod přijít právě teď, ne někdy.','Baroko: akce přímo v hero, první co host uvidí.'],
      ['Atmosféra v obrazech','Host si potřebuje představit, že tam sedí.',''],
      ['Příběh podniku','Lidé chodí za lidmi a příběhem, ne za anonymní kuchyní.',''],
      ['Jasná cenová hladina','Host chce vědět, jestli je to na něj.',''],
    ]},
    {cat:'D · Rezervace (klíčový moment)',items:[
      ['Online rezervační systém','Host chce rezervovat ve 23:00 z gauče, ne volat.','Baroko: chytrý rezervační formulář přímo na webu.'],
      ['Rezervace dostupná z každé stránky','Tlačítko stále po ruce, ne schované v kontaktu.',''],
      ['Potvrzení a připomínka rezervace','Snižuje no-show a působí profesionálně.',''],
      ['Telefon na jeden klik','Kdo chce volat, ať klikne a vytočí.',''],
    ]},
    {cat:'E · Důvěra a dohledatelnost',items:[
      ['Google recenze na webu','Hodnocení od hostů buduje důvěru víc než vaše slova.','Na Rachačkách: Google hodnocení napojené na web.'],
      ['Mapa a snadná navigace','Vložená mapa, odkaz do navigace, parkování.',''],
      ['Google profil propojený s webem','Tady vás lidé hledají nejvíc.',''],
      ['Odkazy na sociální sítě','Propojené, aktivní, ne mrtvé.',''],
      ['Web v souladu s GDPR','Nejen zákon — i signál, že to myslíte vážně.',''],
      ['Konzistentní vizuální identita','Web, menu, sítě i podnik ladí. To dělá úroveň.',''],
    ]},
  ];

  const checkSvg='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><path d="M5 12l5 5L20 6"/></svg>';
  let n=0;
  const listEl=document.getElementById('list');
  listEl.innerHTML='';

  groups.forEach(g=>{
    const cat=document.createElement('div');cat.className='cat';cat.textContent=g.cat;listEl.appendChild(cat);
    g.items.forEach(([name,desc,ex])=>{
      n++;const no=String(n).padStart(2,'0');
      const it=document.createElement('div');it.className='item';it.dataset.on='0';
      it.innerHTML=`<div class="box">${checkSvg}</div><div class="tx"><div class="n"><span class="no">${no}</span>${name}</div><div class="d">${desc}</div>${ex?`<div class="ex">${ex}</div>`:''}</div>`;
      it.onclick=()=>{it.classList.toggle('on');it.dataset.on=it.classList.contains('on')?'1':'0';update();};
      listEl.appendChild(it);
    });
  });
  const TOTAL=n;

  function verdictFor(s){
    if(s===0)return['Zaškrtejte prvky, které váš web má.','',''];
    if(s>=17)return['<b>Skvělá práce.</b> Web vám reálně pracuje.','Web pracuje pro vás','Máte hotovo, co většina restaurací nemá. Pár posledních detailů a jste na špičce.'];
    if(s>=10)return['<b>Solidní základ</b> — ale necháváte hosty na stole.','Solidní základ, ale…','Máte rozjeto, jenže chybějící prvky vás stojí rezervace každý týden. Dají se doplnit.'];
    return['<b>Web vás stojí rezervace</b> každý den.','Tady se ztrácí hosté','Web teď spíš brzdí než pomáhá. Dobrá zpráva: každý doplněný prvek je vidět hned.'];
  }
  function update(){
    const s=[...document.querySelectorAll('.item')].filter(i=>i.dataset.on==='1').length;
    document.getElementById('scoreNum').textContent=s;
    document.getElementById('fill').style.width=(s/TOTAL*100)+'%';
    const[v]=verdictFor(s);
    document.getElementById('verdict').innerHTML=v;
    document.getElementById('showResult').classList.toggle('ready',s>0);
  }
  update();

  function openModal(){
    const s=[...document.querySelectorAll('.item')].filter(i=>i.dataset.on==='1').length;
    const[,title,text]=verdictFor(s);
    document.getElementById('mScore').textContent=s;
    document.getElementById('mTitle').textContent=title||'Začněte zaškrtávat';
    document.getElementById('mText').textContent=text||'';
    document.getElementById('modal').classList.add('on');
  }
  document.getElementById('showResult').onclick=openModal;
  document.getElementById('close').onclick=()=>document.getElementById('modal').classList.remove('on');
  document.getElementById('modal').onclick=e=>{if(e.target.id==='modal')document.getElementById('modal').classList.remove('on');};
  document.getElementById('send').onclick=async()=>{
    const emailEl=document.getElementById('email');
    const sendBtn=document.getElementById('send');
    const e=emailEl.value.trim();
    if(!/^[^@]+@[^@]+\.[^@]+$/.test(e)){emailEl.style.borderColor='var(--danger)';return;}
    emailEl.style.borderColor='';
    sendBtn.disabled=true;sendBtn.textContent='Odesílám…';
    const items=[...document.querySelectorAll('.item')];
    const s=items.filter(i=>i.dataset.on==='1').length;
    const[,verdict,verdictText]=verdictFor(s);
    const getName=i=>i.querySelector('.n').textContent.replace(/^\d+\s*/,'').trim();
    const checked=items.filter(i=>i.dataset.on==='1').map(getName);
    const missing=items.filter(i=>i.dataset.on==='0').map(getName);
    try{
      const res=await fetch('/api/send-results',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({type:'restaurant',email:e,score:s,total:TOTAL,verdict,verdictText,checked,missing})});
      const data=await res.json();
      if(res.ok&&data.ok){emailEl.value='';emailEl.disabled=true;document.getElementById('ok').classList.add('on');}
      else{sendBtn.disabled=false;sendBtn.textContent='Poslat plán';emailEl.style.borderColor='var(--danger)';}
    }catch{sendBtn.disabled=false;sendBtn.textContent='Poslat plán';}
  };
});
</script>

</Tools>
