/* CONTACT */
/* CONTACT */
#kontakt{justify-content:center;position:relative}
.ct-glow{position:absolute;top:10%;left:20%;width:60%;height:80%;background:radial-gradient(circle,rgba(86,33,94,.45),transparent 65%);filter:blur(80px);pointer-events:none;z-index:0}
.ct-grid{position:relative;z-index:2;display:grid;grid-template-columns:1fr 1fr;gap:clamp(40px,8vw,100px);align-items:center;width:100%}
.ct-left h2{font-family:var(--display);font-weight:700;font-size:clamp(2.8rem,6vw,5.5rem);line-height:.92;letter-spacing:-.035em;margin:14px 0 22px}
.ct-left h2 em{font-style:normal;background:linear-gradient(100deg,var(--gold-deep),var(--gold-soft),var(--gold-deep));background-size:200% 100%;-webkit-background-clip:text;background-clip:text;color:transparent;animation:shine 5s linear infinite}
.ct-left p{color:#D7CEDB;max-width:38ch;margin-bottom:32px;font-size:1.05rem;line-height:1.65}
.ct-channels{display:flex;flex-direction:column;gap:10px}
.ct-channels a{color:var(--muted);font-size:.95rem;transition:.2s;width:fit-content;border-bottom:1px solid transparent;padding-bottom:2px}
.ct-channels a:hover{color:var(--gold);border-color:rgba(245,189,2,.4)}
.ct-form{background:rgba(247,247,247,.04);border:1px solid var(--line);border-radius:20px;padding:clamp(24px,3vw,36px);display:flex;flex-direction:column;gap:18px}
.ct-field{display:flex;flex-direction:column;gap:7px}
.ct-field label{font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--muted)}
.ct-field input,.ct-field textarea{background:rgba(247,247,247,.05);border:1px solid var(--line);border-radius:10px;padding:13px 15px;color:var(--paper);font-family:var(--body);font-size:.98rem;outline:none;transition:.2s;resize:none;width:100%}
.ct-field input::placeholder,.ct-field textarea::placeholder{color:rgba(169,156,174,.45)}
.ct-field input:focus,.ct-field textarea:focus{border-color:rgba(245,189,2,.45);background:rgba(247,247,247,.08)}
.ct-bottom{display:flex;align-items:center;gap:20px;flex-wrap:wrap}
.ct-btn{display:inline-flex;align-items:center;gap:10px;background:var(--gold);color:var(--ink);font-family:var(--display);font-weight:600;font-size:1rem;padding:14px 26px;border-radius:100px;border:none;cursor:pointer;transition:transform .3s,box-shadow .3s,opacity .3s;flex-shrink:0}
.ct-btn:hover:not(:disabled){transform:translateY(-2px);box-shadow:0 12px 32px rgba(245,189,2,.35)}
.ct-btn:disabled{opacity:.55;cursor:not-allowed}
.ct-gdpr{font-size:.68rem;color:var(--muted);line-height:1.5;max-width:26ch;opacity:.7}
.ct-success{display:flex;flex-direction:column;align-items:flex-start;gap:10px;padding:clamp(24px,3vw,36px)}
.ct-success h3{font-family:var(--display);font-weight:600;font-size:1.6rem}
.ct-success p{color:#D7CEDB}
.ct-error{color:#ff6b6b;font-size:.9rem;margin-top:4px}
.ct-foot{position:absolute;bottom:28px;left:0;right:0;text-align:center;font-size:.78rem;color:var(--muted);z-index:2;padding:0 clamp(28px,6vw,100px)}
.ct-foot a{color:var(--muted);transition:color .2s}
.ct-foot a:hover{color:var(--gold)}
.btn{display:inline-flex;align-items:center;gap:11px;background:var(--gold);color:var(--ink);padding:18px 38px;border-radius:100px;font-weight:600;font-family:var(--display);font-size:1.1rem;transition:transform .2s,box-shadow .2s}
.btn:hover{transform:translateY(-3px);box-shadow:0 18px 44px rgba(245,189,2,.42)}
@media(max-width:860px){.ct-grid{grid-template-columns:1fr}.ct-left h2{font-size:clamp(2.6rem,9vw,4rem)}}

/* CURSOR */

/* KEYFRAMES */
@keyframes rise{to{transform:translateY(0)}}
@keyframes fadeUp{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
@keyframes shine{to{background-position:-250% 0}}
@keyframes scan{0%{transform:translateX(-100%)}100%{transform:translateX(100%)}}

/* REVEAL */
.cv{opacity:0;transform:translateY(40px);transition:opacity .9s cubic-bezier(.19,1,.22,1),transform .9s cubic-bezier(.19,1,.22,1)}
.panel.active .cv{opacity:1;transform:none}
.panel.active .cv:nth-child(2){transition-delay:.08s}
.panel.active .cv:nth-child(3){transition-delay:.16s}
.panel.active .cv:nth-child(4){transition-delay:.24s}

@media(prefers-reduced-motion:reduce){
  html{scroll-behavior:auto}
  h1.big .ln i,.shine,.hsub{animation:none!important;opacity:1!important;transform:none!important}
  .cv{opacity:1;transform:none;transition:none}
  .ct-left h2 em{animation:none!important}
}
</style>

<script>
let _io: IntersectionObserver | null = null;
let _ac: AbortController | null = null;

function initIndex() {
  // Cleanup previous run
  _io?.disconnect();
  _ac?.abort();
  _ac = new AbortController();
  const sig = _ac.signal;

  document.querySelectorAll<HTMLElement>('.yr').forEach(el => el.textContent = String(new Date().getFullYear()));

  // Contact form
  const ctForm    = document.getElementById('ctForm')    as HTMLFormElement | null;
  const ctBtn     = document.getElementById('ctBtn')     as HTMLButtonElement | null;
  const ctSuccess = document.getElementById('ctSuccess') as HTMLElement | null;
  const ctError   = document.getElementById('ctError')   as HTMLElement | null;

  ctForm?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!ctBtn || !ctSuccess || !ctError) return;
    ctBtn.disabled = true;
    ctBtn.querySelector('.ct-btn-label')!.textContent = 'Odesílám…';
    ctError.hidden = true;
    try {
      const res  = await fetch('/api/contact', { method: 'POST', body: new FormData(ctForm) });
      const data = await res.json();
      if (res.ok && data.ok) {
        ctForm.hidden = true;
        ctSuccess.hidden = false;
      } else {
        ctError.textContent = data.error ?? 'Něco se pokazilo. Zkuste to znovu.';
        ctError.hidden = false;
        ctBtn.disabled = false;
        ctBtn.querySelector('.ct-btn-label')!.textContent = 'Odeslat poptávku';
      }
    } catch {
      ctError.textContent = 'Problém s připojením. Zkuste to prosím znovu.';
      ctError.hidden = false;
      ctBtn.disabled = false;
      ctBtn.querySelector('.ct-btn-label')!.textContent = 'Odeslat poptávku';
    }
  }, { signal: sig });

  // Panels + dots
  const panels = [...document.querySelectorAll<HTMLElement>('.panel')];
  const panelLabels = ['Úvod','Poznáte se?','AMFELS','Restaurace Baroko','Arlex','Na Rachačkách','Realizace','Golden Vision','Co umíme','Golden Labs','Nástroje zdarma','Ceník','Martin Sedláček','Kontakt'];
  const dotsWrap = document.getElementById('dots');
  if (dotsWrap) {
    dotsWrap.innerHTML = '';
    panels.forEach((p, i) => {
      const b    = document.createElement('button');
      const span = document.createElement('span');
      b.setAttribute('aria-label', panelLabels[i] || ('Sekce ' + (i + 1)));
      b.onclick = () => p.scrollIntoView({ behavior: 'smooth' });
      span.className = 'dot-label';
      span.textContent = panelLabels[i] || ('Sekce ' + (i + 1));
      b.appendChild(span);
      dotsWrap.appendChild(b);
    });
  }
  const dots = [...(dotsWrap?.children ?? [])];

  _io = new IntersectionObserver((es) => {
    es.forEach(e => {
      if (e.isIntersecting) {
        const i = panels.indexOf(e.target as HTMLElement);
        e.target.classList.add('active');
        dots.forEach((d, j) => d.classList.toggle('on', j === i));
      } else {
        e.target.classList.remove('active');
      }
    });
  }, { root: null, threshold: .45 });
  panels.forEach(p => _io!.observe(p));

  // Keyboard nav
  document.addEventListener('keydown', e => {
    const cur = panels.findIndex(p => p.classList.contains('active'));
    if (e.key === 'ArrowDown' && cur < panels.length - 1) { e.preventDefault(); panels[cur + 1].scrollIntoView(); }
    if (e.key === 'ArrowUp'   && cur > 0)                  { e.preventDefault(); panels[cur - 1].scrollIntoView(); }
  }, { signal: sig });

  // Hero glow parallax
  const hgA = document.getElementById('hgA');
  const hgB = document.getElementById('hgB');
  if (hgA && hgB) {
    document.addEventListener('mousemove', e => {
      const x = (e.clientX / window.innerWidth  - .5) * 2;
      const y = (e.clientY / window.innerHeight - .5) * 2;
      hgA.style.transform = `translate(${x * 30}px, ${y * 22}px)`;
      hgB.style.transform = `translate(${-x * 22}px, ${-y * 16}px)`;
    }, { passive: true, signal: sig });
  }

  // Lazy load hCaptcha — only when kontakt section enters viewport
  const kontakt = document.getElementById('kontakt');
  if (kontakt) {
    const hcapObs = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting) {
        hcapObs.disconnect();
        if (!document.querySelector('script[src*="hcaptcha.com"]')) {
          const s = document.createElement('script');
          s.src = 'https://js.hcaptcha.com/1/api.js';
          s.async = true;
          s.defer = true;
          document.head.appendChild(s);
        }
      }
    }, { rootMargin: '200px' });
    hcapObs.observe(kontakt);
  }
}

document.addEventListener('astro:page-load', initIndex);
</script>

