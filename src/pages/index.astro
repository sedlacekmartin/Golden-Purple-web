---
import Base from '../layouts/Base.astro';
import Topbar from '../components/Topbar.astro';
import Arrow from '../components/Arrow.astro';

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Kolik stojí nový web?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ceny začínají od 25 000 Kč za landing page, komplexní weby od 55 000 Kč. Finální cena závisí na rozsahu a funkcích. Nejsme plátci DPH, ceny jsou konečné."
      }
    },
    {
      "@type": "Question",
      "name": "Jak dlouho trvá tvorba webu?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Standardní web dodáme za 4–8 týdnů od zahájení spolupráce a dodání podkladů. Expresní realizace do 2 týdnů je možná s příplatkem +50 %."
      }
    },
    {
      "@type": "Question",
      "name": "Pracujete jen pro firmy z Vysočiny?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ne, spolupracujeme s firmami po celé České republice. Osobní schůzky nabízíme v Třebíči, Jihlavě a Brně — ostatní řešíme online bez problémů."
      }
    },
    {
      "@type": "Question",
      "name": "Co potřebuji připravit před začátkem?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Stačí mít představu o tom, co web má dělat a komu. O texty, fotografie a grafiku se postaráme společně. Začneme krátkým úvodním hovorem, kde vše probereme."
      }
    },
    {
      "@type": "Question",
      "name": "Poskytujete také správu webu po spuštění?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ano. Nabízíme pravidelnou správu, technické aktualizace a rozvoj webu. Podmínky domluvíme individuálně podle potřeb projektu."
      }
    },
    {
      "@type": "Question",
      "name": "Děláte také e-shopy nebo rezervační systémy?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Ano — e-shopy stavíme na WooCommerce nebo na míru. Rezervační systémy pro restaurace a ubytování řeší náš vlastní produkt Get my Reservation."
      }
    }
  ]
};

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": "Golden Purple",
  "url": "https://goldenpurple.cz",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Služby Golden Purple",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Tvorba webových stránek",
          "description": "Stavíme weby na míru, které přivádí poptávky a odpovídají kvalitě firmy. Od landing page po komplexní firemní web.",
          "areaServed": "CZ"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Branding a vizuální identita",
          "description": "Vytváříme unikátní vizuální identity — logo, manuál značky, typografie a barevný systém, které firmu odliší.",
          "areaServed": "CZ"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Digitální marketing a SEO",
          "description": "Návrh a správa digitálního marketingu — SEO, Google Ads, Meta, obsahová strategie. Výsledky, ne jen výstupy.",
          "areaServed": "CZ"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Vývoj digitálních produktů",
          "description": "Vyvíjíme vlastní digitální nástroje — rezervační systémy, analytické dashboardy a SaaS produkty na míru.",
          "areaServed": "CZ"
        }
      }
    ]
  }
};
---

<Base
  title="Golden Purple — digitálně kreativní agentura"
  description="Golden Purple — digitálně kreativní agentura. Postaráme se o vás královsky. Třebíč · Jihlava · Brno."
  noFooter={true}
>

<Topbar />

<div class="dots" id="dots"></div>

<main>
<div class="scroller" id="scroller">

  <section class="panel" id="uvod">
    <div class="grain"></div>
    <div class="h-hero-bg"></div>
    <div class="h-glow-a" id="hgA"></div>
    <div class="h-glow-b" id="hgB"></div>
<div class="h-scanline"></div>

    <div class="h-wrap">
      <div class="h-badge"><span class="d"></span>Digitální studio · Třebíč · Jihlava · Brno</div>

      <div class="h-split">
        <div class="h-left">
          <h1 class="big">
            <span class="ln"><span style="animation-delay:.15s">Digitální prezentace</span></span>
            <span class="ln"><span style="animation-delay:.3s">pro firmy, které</span></span>
            <span class="ln"><span class="shine" style="animation-delay:.5s">nejsou malé.</span></span>
          </h1>
        </div>
      </div>

      <p class="h-vp">Navrhujeme weby, značky a systémy, které odpovídají skutečné kvalitě vaší práce — a pomáhají zákazníkům rychle pochopit, proč si vybrat právě vás.</p>

      <div class="h-cta">
        <a class="btn" href="#kontakt">Probrat projekt<Arrow size={17} /></a>
        <a class="h-sec" href="/prace/">Prohlédnout práci</a>
      </div>

      <div class="h-proof">
        <span>4 vlastní produkty</span><span>B2B, restaurace &amp; ubytování</span><span>Třebíč · Jihlava · Brno</span>
      </div>

    </div>
  </section>

  <section class="panel" id="vyzvy">
    <div class="bolesti-glow"></div>
    <div class="bolesti-inner">
      <div class="bolesti-head">
        <p class="eyebrow cv">Poznáte se?</p>
        <h2 class="cv">Možná nemáte špatnou firmu.<br><em>Možná jen váš digitál neříká dost.</em></h2>
      </div>
      <p class="bolesti-sub cv">Nejčastěji jsou to B2B firmy, restaurace, ubytovací zařízení a lokální podnikatelé — firmy s dobrým produktem nebo službou, jejichž online prezentace ještě nestíhá.</p>
      <div class="bolesti-grid">
        <div class="bcard cv"><span class="bc-n">01</span><p>Web působí levněji než práce, kterou odvádíte.</p></div>
        <div class="bcard cv"><span class="bc-n">02</span><p>Lidé přijdou, projdou pár sekcí — a neozvou se.</p></div>
        <div class="bcard cv"><span class="bc-n">03</span><p>Každá drobná změna znamená čekat, vysvětlovat, urgovat.</p></div>
        <div class="bcard cv"><span class="bc-n">04</span><p>Značka nemá jasný výraz. Vypadá slušně, ale nezůstane v hlavě.</p></div>
        <div class="bcard cv"><span class="bc-n">05</span><p>Marketing běží, rozpočet mizí, ale obchod necítí rozdíl.</p></div>
        <div class="bcard cv"><span class="bc-n">06</span><p>Tušíte, že něco brzdí poptávky. Jen přesně nevíte co.</p></div>
      </div>
      <div class="bolesti-cta cv">
        <p>Začněte web scanem. Ukáže, kde web ztrácí rychlost, důvěru i zákazníky.</p>
        <a class="btn" href="/scan/">Spustit web scan zdarma <Arrow size={17} /></a>
      </div>
    </div>
  </section>

  <section class="panel" id="vybrana-prace">
    <div class="vp-glow"></div>
    <div class="vp-inner">
      <div class="vp-left">
        <p class="eyebrow cv">Vybraná práce</p>
        <h2 class="cv">Práce, která nevypadá<br><em>jen dobře na monitoru.</em></h2>
        <div class="vp-list">
          <a class="vp-item cv" href="/prace/amfels/" data-i="0" aria-selected="false">
            <span class="vp-n">01</span>
            <span class="vp-meta">
              <span class="vp-name">AMFELS</span>
              <span class="vp-tag">Web · Landing · SEO</span>
              <span class="vp-desc-mob">Z technicky široké nabídky přehledný obchodní web — služby, důvěra, reference a cesta k poptávce.</span>
            </span>
            <svg class="vp-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="vp-item cv" href="/prace/baroko/" data-i="1" aria-selected="false">
            <span class="vp-n">02</span>
            <span class="vp-meta">
              <span class="vp-name">Restaurace Baroko</span>
              <span class="vp-tag">Web · Rezervace · Branding</span>
              <span class="vp-desc-mob">Z klasického restauračního webu výraznější prezentace s rezervací, akcemi a atmosférou baru.</span>
            </span>
            <svg class="vp-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="vp-item cv" href="/prace/arlex/" data-i="2" aria-selected="false">
            <span class="vp-n">03</span>
            <span class="vp-meta">
              <span class="vp-name">Arlex</span>
              <span class="vp-tag">E-shop · B2B · Branding</span>
              <span class="vp-desc-mob">B2B e-shop pro tisícovku produktů, schvalované účty a objednávky bez zbytečné ruční práce.</span>
            </span>
            <svg class="vp-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
          <a class="vp-item cv" href="/prace/na-rachackach/" data-i="3" aria-selected="false">
            <span class="vp-n">04</span>
            <span class="vp-meta">
              <span class="vp-name">Na Rachačkách</span>
              <span class="vp-tag">Web · Ubytování · Rezervace</span>
              <span class="vp-desc-mob">Web, který z dobrého Google hodnocení dělá důvod k rezervaci.</span>
            </span>
            <svg class="vp-arr" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
          </a>
        </div>
        <a class="btn cv" href="/prace/">
          Prohlédnout všechny projekty
          <Arrow size={17} />
        </a>
      </div>
      <div class="vp-right cv">
        <div class="vp-previews">
          <div class="vp-preview" data-i="0">
            <div class="vp-prev-glow" style="background:radial-gradient(ellipse at 30% 30%,rgba(86,33,94,.72),transparent 65%)"></div>
            <span class="vp-prev-n" aria-hidden="true">01</span>
            <div class="vp-prev-body">
              <div class="vp-prev-tags">Web · Landing · SEO</div>
              <h3 class="vp-prev-title">AMFELS</h3>
              <p class="vp-prev-desc">Z technicky široké nabídky jsme udělali přehledný obchodní web: služby, důvěra, reference a jasná cesta k poptávce.</p>
            </div>
          </div>
          <div class="vp-preview" data-i="1">
            <div class="vp-prev-glow" style="background:radial-gradient(ellipse at 70% 65%,rgba(245,189,2,.22),transparent 65%)"></div>
            <span class="vp-prev-n" aria-hidden="true">02</span>
            <div class="vp-prev-body">
              <div class="vp-prev-tags">Web · Rezervace · Branding</div>
              <h3 class="vp-prev-title">Restaurace Baroko</h3>
              <p class="vp-prev-desc">Z klasického restauračního webu vznikla tmavší, výraznější prezentace s rezervací, akcemi a atmosférou baru.</p>
            </div>
          </div>
          <div class="vp-preview" data-i="2">
            <div class="vp-prev-glow" style="background:radial-gradient(ellipse at 40% 40%,rgba(142,77,151,.58),transparent 65%)"></div>
            <span class="vp-prev-n" aria-hidden="true">03</span>
            <div class="vp-prev-body">
              <div class="vp-prev-tags">E-shop · B2B · Branding</div>
              <h3 class="vp-prev-title">Arlex</h3>
              <p class="vp-prev-desc">B2B e-shop pro tisícovku produktů — schvalované účty a objednávkový proces bez zbytečné ruční práce.</p>
            </div>
          </div>
          <div class="vp-preview" data-i="3">
            <div class="vp-prev-glow" style="background:radial-gradient(ellipse at 60% 70%,rgba(245,189,2,.19),transparent 65%)"></div>
            <span class="vp-prev-n" aria-hidden="true">04</span>
            <div class="vp-prev-body">
              <div class="vp-prev-tags">Web · Ubytování · Rezervace</div>
              <h3 class="vp-prev-title">Na Rachačkách</h3>
              <p class="vp-prev-desc">Web, který z dobrého Google hodnocení dělá důvod k rezervaci — rychle, přehledně, hlavně na mobilu.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="panel" id="golden-vision">
    <div class="gv-glow"></div>
    <div class="gv-inner">
      <div class="gv-left">
        <p class="eyebrow cv">Golden Vision</p>
        <h2 class="cv">Digitál má práci zjednodušovat.<br><em>Ne přidávat další.</em></h2>
        <p class="gv-desc cv">Navrhujeme weby a systémy tak, aby zákazník nemusel přemýšlet, kde kliknout — a vy nemuseli pokaždé někoho prosit o drobnou změnu. Každá nová funkce má ubírat kroky, ne přidávat vrstvy.</p>
      </div>
      <div class="gv-right">
        <div class="gv-step cv">
          <span class="gvs-n">01</span>
          <span class="gvs-t">Zákazník ví, co má udělat.</span>
          <span class="gvs-d">Struktura vede k akci místo k bloudění.</span>
        </div>
        <div class="gv-step cv">
          <span class="gvs-n">02</span>
          <span class="gvs-t">Vy máte obsah pod kontrolou.</span>
          <span class="gvs-d">Důležité věci zvládnete bez čekání. O zbytek se postaráme my.</span>
        </div>
        <div class="gv-step cv">
          <span class="gvs-n">03</span>
          <span class="gvs-t">Systém bere rutinu na sebe.</span>
          <span class="gvs-d">Co se opakuje, má dělat software — ne člověk po večerech.</span>
        </div>
      </div>
    </div>
  </section>

  <section class="panel" id="sluzby">
    <div class="head cv"><p class="eyebrow">Co stavíme</p><h2>Od první myšlenky po spuštění. <em>Vše v jednom kontextu.</em></h2></div>
    <div class="srow cv"><span class="sn">01</span><span class="st">Weby, které vysvětlí hodnotu firmy rychleji než obchodník.</span><span class="sd">Struktura, UX, texty a design navržené tak, aby návštěvník pochopil nabídku, uvěřil jí a věděl, co má udělat dál.</span></div>
    <div class="srow cv"><span class="sn">02</span><span class="st">Značky, které nepůsobí zaměnitelně.</span><span class="sd">Logo, vizuální systém, brand manuál a materiály, které sjednotí firmu navenek — od webu po obchodní prezentaci.</span></div>
    <div class="srow cv"><span class="sn">03</span><span class="st">Marketing, který má kam posílat lidi.</span><span class="sd">Kampaně na Googlu, Metě a v e-mailu dávají smysl až ve chvíli, kdy web, nabídka a měření drží pohromadě.</span></div>
    <div class="srow cv"><span class="sn">04</span><span class="st">Systémy, které odstraňují ruční práci.</span><span class="sd">Rezervace, formuláře, správa obsahu a vlastní nástroje tam, kde hotové pluginy nestačí nebo způsobují víc problémů, než řeší.</span></div>
  </section>

  <section class="panel" id="spoluprace">
    <div class="collab-glow"></div>
    <div class="collab-inner">
      <div class="collab-left">
        <p class="eyebrow cv">Jak to funguje</p>
        <h2 class="cv">Jak z nejasného zadání<br><em>vznikne hotový digitál.</em></h2>
        <p class="collab-sub cv">Každý projekt začíná tím, že pochopíme obchod. Pak teprve řešíme web, značku nebo systém.</p>
      </div>
      <div class="collab-steps">
        <div class="cstep cv">
          <span class="cs-n">01</span>
          <div class="cs-body">
            <h3>Nejdřív pochopíme obchod.</h3>
            <p>Co prodáváte, komu, za kolik, proč si vás lidé vybírají — a kde dnes vzniká tření.</p>
          </div>
        </div>
        <div class="cstep cv">
          <span class="cs-n">02</span>
          <div class="cs-body">
            <h3>Najdeme směr.</h3>
            <p>Projdeme web, značku, komunikaci a konkurenci. Pak navrhneme, co má největší smysl řešit jako první.</p>
          </div>
        </div>
        <div class="cstep cv">
          <span class="cs-n">03</span>
          <div class="cs-body">
            <h3>Postavíme obsahovou kostru.</h3>
            <p>Nezačínáme barvami. Nejdřív musí sedět argumentace, struktura a cesta návštěvníka.</p>
          </div>
        </div>
        <div class="cstep cv">
          <span class="cs-n">04</span>
          <div class="cs-body">
            <h3>Navrhneme a vyvineme řešení.</h3>
            <p>Design, texty, technika a správa vznikají jako jeden celek. Ne jako slepenec dodatečných oprav.</p>
          </div>
        </div>
        <div class="cstep cv">
          <span class="cs-n">05</span>
          <div class="cs-body">
            <h3>Spustíme, změříme, zlepšíme.</h3>
            <p>Po spuštění sledujeme rychlost, analytiku a chování lidí. Web není plakát — má pracovat.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="panel" id="labs">
    <div class="ltease-glow"></div>
    <div class="ltease-inner">
      <p class="eyebrow cv">Golden Labs</p>
      <h2 class="cv">Když hotové řešení nestačí,<br><em>stavíme vlastní.</em></h2>
      <p class="ltease-desc cv">Vedle klientských projektů vyvíjíme digitální produkty pro provoz, rezervace, QR tracking a správu webů. Díky tomu nepřemýšlíme jen jako designéři — přemýšlíme jako lidé, kteří musí dostat systém do reálného provozu.</p>
      <a class="btn cv" href="/labs/">
        Prohlédnout produkty
        <Arrow size={17} />
      </a>
    </div>
  </section>

  <section class="panel" id="nastroje">
    <div class="head cv"><p class="eyebrow">Nástroje zdarma</p><h2>Než začnete měnit web, <em>zjistěte, co ho opravdu brzdí.</em></h2></div>
    <div class="tools">
      <a class="tool cv" href="/scan/">
        <span class="free">Zdarma</span>
        <span class="tno">01 · Web</span>
        <h3>Web scan</h3>
        <p>Změří rychlost, mobil, SEO a technické základy. Dostanete první seznam věcí, které mají největší vliv na výkon webu.</p>
        <span class="go">Spustit scan <Arrow size={15} /></span>
      </a>
      <a class="tool cv" href="/test-restaurace/">
        <span class="free">Zdarma</span>
        <span class="tno">02 · Restaurace</span>
        <h3>Plní váš web stoly?</h3>
        <p>21 prvků, které rozhodují, jestli návštěvník jen koukne na menu — nebo si rovnou rezervuje stůl.</p>
        <span class="go">Spustit test <Arrow size={15} /></span>
      </a>
      <a class="tool cv" href="/brand-scorecard/">
        <span class="free">Zdarma</span>
        <span class="tno">03 · Značka</span>
        <h3>Působí vaše značka tak silně, jak silná je vaše firma?</h3>
        <p>Pět pilířů značky. Za pár minut zjistíte, jestli je problém ve vzhledu, sdělení, odlišení nebo důvěře.</p>
        <span class="go">Spustit scorecard <Arrow size={15} /></span>
      </a>
    </div>
  </section>

  <section class="panel" id="cenik">
    <div class="cenik-glow"></div>
    <div class="head cv"><p class="eyebrow">Ceník</p><h2>Neprodáváme hodiny u počítače.<br><em>Stavíme řešení, která mají obchodní smysl.</em></h2></div>
    <p class="cenik-intro cv">Cena se odvíjí od rozsahu, odpovědnosti a hodnoty, kterou má projekt přinést. Tady je orientační rámec, abyste hned věděli, jestli jsme pro sebe vhodní.</p>
    <div class="cenik-grid">
      <div class="cprod cv">
        <span class="cp-label">Audit &amp; strategie</span>
        <p class="cp-for">Pro firmy, které tuší, že web, značka nebo komunikace nefungují — ale nechtějí začít drahým redesignem naslepo.</p>
        <div class="cp-price">od <b>9 900</b> Kč</div>
        <span class="cp-unit">jednorázově</span>
        <ul class="cp-list">
          <li>Audit webu a komunikace</li>
          <li>Návrh struktury a obsahu</li>
          <li>Konkrétní priority a doporučení</li>
        </ul>
        <span class="cp-tag">Ideální první krok</span>
      </div>
      <div class="cprod feat cv">
        <span class="cp-label">Web &amp; prezentace</span>
