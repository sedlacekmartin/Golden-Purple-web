.cprod.feat{border-color:rgba(245,189,2,.45);background:linear-gradient(160deg,rgba(86,33,94,.22),var(--ink))}
.cprod.feat::before{content:'Nejžádanější';position:absolute;top:16px;right:16px;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;font-weight:700;color:var(--ink);background:var(--gold);padding:4px 10px;border-radius:100px}
.cp-label{font-size:.74rem;letter-spacing:.14em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:10px}
.cp-for{font-size:.82rem;color:var(--muted);line-height:1.5;margin-bottom:16px;opacity:.8}
.cp-price{font-family:var(--display);font-weight:500;font-size:1.05rem;color:var(--muted);line-height:1}
.cp-price b{font-family:var(--display);font-weight:700;font-size:clamp(1.9rem,3vw,2.4rem);color:var(--paper);letter-spacing:-.02em;display:inline-block;margin:0 2px}
.cp-unit{font-size:.78rem;color:var(--muted);margin-top:6px;display:block}
.cp-list{list-style:none;margin:20px 0 0;padding:0;flex:1}
.cp-list li{font-size:.88rem;color:#CFC4D3;line-height:1.4;padding:9px 0 9px 22px;border-top:1px solid var(--line);position:relative}
.cp-list li::before{content:'';position:absolute;left:0;top:15px;width:7px;height:7px;border-radius:50%;background:var(--gold);opacity:.7}
.cp-tag{font-size:.74rem;color:var(--muted);margin-top:18px;font-style:italic}
.cenik-note{position:relative;z-index:2;margin-top:clamp(22px,3.5vh,36px);font-size:.86rem;color:var(--muted);line-height:1.6;max-width:80ch}
.cenik-note b{color:#D7CEDB;font-weight:600}

/* MARTIN */
#o-nas{justify-content:center;overflow:hidden}
.martin-glow{position:absolute;top:50%;left:-120px;transform:translateY(-50%);width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(245,189,2,.11),transparent 60%);filter:blur(80px);z-index:0;pointer-events:none}
.martin-inner{position:relative;z-index:2;width:100%;max-width:780px}
.martin-h2{font-family:var(--display);font-weight:700;font-size:clamp(3rem,9vw,7rem);line-height:.9;letter-spacing:-.04em;margin:14px 0 32px}
.martin-bio{font-size:clamp(1.05rem,1.7vw,1.3rem);color:#D7CEDB;line-height:1.7;max-width:56ch;margin-bottom:18px}
.martin-chips{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px}
.martin-chips span{font-size:.8rem;letter-spacing:.08em;border:1px solid var(--line);padding:8px 16px;border-radius:100px;color:#CFC4D3}
