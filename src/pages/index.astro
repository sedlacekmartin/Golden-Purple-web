/* CENÍK */
#cenik{justify-content:center;overflow:hidden}
.cenik-glow{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);width:70vw;height:70vw;max-width:850px;max-height:850px;border-radius:50%;background:radial-gradient(circle,rgba(86,33,94,.3),transparent 60%);filter:blur(80px);z-index:0;pointer-events:none}
