    <div class="content">
      <p class="label">Připravujeme něco výjimečného</p>
      <h1>Brzy<br/>online.</h1>
      <p class="sub">Weby, značky a systémy, které firmám přivádí poptávky.</p>
      <a class="cta" href="mailto:info@goldenpurple.cz">info@goldenpurple.cz</a>
    </div>
  </main>

  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --gold: #F5BD02;
      --purple-deep: #3B1243;
      --ink: #0C0610;
      --paper: #F7F7F7;
      --muted: #A99CAE;
      --display: 'Clash Display', system-ui, sans-serif;
      --body: 'General Sans', system-ui, sans-serif;
    }
    html { overflow: hidden; }
    body {
      background: var(--ink);
      color: var(--paper);
      font-family: var(--body);
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      -webkit-font-smoothing: antialiased;
    }
    .glow {
      position: fixed;
      top: -20%;
      right: -10%;
      width: 60vw;
      height: 60vw;
      max-width: 800px;
      max-height: 800px;
      border-radius: 50%;
      background: radial-gradient(circle, rgba(86,33,94,.45), transparent 65%);
      filter: blur(80px);
      pointer-events: none;
    }
    main {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding: clamp(32px, 6vw, 80px);
      gap: clamp(60px, 15vh, 140px);
    }
    .logo svg {
      height: 36px;
      width: auto;
      display: block;
      opacity: .9;
    }
    .content {
      display: flex;
      flex-direction: column;
      gap: 20px;
      max-width: 640px;
    }
    .label {
      font-size: .75rem;
      letter-spacing: .16em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 500;
    }
    h1 {
      font-family: var(--display);
      font-weight: 700;
      font-size: clamp(4rem, 12vw, 9rem);
      line-height: .95;
      letter-spacing: -.03em;
    }
    .sub {
      font-size: clamp(1rem, 2vw, 1.2rem);
      color: var(--muted);
      line-height: 1.6;
      max-width: 420px;
    }
    .cta {
      display: inline-block;
      margin-top: 8px;
      color: var(--paper);
      text-decoration: none;
      font-size: .85rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      border-bottom: 1px solid rgba(247,247,247,.3);
      padding-bottom: 4px;
      width: fit-content;
      transition: color .2s, border-color .2s;
    }
    .cta:hover { color: var(--gold); border-color: var(--gold); }
  </style>
</body>
</html>
