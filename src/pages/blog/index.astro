---
import Base from '../../layouts/Base.astro';
import Topbar from '../../components/Topbar.astro';
import Arrow from '../../components/Arrow.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const featured = posts[0];
const rest = posts.slice(1);
---

<Base
  title="Blog — Golden Purple"
  description="Tipy, postupy a pohled za oponu digitálního marketingu a brandingu od Golden Purple."
>

<Topbar />

<section class="bhero">
  <div class="wrap">
    <span class="eyebrow reveal">Blog</span>
    <h1 class="reveal">Tipy & <em>pohled za oponu</em>.</h1>
    <p class="reveal">Jak přemýšlíme o webu, brandingu a digitálním marketingu — bez zbytečné omáčky.</p>
  </div>
</section>

{posts.length === 0 ? (
  <div class="wrap bempty reveal">
    <p>Zatím žádné příspěvky. Brzy se dočkáš.</p>
  </div>
) : (
  <>
    {featured && (
      <section class="bfeatured">
        <div class="wrap">
          <a class="bfcard reveal" href={`/blog/${featured.id}`}>
            <div class="bfvis">
              {featured.data.image
                ? <img src={featured.data.image} alt={featured.data.title} />
                : <span class="bfbignum">01</span>
              }
            </div>
            <div class="bfbody">
              <h2>{featured.data.title}</h2>
              <p>{featured.data.description}</p>
              <div class="bffooter">
                <time datetime={featured.data.pubDate.toISOString()}>
                  {featured.data.pubDate.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                <span class="bfgo">
                  Číst článek
                  <Arrow />
                </span>
              </div>
            </div>
          </a>
        </div>
      </section>
    )}

    {rest.length > 0 && (
      <section class="bgrid-sec">
        <div class="wrap">
          <div class="bgh">Všechny články</div>
          <div class="bgrid">
            {rest.map((post, i) => (
              <a class="bcard reveal" href={`/blog/${post.id}`}>
                {post.data.image
                  ? <img src={post.data.image} alt={post.data.title} class="bcard-img" />
                  : <div class="bcard-ph"><span class="bcard-n">0{i + 2}</span></div>
                }
                <div class="bcard-body">
                  <h3>{post.data.title}</h3>
                  <p>{post.data.description}</p>
                  <div class="bcard-foot">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString('cs-CZ', { year: 'numeric', month: 'long', day: 'numeric' })}
                    </time>
                    <span class="bcard-arr">→</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        </div>
      </section>
    )}
  </>
)}

<script>
  let _io = null;

  function revealAboveFold() {
    const revs = [...document.querySelectorAll('.reveal')];
    if (!revs.length) return;
    revs.forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < innerHeight && r.bottom > 0) {
        el.style.transition = 'none';
        el.classList.add('in');
      }
    });
    requestAnimationFrame(() => revs.forEach(el => { el.style.transition = ''; }));
  }

  document.addEventListener('astro:after-swap', revealAboveFold);

  document.addEventListener('astro:page-load', () => {
    _io?.disconnect();
    const revs = [...document.querySelectorAll('.reveal')];

    revs.forEach(el => {
      const r = el.getBoundingClientRect();
      if (r.top < innerHeight && r.bottom > 0 && !el.classList.contains('in')) {
        el.style.transition = 'none';
        el.classList.add('in');
      }
    });
    requestAnimationFrame(() => revs.forEach(el => { el.style.transition = ''; }));

    const hidden = revs.filter(el => !el.classList.contains('in'));
    hidden.forEach((el, i) => { el.style.transitionDelay = (i % 3 * 70) + 'ms'; });
    _io = new IntersectionObserver(
      es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); _io.unobserve(e.target); } }),
      { threshold: .08, rootMargin: '0px 0px -5% 0px' }
    );
    hidden.forEach(el => _io.observe(el));
    setTimeout(() => revs.forEach(el => el.classList.add('in')), 600);
  });
</script>

</Base>

<style is:global>

/* HERO */
.bhero { padding:160px 0 80px }
.bhero h1 { font-family:var(--display); font-weight:600; font-size:clamp(3rem,9vw,7rem); line-height:.92; letter-spacing:-.03em; max-width:14ch }
.bhero h1 em { font-style:normal; color:var(--gold) }
.bhero p { font-size:clamp(1.05rem,2vw,1.35rem); max-width:52ch; color:var(--text-soft); margin-top:26px }

.bempty { padding:60px 0 120px; color:var(--muted); font-size:1.05rem }

/* FEATURED */
.bfeatured { padding:30px 0 24px }
.bfcard { position:relative; display:grid; grid-template-columns:1.1fr 1fr; gap:0; background:linear-gradient(160deg,var(--ink-2),var(--ink)); border:1px solid var(--line); border-radius:24px; overflow:hidden; transition:transform .4s cubic-bezier(.22,1,.36,1),border-color .4s; min-height:440px }
.bfcard:hover { transform:translateY(-6px); border-color:var(--gold) }
.bfvis { position:relative; background:radial-gradient(circle at 30% 30%,rgba(86,33,94,.6),transparent 60%),linear-gradient(135deg,#2a2030,#15101c); display:flex; align-items:center; justify-content:center; overflow:hidden }
.bfvis img { width:100%; height:100%; object-fit:cover; position:absolute; inset:0; opacity:.8 }
.bfbignum { font-family:var(--display); font-weight:700; font-size:13rem; line-height:1; color:transparent; -webkit-text-stroke:1.5px rgba(245,189,2,.25); user-select:none }
.bfbody { padding:clamp(30px,4vw,54px); display:flex; flex-direction:column; justify-content:center }
.bfbody h2 { font-family:var(--display); font-weight:600; font-size:clamp(2.2rem,4.5vw,3.4rem); line-height:.96; letter-spacing:-.02em; margin-bottom:18px }
.bfbody p { color:var(--text-soft); font-size:1.05rem; margin-bottom:28px; max-width:42ch; line-height:1.6 }
.bffooter { display:flex; align-items:center; justify-content:space-between; gap:16px; flex-wrap:wrap }
.bffooter time { font-size:.82rem; color:var(--muted) }
.bfgo { display:inline-flex; align-items:center; gap:8px; font-family:var(--display); font-weight:600; color:var(--gold); font-size:.95rem }
.bfgo svg { transition:transform .3s }
.bfcard:hover .bfgo svg { transform:translateX(5px) }
@media(max-width:860px) { .bfcard { grid-template-columns:1fr } .bfvis { min-height:240px } .bfbignum { font-size:8rem } }

/* GRID */
.bgrid-sec { padding:24px 0 120px }
.bgh { font-size:.74rem; letter-spacing:.18em; text-transform:uppercase; color:var(--muted); margin:36px 0 24px; padding-bottom:14px; border-bottom:1px solid var(--line) }
.bgrid { display:grid; grid-template-columns:repeat(3,1fr); gap:22px }
@media(max-width:960px) { .bgrid { grid-template-columns:repeat(2,1fr) } }
@media(max-width:600px) { .bgrid { grid-template-columns:1fr } }

.bcard { position:relative; background:linear-gradient(160deg,var(--ink-2),var(--ink)); border:1px solid var(--line); border-radius:18px; overflow:hidden; transition:transform .35s cubic-bezier(.22,1,.36,1),border-color .35s; display:flex; flex-direction:column }
.bcard:hover { transform:translateY(-6px); border-color:var(--gold) }
.bcard-img { width:100%; aspect-ratio:16/10; object-fit:cover; display:block }
.bcard-ph { aspect-ratio:16/10; background:radial-gradient(circle at 60% 30%,rgba(86,33,94,.45),transparent 60%),linear-gradient(135deg,#241b2c,#140f1a); display:flex; align-items:center; justify-content:center }
.bcard-n { font-family:var(--display); font-weight:700; font-size:5rem; color:transparent; -webkit-text-stroke:1px rgba(245,189,2,.2) }
.bcard-body { padding:24px 26px 28px; flex:1; display:flex; flex-direction:column }
.bcard h3 { font-family:var(--display); font-weight:600; font-size:clamp(1.15rem,2vw,1.5rem); letter-spacing:-.01em; margin-bottom:10px; line-height:1.1 }
.bcard p { font-size:.92rem; color:var(--text-prose); line-height:1.6; margin-bottom:16px; flex:1 }
.bcard-foot { display:flex; justify-content:space-between; align-items:center }
.bcard-foot time { font-size:.76rem; color:var(--muted) }
.bcard-arr { color:var(--gold); transition:transform .3s; font-style:normal }
.bcard:hover .bcard-arr { transform:translateX(5px) }

/* REVEAL */
.reveal { opacity:0; transform:translateY(30px); transition:opacity .8s cubic-bezier(.22,1,.36,1),transform .8s cubic-bezier(.22,1,.36,1) }
.reveal.in { opacity:1; transform:none }
@media(prefers-reduced-motion:reduce) { .reveal { opacity:1; transform:none; transition:none } }
</style>
