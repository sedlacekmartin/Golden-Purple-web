---
export const prerender = true;
import Tools from '../../layouts/Tools.astro';
import Arrow from '../../components/Arrow.astro';
---

<Tools
  title="Web scan zdarma — Golden Purple"
  description="Zadejte URL a zjistěte, co váš web brzdí v získávání zákazníků. Rychlost, mobil, SEO. Zdarma od Golden Purple."
>

  <div class="shell">

      <div class="intro" id="intro">
        <div class="itag"><span class="d"></span><span class="mono">Web scan · zdarma</span></div>
        <h1>Co váš web brzdí <em>v získávání zákazníků</em>?</h1>
        <p>Zadejte adresu webu. Za chvíli uvidíte, jak je na tom rychlost, mobil a základy SEO — a co konkrétně zlepšit.</p>
      </div>

      <div class="scanbox">
        <!-- FORM -->
        <div id="formStep">
          <div class="field">
            <input id="urlInput" type="url" placeholder="https://vasweb.cz" autocomplete="off" spellcheck="false" list="url-history">
            <datalist id="url-history"></datalist>
            <button class="scan-btn" id="scanBtn">Spustit scan
              <Arrow />
            </button>
          </div>
          <p class="hint">Trvá ~30 sekund. Měříme reálná data přes Google PageSpeed.</p>
          <p class="err" id="errMsg"></p>
        </div>

        <!-- SCANNING -->
        <div class="scanning" id="scanning">
          <div class="radar"><div class="core"></div></div>
          <p class="status" id="status">Načítám web…</p>
        </div>

        <!-- RESULTS -->
        <div class="results" id="results">
          <p class="res-url">Výsledek pro <b id="resUrl"></b></p>
          <div class="scores" id="scores"></div>
          <div class="gate">
            <div class="gi">
              <h3>Výsledky na email + co řešit nejdřív</h3>
              <p>Pošleme vám shrnutí skóre a konkrétní tipy pro váš web. Zdarma, do pár minut.</p>
              <div class="field">
                <input id="emailInput" type="email" placeholder="vas@email.cz" autocomplete="email">
                <button class="scan-btn" id="sendBtn">Poslat výsledky</button>
              </div>
              <p class="ok" id="okMsg">✓ Hotovo — výsledky dorazí do pár minut.</p>
            </div>
          </div>

          <!-- EDU sekce pod gate -->
          <div class="edu">
            <p class="edu-title">Co jednotlivá skóre znamenají v praxi</p>
            <div class="edu-grid">
              <div class="edu-item">
                <h4>⚡ Rychlost</h4>
                <p>53 % mobilních uživatelů opustí stránku, která se nenačte do 3 sekund.<sup>1</sup> Zrychlení o 0,1 s může zvýšit konverze e-shopu průměrně o 8 %.<sup>2</sup> Google navíc používá Core Web Vitals (rychlost, stabilita layoutu, interaktivita) jako přímý rankingový faktor.<sup>3</sup></p>
              </div>
              <div class="edu-item">
                <h4>🔍 SEO</h4>
                <p>První výsledek na Googlu dostává 27,6 % všech kliků,<sup>4</sup> první stránka jako celek přes 90 % veškeré návštěvnosti.<sup>5</sup> Chybějící meta popis, špatná struktura nadpisů nebo alt texty obrázků snižují šanci na nalezení — a Google si meta popis napíše sám, často nevhodně.</p>
              </div>
              <div class="edu-item">
                <h4>♿ Přístupnost</h4>
                <p>Asi 1,3 miliardy lidí (16 % světové populace) žije s nějakou formou postižení.<sup>6</sup> Nízký kontrast nebo chybějící popisky formulářů ale trápí i běžné uživatele na mobilu na přímém slunci. Od června 2025 navíc platí European Accessibility Act — nové právní povinnosti pro weby soukromých firem.<sup>7</sup></p>
              </div>
              <div class="edu-item">
                <h4>🛡️ Kód & osvědčené postupy</h4>
                <p>Chrome od roku 2018 označuje weby bez HTTPS jako „Nezabezpečeno" přímo v adresním řádku — uživatel to vidí ještě před tím, než se stránka načte. Zastaralé JavaScriptové knihovny s bezpečnostními děrami jsou vstupní branou pro vložení malwaru nebo krádež dat návštěvníků.</p>
              </div>
              <div class="edu-item">
                <h4>🔒 HTTP hlavičky</h4>
                <p>Bezpečnostní HTTP hlavičky jako <em>Content-Security-Policy</em>, <em>HSTS</em> nebo <em>X-Frame-Options</em> chrání návštěvníky před clickjackingem, vložením cizího kódu a man-in-the-middle útoky. Bez nich může útočník přesměrovat prohlížeč uživatele nebo podvrhnout obsah stránky.<sup>8</sup> Mozilla HTTP Observatory hodnotí tyto hlavičky stupnicí A+–F.</p>
              </div>
              <div class="edu-item">
                <h4>🌱 Ekologie webu</h4>
                <p>Internet jako celek odpovídá za 1,5–2 % globálních emisí CO₂ — srovnatelné s leteckou dopravou.<sup>9</sup> Hosting na obnovitelné energii (zelený hosting) je jedním z nejjednodušších kroků ke snížení digitální stopy webu. The Green Web Foundation sleduje, která datacentra a hostingové společnosti používají 100 % zelený proud.<sup>10</sup></p>
              </div>
            </div>
            <p class="edu-sources">
              1. Google, „The Need for Mobile Speed", 2018 &nbsp;·&nbsp;
              2. Google + Deloitte, „Milliseconds Make Millions", 2020 &nbsp;·&nbsp;
              3. Google Search Central, „Page experience in Google Search", 2021 &nbsp;·&nbsp;
              4. Advanced Web Ranking, Organic CTR Study, 2023 &nbsp;·&nbsp;
              5. HubSpot Research, „Marketing Statistics", 2024 &nbsp;·&nbsp;
              6. WHO, „World Report on Disability", 2023 &nbsp;·&nbsp;
              7. Evropský parlament, Směrnice (EU) 2019/882 &nbsp;·&nbsp;
              8. Mozilla Security Wiki, HTTP Observatory &nbsp;·&nbsp;
              9. IEA, „Electricity 2024" &nbsp;·&nbsp;
              10. The Green Web Foundation, greenwebfoundation.org
            </p>
          </div>
        </div>
      </div>

      <p class="foot">Powered by <a href="https://goldenpurple.cz">Golden Purple</a> — postaráme se o vás královsky.</p>
  </div>

  <style is:global>
    :root {
      --green: var(--success);
      --red: var(--danger);
    }
    /* ambient */
    .shell { position: relative; z-index: 2; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; max-width: 760px; margin: 0 auto; padding: 100px 22px 60px }

    /* FORM */
    .scanbox { background: linear-gradient(160deg,var(--ink-2),rgba(12,6,16,.5)); border: 1px solid var(--line); border-radius: 20px; padding: 30px; backdrop-filter: blur(8px) }
    .field { display: flex; gap: 12px; flex-wrap: wrap }
    .field input { flex: 1; min-width: 220px; background: rgba(247,247,247,.04); border: 1px solid var(--line); border-radius: 12px; padding: 17px 20px; color: var(--paper); font-family: var(--body); font-size: 1.05rem; outline: none; transition: border-color .2s }
    .field input:focus { border-color: var(--gold) }
    .field input::placeholder { color: var(--muted) }
    .scan-btn { display: inline-flex; align-items: center; justify-content: center; gap: 10px; background: var(--gold); color: var(--ink); border: none; padding: 17px 30px; border-radius: 12px; font-family: var(--display); font-weight: 600; font-size: 1.05rem; cursor: pointer; transition: transform .2s, box-shadow .2s }
    .scan-btn:hover { transform: translateY(-2px); box-shadow: 0 14px 36px rgba(245,189,2,.38) }
    .scan-btn:disabled { opacity: .6; cursor: wait; transform: none; box-shadow: none }
    .hint { color: var(--muted); font-size: .85rem; margin-top: 14px; text-align: center }
    .err { color: var(--red); font-size: .9rem; margin-top: 14px; text-align: center; display: none }

    /* SCANNING */
    .scanning { display: none; text-align: center; padding: 20px 0 }
    .scanning.on { display: block }
    .radar { width: 120px; height: 120px; margin: 0 auto 24px; position: relative }
    .radar::before, .radar::after { content: ""; position: absolute; inset: 0; border-radius: 50%; border: 2px solid var(--gold); opacity: 0; animation: ping 2s ease-out infinite }
    .radar::after { animation-delay: 1s }
    .radar .core { position: absolute; inset: 42px; border-radius: 50%; background: var(--gold); box-shadow: 0 0 30px var(--gold) }
    .scanning .status { font-family: var(--mono); font-size: .8rem; letter-spacing: .14em; text-transform: uppercase; color: var(--muted) }
    @keyframes ping { 0% { transform: scale(.4); opacity: .8 } 100% { transform: scale(1); opacity: 0 } }

    /* RESULTS */
    .results { display: none }
    .results.on { display: block; animation: fadeUp .6s ease }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px) } to { opacity: 1; transform: none } }
    .res-url { text-align: center; color: var(--muted); margin-bottom: 24px; word-break: break-all }
    .res-url b { color: var(--paper) }
    .scores { display: grid; grid-template-columns: repeat(3,1fr); gap: 14px; margin-bottom: 14px }
    @media(max-width:620px) { .scores { grid-template-columns: repeat(2,1fr) } }
    .sc { background: rgba(247,247,247,.03); border: 1px solid var(--line); border-radius: 16px; padding: 22px 16px; text-align: center }
    .sc .ring { width: 74px; height: 74px; margin: 0 auto 12px; position: relative }
    .sc .ring svg { transform: rotate(-90deg) }
    .sc .ring .val { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-family: var(--display); font-weight: 600; font-size: 1.4rem }
    .sc .lbl { font-family: var(--mono); font-size: .66rem; letter-spacing: .1em; text-transform: uppercase; color: var(--muted) }
    .sc .sc-grade { font-size: .7rem; color: var(--gold); letter-spacing: .1em; font-family: var(--mono); margin-top: 4px; font-weight: 600 }
    .sc .sc-sub { font-size: .68rem; color: var(--muted); margin-top: 3px }
    .sc-na { width: 74px; height: 74px; border-radius: 50%; border: 2px dashed rgba(247,247,247,.12); display: flex; align-items: center; justify-content: center; color: rgba(247,247,247,.25); font-size: 1.3rem; margin: 0 auto 12px }

    /* GATE */
    .gate { background: linear-gradient(150deg,var(--purple),var(--purple-deep)); border: 1px solid var(--line); border-radius: 18px; padding: 30px; margin-top: 22px; text-align: center; position: relative; overflow: hidden }
    .gate::after { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 50% 0,rgba(245,189,2,.2),transparent 60%); pointer-events: none }
    .gate .gi { position: relative; z-index: 2 }
    .gate h3 { font-family: var(--display); font-weight: 600; font-size: 1.6rem; margin-bottom: 10px }
    .gate p { color: var(--text-bright); font-size: .97rem; max-width: 42ch; margin: 0 auto 22px }
    .gate .field { max-width: 440px; margin: 0 auto }
    .gate .ok { display: none; color: var(--gold); font-family: var(--display); font-size: 1.2rem; margin-top: 8px }
    .gate .ok.on { display: block }

    /* EDU */
    .edu { margin-top: 28px; border-top: 1px solid var(--line); padding-top: 24px }
    .edu-title { font-family: var(--mono); font-size: .7rem; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); text-align: center; margin-bottom: 16px }
    .edu-grid { display: grid; grid-template-columns: repeat(2,1fr); gap: 12px; margin-bottom: 18px }
    @media(max-width:560px) { .edu-grid { grid-template-columns: 1fr } }
    .edu-item { background: rgba(247,247,247,.02); border: 1px solid var(--line); border-radius: 12px; padding: 16px }
    .edu-item h4 { font-family: var(--display); font-weight: 600; font-size: .9rem; letter-spacing: -.01em; margin-bottom: 7px; color: var(--paper) }
    .edu-item p { font-size: .82rem; color: var(--muted); line-height: 1.6 }
    .edu-item p sup { font-size: .65rem; color: var(--gold); vertical-align: super; line-height: 0 }
    .edu-sources { font-size: .72rem; color: var(--text-faint); line-height: 2; text-align: center }

    @media(prefers-reduced-motion:reduce) {
      .radar::before, .radar::after { animation: none }
      .results.on { animation: none }
    }
  </style>

  <script>
    let _scanAc: AbortController | null = null;

    document.addEventListener('astro:page-load', () => {
      _scanAc?.abort();
      _scanAc = new AbortController();
      const sig = _scanAc.signal;

      // Zdroj návštěvy z kampaní (utm_source) — přiložíme k leadu, ať je vidět, odkud přišel
      const _src = new URLSearchParams(location.search).get('utm_source');
      if (_src) sessionStorage.setItem('gp_src', _src.slice(0, 40));

      const $ = s => document.querySelector(s);

      /* SCAN */
      const statuses=['Načítám web…','Měřím rychlost…','Kontroluji mobilní verzi…','Prověřuji SEO základy…','Testuju bezpečnostní hlavičky…','Měřím ekologickou stopu…','Skládám výsledky…'];
      let stI=0, stTimer=null, lastScanData=null;

      function showError(msg){$('#errMsg').textContent=msg;$('#errMsg').style.display='block';}
      function clearError(){$('#errMsg').style.display='none';}

      $('#scanBtn').onclick=async()=>{
        let url=$('#urlInput').value.trim();
        if(!url){showError('Zadejte adresu webu.');return;}
        if(!/^https?:\/\//.test(url))url='https://'+url;
        if(!/^https?:\/\/.+\..+/.test(url)){showError('Zadejte platnou adresu včetně domény.');return;}
        clearError();
        $('#formStep').style.display='none';
        $('#scanning').classList.add('on');
        stI=0;$('#status').textContent=statuses[0];
        stTimer=setInterval(()=>{stI=(stI+1)%statuses.length;$('#status').textContent=statuses[stI];},2600);
        try{
          const r=await fetch(`/api/scan?url=${encodeURIComponent(url)}&strategy=mobile`);
          const data=await r.json();
          clearInterval(stTimer);
          if(!r.ok){throw new Error(data.error||'Scan se nezdařil.');}
          saveUrl(url);lastScanData=data;renderResults(data);
        }catch(e){
          clearInterval(stTimer);
          $('#scanning').classList.remove('on');
          $('#formStep').style.display='block';
          showError(e.message||'Něco se pokazilo. Zkuste to prosím znovu.');
        }
      };

      function ring(val){
        const col=val>=90?'var(--success)':val>=50?'#F5BD02':'var(--danger)';
        const r=32,circ=2*Math.PI*r,off=circ*(1-(val||0)/100);
        return `<div class="ring"><svg width="74" height="74"><circle cx="37" cy="37" r="${r}" fill="none" stroke="rgba(247,247,247,.1)" stroke-width="6"/><circle cx="37" cy="37" r="${r}" fill="none" stroke="${col}" stroke-width="6" stroke-linecap="round" stroke-dasharray="${circ}" stroke-dashoffset="${off}"/></svg><span class="val" style="color:${col}">${val??'–'}</span></div>`;
      }

      function renderResults(d){
        $('#scanning').classList.remove('on');
        $('#resUrl').textContent=d.url;
        const map=[['performance','Rychlost'],['seo','SEO'],['accessibility','Přístupnost'],['bestPractices','Kód & postupy']];
        let html=map.map(([k,lbl])=>`<div class="sc">${ring(d.scores[k])}<div class="lbl">${lbl}</div></div>`).join('');
        if(d.observatory){html+=`<div class="sc">${ring(d.observatory.score)}<div class="lbl">HTTP hlavičky</div><div class="sc-grade">${d.observatory.grade}</div></div>`;}
        else{html+=`<div class="sc"><div class="sc-na">–</div><div class="lbl">HTTP hlavičky</div></div>`;}
        if(d.green&&d.green.score!=null){const gl=d.green.green?'🌱 Zelený hosting':'⚫ Konvenční hosting';html+=`<div class="sc">${ring(d.green.score)}<div class="lbl">Ekologie</div><div class="sc-sub">${gl}</div></div>`;}
        else{html+=`<div class="sc"><div class="sc-na">–</div><div class="lbl">Ekologie</div></div>`;}
        $('#scores').innerHTML=html;
        $('#results').classList.add('on');
        // GA4 event přes GTM dataLayer (funguje i před načtením GTM — fronta se přehraje)
        (window.dataLayer=window.dataLayer||[]).push({event:'scan_completed'});
      }

      /* URL HISTORIE */
      const H_KEY='gp_scan_urls';
      function loadHistory(){try{return JSON.parse(localStorage.getItem(H_KEY)||'[]');}catch{return[];}}
      function saveUrl(u){let h=loadHistory().filter(v=>v!==u);h.unshift(u);h=h.slice(0,10);localStorage.setItem(H_KEY,JSON.stringify(h));renderDL();}
      function renderDL(){const dl=document.getElementById('url-history');if(!dl)return;dl.innerHTML='';loadHistory().forEach(u=>{const o=document.createElement('option');o.value=u;dl.appendChild(o);});}
      renderDL();
      $('#urlInput').addEventListener('keydown',e=>{if(e.key==='Enter')$('#scanBtn').click();},{signal:sig});

      /* LEAD CAPTURE */
      $('#sendBtn').onclick=async()=>{
        const email=$('#emailInput').value.trim();
        if(!/^[^@]+@[^@]+\.[^@]+$/.test(email)){showError('Zadejte platný e-mail.');return;}
        clearError();
        $('#sendBtn').disabled=true;$('#sendBtn').textContent='Odesílám…';
        try{
          const res=await fetch('/api/send-results',{method:'POST',headers:{'Content-Type':'application/json'},
            body:JSON.stringify({type:'scan',email,zdroj:sessionStorage.getItem('gp_src')||undefined,...(lastScanData||{})})});
          const data=await res.json();
          if(res.ok&&data.ok){$('#emailInput').value='';$('#emailInput').disabled=true;$('#okMsg').classList.add('on');(window.dataLayer=window.dataLayer||[]).push({event:'lead_submitted',tool:'scan'});}
          else{showError(data.error||'Něco se pokazilo. Zkuste znovu.');$('#sendBtn').disabled=false;$('#sendBtn').textContent='Poslat výsledky';}
        }catch{
          showError('Problém s připojením. Zkuste znovu.');
          $('#sendBtn').disabled=false;$('#sendBtn').textContent='Poslat výsledky';
        }
      };
    });
  </script>
</Tools>
