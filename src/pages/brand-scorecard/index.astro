---
export const prerender = true;
import Tools from '../../layouts/Tools.astro';
---

<Tools
  title="Brand scorecard: Jak silná je vaše značka? — Golden Purple"
  description="Interaktivní test síly značky napříč 5 pilíři. Zaškrtejte, co máte, a zjistěte skóre. Od Golden Purple."
>

<div class="shell">
  <div class="intro">
    <div class="itag"><span class="d"></span><span class="mono">Brand scorecard · 3 minuty</span></div>
    <h1>Jak silná je <em>vaše značka</em>?</h1>
    <p>Pět pilířů, 20 otázek. Zaškrtejte, co o vaší značce platí — dole uvidíte naživo, jak na tom jste.</p>
  </div>

  <div class="pillars" id="pillars"></div>
  <div id="list"></div>

  <div class="sources">
    <div class="sh">Z čeho test vychází</div>
    <p class="si">Scorecard stojí na zavedených principech budování značky — od teorie značky po data o tom, proč si značku lidé pamatují a vybírají.</p>
    <div class="grid">
      <div class="src">
        <div class="t">The Brand Gap</div>
        <div class="a">Marty Neumeier</div>
        <div class="w">Pět disciplín budování značky a propojení strategie s vizuální identitou.</div>
      </div>
      <div class="src">
        <div class="t">How Brands Grow</div>
        <div class="a">Byron Sharp</div>
        <div class="w">Rozpoznatelnost a vybavitelnost značky jako motor růstu, podložené daty.</div>
      </div>
      <div class="src">
        <div class="t">Positioning</div>
        <div class="a">Ries &amp; Trout</div>
        <div class="w">Jak značka zabere jasné místo v hlavě zákazníka — cílovka a odlišení.</div>
      </div>
    </div>
  </div>

  <p class="foot">Powered by <a href="https://goldenpurple.cz">Golden Purple</a> — postaráme se o vás královsky.</p>
</div>

<div class="scorebar">
  <div class="in">
    <div class="meter">
      <div class="top"><span class="label">Síla značky</span><span class="num"><b id="scoreNum">0</b> / 20</span></div>
      <div class="track"><div class="fill" id="fill"></div></div>
      <div class="verdict" id="verdict">Zaškrtejte, co o vaší značce platí.</div>
    </div>
    <button class="cta-btn" id="showResult">Zobrazit výsledek</button>
  </div>
</div>

<div class="modal" id="modal">
  <div class="card">
    <button class="close" id="close">×</button>
    <div class="big"><b id="mScore">0</b></div>
    <div class="of">z 20 bodů síly značky</div>
    <h3 id="mTitle"></h3>
    <p class="vtext" id="mText"></p>
    <div class="breakdown" id="breakdown"></div>
    <div class="gate">
      <p>Chcete vědět, který pilíř posílit první a jak? Pošleme vám konkrétní brand plán na míru — zdarma.</p>
      <div class="field">
        <input id="email" type="email" placeholder="vas@email.cz" autocomplete="email">
        <button id="send">Poslat plán</button>
      </div>
      <p class="okmsg" id="ok">✓ Hotovo — plán dorazí do pár minut.</p>
    </div>
  </div>
</div>

<style is:global>
.shell{position:relative;z-index:2;max-width:760px;margin:0 auto;padding:100px 22px 170px}
.pillars{display:flex;gap:8px;margin:30px 0 8px;flex-wrap:wrap;justify-content:center}
.cat{font-family:var(--mono);font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:600;margin:30px 0 10px;padding-bottom:9px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:baseline}
.cat .cnt{color:var(--muted)}
.breakdown{text-align:left;margin:0 0 22px;border:1px solid var(--line);border-radius:12px;overflow:hidden}
.bd{display:flex;align-items:center;gap:12px;padding:11px 16px;border-bottom:1px solid var(--line)}
.bd:last-child{border-bottom:none}
.bd .bn{flex:1;font-size:.9rem;color:var(--text-soft)}
.bd .bt{height:6px;width:80px;background:rgba(247,247,247,.1);border-radius:100px;overflow:hidden}
.bd .bf{height:100%;background:var(--gold);border-radius:100px}
.bd .bv{font-family:var(--mono);font-size:.74rem;color:var(--muted);min-width:30px;text-align:right}
.sources{margin-top:48px;padding:30px 26px;background:rgba(247,247,247,.025);border:1px solid var(--line);border-radius:18px}
.sources .sh{font-family:var(--mono);font-size:.72rem;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);font-weight:600;margin-bottom:8px}
.sources .si{font-size:.92rem;color:var(--text-prose);line-height:1.5;margin-bottom:18px;max-width:56ch}
.sources .grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
@media(max-width:600px){.sources .grid{grid-template-columns:1fr}}
.src{border:1px solid var(--line);border-radius:12px;padding:16px}
.src .t{font-family:var(--display);font-weight:600;font-size:1.02rem;line-height:1.15;margin-bottom:4px}
.src .a{font-size:.84rem;color:var(--gold);margin-bottom:7px}
.src .w{font-size:.82rem;color:var(--muted);line-height:1.4}
@media(prefers-reduced-motion:reduce){.fill,.bf{transition:none}}
</style>

<script>
document.addEventListener('astro:page-load', () => {
  const groups=[
    {key:'Strategie',cat:'01 · Strategie & positioning',items:[
      ['Víte přesně, kdo je vaše cílovka','Ne „všichni". Konkrétní typ zákazníka, jeho potřeby a jazyk.'],
      ['Umíte říct, čím se lišíte od konkurence','Jednou větou, proč si vyberou vás a ne toho vedle.'],
      ['Máte jasné hlavní sdělení (claim)','Co si má zákazník o vás zapamatovat po prvním kontaktu.'],
      ['Víte, jakou hodnotu reálně prodáváte','Ne produkt, ale výsledek/pocit, který zákazník dostane.'],
    ]},
    {key:'Vizuál',cat:'02 · Vizuální identita',items:[
      ['Máte logo, které funguje i v malé velikosti','Čitelné na profilovce i na vizitce, ne jen na banneru.'],
      ['Máte definované firemní barvy a písmo','Konkrétní hodnoty, ne „tak nějak modrá".'],
      ['Vaše vizuály mají jednotný styl','Fotky, grafika a materiály vypadají jako z jedné rodiny.'],
      ['Máte brand manuál nebo aspoň základní pravidla','I jednoduchý dokument, podle kterého se řídíte.'],
    ]},
    {key:'Konzistence',cat:'03 · Konzistence napříč kanály',items:[
      ['Poznají lidi váš příspěvek, i když nevidí jméno','Vizuální rukopis tak silný, že vás poznají na první pohled.'],
      ['Web, sítě a tiskoviny ladí dohromady','Stejné barvy, písmo a tón všude, kde jste.'],
      ['Používáte stejný tón komunikace všude','Od e-mailu po Instagram mluvíte jedním hlasem.'],
      ['Vaše profilové fotky a hlavičky jsou jednotné','Napříč Googlem, Instagramem, Facebookem stejná tvář.'],
    ]},
    {key:'Online',cat:'04 · Online přítomnost',items:[
      ['Máte web, který reprezentuje vaši úroveň','Ne provizorka — web na úrovni toho, co nabízíte.'],
      ['Jste dohledatelní na Googlu','Když vás někdo hledá jménem i oborem, najde vás.'],
      ['Máte aktivní a aktuální sociální sítě','Ne mrtvý profil s posledním postem z loňska.'],
      ['Máte Google profil firmy s recenzemi','Vyplněný, s hodnocením, vedoucí na web.'],
    ]},
    {key:'Komunikace',cat:'05 · Komunikace & tón',items:[
      ['Mluvíte jazykem zákazníka, ne odborným žargonem','Rozumí vám i člověk mimo váš obor.'],
      ['Vaše texty mají osobitost, ne šablonu','Poznají z nich vaši značku, ne generické fráze.'],
      ['Máte jasné výzvy k akci','Zákazník vždy ví, co má udělat dál.'],
      ['Komunikujete pravidelně, ne nárazově','Vaše značka je vidět konzistentně, ne jednou za čtvrt roku.'],
    ]},
  ];

  const checkSvg='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5"><path d="M5 12l5 5L20 6"/></svg>';
  let n=0;
  const listEl=document.getElementById('list');
  const pillEl=document.getElementById('pillars');
  listEl.innerHTML='';
  pillEl.innerHTML='';

  groups.forEach((g,gi)=>{
    const chip=document.createElement('div');chip.className='pchip';chip.id='chip'+gi;chip.textContent=g.key;pillEl.appendChild(chip);
    const cat=document.createElement('div');cat.className='cat';
    cat.innerHTML=`<span>${g.cat}</span><span class="cnt" id="cnt${gi}">0/${g.items.length}</span>`;listEl.appendChild(cat);
    g.items.forEach(([name,desc])=>{
      n++;const it=document.createElement('div');it.className='item';it.dataset.on='0';it.dataset.g=gi;
      it.innerHTML=`<div class="box">${checkSvg}</div><div class="tx"><div class="n">${name}</div><div class="d">${desc}</div></div>`;
      it.onclick=()=>{it.classList.toggle('on');it.dataset.on=it.classList.contains('on')?'1':'0';update();};
      listEl.appendChild(it);
    });
  });
  const TOTAL=n;

  function verdictFor(s){
    if(s===0)return['Zaškrtejte, co o vaší značce platí.','',''];
    if(s>=17)return['<b>Silná značka.</b> Máte vyladěno víc než většina.','Silná, konzistentní značka','Vaše značka stojí na pevných základech. Pár detailů a jste na špičkové úrovni — to je dobrý čas investovat do růstu.'];
    if(s>=11)return['<b>Slušný základ</b> — ale chybí konzistence.','Dobrý základ, nesourodý celek','Máte stavební kameny, ale nedrží pohromadě. Sjednocení pilířů z vás udělá značku, kterou si lidé pamatují.'];
    if(s>=6)return['<b>Značka zatím nepracuje</b> za vás.','Roztříštěná značka','Jednotlivosti máte, ale jako celek značka nepůsobí. Tady necháváte hodně na stole — a dá se to srovnat.'];
    return['<b>Značka teprve vzniká.</b>','Značka na startu','Zatím spíš firma než značka. Dobrá zpráva: stavíte na zelené louce a každý krok je vidět hned.'];
  }
  function update(){
    const items=[...document.querySelectorAll('.item')];
    const s=items.filter(i=>i.dataset.on==='1').length;
    document.getElementById('scoreNum').textContent=s;
    document.getElementById('fill').style.width=(s/TOTAL*100)+'%';
    document.getElementById('verdict').innerHTML=verdictFor(s)[0];
    document.getElementById('showResult').classList.toggle('ready',s>0);
    groups.forEach((g,gi)=>{
      const done=items.filter(i=>i.dataset.g==gi&&i.dataset.on==='1').length;
      document.getElementById('cnt'+gi).textContent=done+'/'+g.items.length;
      document.getElementById('chip'+gi).classList.toggle('done',done===g.items.length);
    });
  }
  update();

  function openModal(){
    const items=[...document.querySelectorAll('.item')];
    const s=items.filter(i=>i.dataset.on==='1').length;
    const[,title,text]=verdictFor(s);
    document.getElementById('mScore').textContent=s;
    document.getElementById('mTitle').textContent=title||'Začněte zaškrtávat';
    document.getElementById('mText').textContent=text||'';
    document.getElementById('breakdown').innerHTML=groups.map((g,gi)=>{
      const done=items.filter(i=>i.dataset.g==gi&&i.dataset.on==='1').length;
      return `<div class="bd"><span class="bn">${g.key}</span><span class="bt"><span class="bf" style="width:${done/g.items.length*100}%"></span></span><span class="bv">${done}/${g.items.length}</span></div>`;
    }).join('');
    document.getElementById('modal').classList.add('on');
  }
  document.getElementById('showResult').onclick=openModal;
  document.getElementById('close').onclick=()=>document.getElementById('modal').classList.remove('on');
  document.getElementById('modal').onclick=e=>{if(e.target.id==='modal')document.getElementById('modal').classList.remove('on');};
  document.getElementById('send').onclick=async()=>{
    const emailEl=document.getElementById('email');
    const sendBtn=document.getElementById('send');
    const e=emailEl.value.trim();
    if(!/^[^@]+@[^@]+\.[^@]+$/.test(e)){emailEl.style.borderColor='var(--danger)';return;}
    emailEl.style.borderColor='';
    sendBtn.disabled=true;sendBtn.textContent='Odesílám…';
    const items=[...document.querySelectorAll('.item')];
    const s=items.filter(i=>i.dataset.on==='1').length;
    const[,verdict,verdictText]=verdictFor(s);
    const breakdown=groups.map((g,gi)=>{
      const done=items.filter(i=>i.dataset.g==gi&&i.dataset.on==='1').length;
      return{name:g.key,done,total:g.items.length};
    });
    try{
      const res=await fetch('/api/send-results',{method:'POST',headers:{'Content-Type':'application/json'},
        body:JSON.stringify({type:'brand',email:e,score:s,total:TOTAL,verdict,verdictText,breakdown})});
      const data=await res.json();
      if(res.ok&&data.ok){emailEl.value='';emailEl.disabled=true;document.getElementById('ok').classList.add('on');}
      else{sendBtn.disabled=false;sendBtn.textContent='Poslat plán';emailEl.style.borderColor='var(--danger)';}
    }catch{sendBtn.disabled=false;sendBtn.textContent='Poslat plán';}
  };
});
</script>

</Tools>
