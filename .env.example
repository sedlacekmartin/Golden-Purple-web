# ─── Google PageSpeed ────────────────────────────────────────────────────────
# Získáš zdarma v Google Cloud Console → APIs & Services → Credentials
PAGESPEED_API_KEY=

# ─── Resend ───────────────────────────────────────────────────────────────────
# resend.com → API Keys
RESEND_API_KEY=

# Odesílací adresa — doména musí být ověřena v Resend → Domains
# Bez ověření zůstane fallback onboarding@resend.dev (horší doručitelnost)
RESEND_FROM=Golden Purple <info@goldenpurple.cz>

# ─── Kontaktní formulář ───────────────────────────────────────────────────────
# E-mail, na který chodí poptávky
CONTACT_EMAIL=info@goldenpurple.cz

# ─── hCaptcha ─────────────────────────────────────────────────────────────────
# hcaptcha.com → Settings → Secret Key
HCAPTCHA_SECRET=

# ─── Upstash Redis (rate limiting) ───────────────────────────────────────────
# Volitelné v dev, doporučené v produkci — upstash.com → Redis → REST API
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
